           Sin[$CellContext`thetaLean$$ Degree], $CellContext`hHead$$ 
           Cos[$CellContext`thetaLean$$ Degree]}; $CellContext`mH$$ = {
          Part[$CellContext`pH$$, 1] - $CellContext`dHead$$ 
