                   1] $CellContext`degToRad$$]}], {$CellContext`n, 
            1, $CellContext`numPoints$$ + 1}]; $CellContext`mVars$$ = Table[
           Midpoint[{
             Part[$CellContext`pVars$$, $CellContext`n], 
             
             Part[$CellContext`pVars$$, $CellContext`n + 
              1]}], {$CellContext`n, 
            1, $CellContext`numPoints$$}]; $CellContext`torqueVars$$ = 
         Table[Part[
             Part[$CellContext`mVars$$, $CellContext`n], 1] 
           Part[$CellContext`listOfMasses$$, $CellContext`n], {$CellContext`n,
             1, $CellContext`numPoints$$}]; $CellContext`pH$$ = \
