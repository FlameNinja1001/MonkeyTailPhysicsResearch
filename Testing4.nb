           Total[$CellContext`torqueVars$$])^2; $CellContext`output$$ = 
         NMinimize[{$CellContext`objective$$, $CellContext`constraints$$}, \
$CellContext`thetaAdjVars$$]; $CellContext`error$$ = 
         Part[$CellContext`output$$, 1]; $CellContext`thetaAdjVars$$ = 
         Values[
           Part[$CellContext`output$$, 2]]; $CellContext`doubleprev$$ = 
         Part[$CellContext`thetaAdjVars$$, 1] - (
          90 + $CellContext`thetaLean$$); $CellContext`prev$$ = 
         180 - (Part[$CellContext`thetaAdjVars$$, 
            2] - $CellContext`doubleprev$$); $CellContext`thetaVars$$ = 
         Table[
           
           Which[$CellContext`n == 1, 
            Part[$CellContext`thetaAdjVars$$, $CellContext`n] - (
            90 + $CellContext`thetaLean$$), $CellContext`n == 
            2, $CellContext`prev$$ = 
             180 - (Part[$CellContext`thetaAdjVars$$, $CellContext`n] - \
$CellContext`doubleprev$$); 
            180 - (Part[$CellContext`thetaAdjVars$$, $CellContext`n] - \
$CellContext`doubleprev$$), $CellContext`n >= 3, 
            360 - Part[$CellContext`thetaAdjVars$$, $CellContext`n] - (
             Part[$CellContext`thetaAdjVars$$, $CellContext`n - 
               1] - $CellContext`doubleprev$$); $CellContext`prev$$ = 
             360 - Part[$CellContext`thetaAdjVars$$, $CellContext`n] - (
              Part[$CellContext`thetaAdjVars$$, $CellContext`n - 
                1] - $CellContext`doubleprev$$); $CellContext`doubleprev$$ = \
$CellContext`prev$$], {$CellContext`n, 
            1, $CellContext`numPoints$$}]; $CellContext`p$$; \
$CellContext`pVars$$ = Table[
           
           Which[$CellContext`n == 
            1, $CellContext`p$$ = {(-$CellContext`hTail$$) 
              Sin[$CellContext`thetaLean$$ Degree], $CellContext`hTail$$ 
