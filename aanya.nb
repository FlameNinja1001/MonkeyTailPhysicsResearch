Cell[TextData[{
 "Notice how instead of going to the left and down, the point goes to the \
right and up. This means that instead of the subtraction like in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "0f875c4c-67c5-c54d-bc5b-8e4f896036c1"],
 ", addition is used. Thus, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "90dfaab1-f4c0-4b4d-9293-021a95fb5e48"],
 " is defined as the following:"
}], "Text",
 CellChangeTimes->{{3.9293546184036617`*^9, 3.9293546199188967`*^9}, {
