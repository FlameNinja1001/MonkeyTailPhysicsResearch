 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "bfaae874-16fe-f147-8123-18add1b2730e"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "f6f9f6af-f039-ea43-9f96-026ac686c06b"],
