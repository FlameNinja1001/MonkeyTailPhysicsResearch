   3.9926015323784027`*^9},ExpressionUUID->"8d021976-acd6-b443-bf59-\
79ba96bbeead"],

Cell["\<\
Assuming the force to be gravitational force, then F = m * g.\
\>", "Text",
 CellChangeTimes->{{3.992097266395308*^9, 3.9920972777812233`*^9}, {
   3.9920974531310387`*^9, 3.992097472807303*^9}, {3.992097745948107*^9, 
