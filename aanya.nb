  3.9926014685997295`*^9}},ExpressionUUID->"82bcc1bf-e2cb-aa4c-88bc-\
af9827fe4fa9"],

Cell[TextData[{
 "Drawing a vertical line from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "f2abef91-2532-f440-a89a-73cfac429ec0"],
 ", it becomes evident that it\[CloseCurlyQuote]s parallel to the line which \
defines ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "9a1bd94b-c827-1e47-84e1-05294ff9a022"],
 ". By the alternate interior angles theorem, this means that it\
\[CloseCurlyQuote]s congruent to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "a210d325-eb80-924d-8556-0e72864b0afa"],
 ". Since the line between ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "41c691f2-cc69-9f47-a826-d1f2afa86ff8"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "7756cfce-9237-d547-bab3-75df40837fcd"],
 " is 90 degrees, I defined the complementary angle as 90-",
 Cell[BoxData[
  FormBox[
   FormBox[
    SubscriptBox["\[Theta]", "lean"],
    TraditionalForm], TraditionalForm]],ExpressionUUID->
  "0322e44a-f501-3645-b73f-b5983192ab0d"],
 ". However, since this new angle of 90-",
 Cell[BoxData[
  FormBox[
   FormBox[
    SubscriptBox["\[Theta]", "lean"],
    TraditionalForm], TraditionalForm]],ExpressionUUID->
  "3f825e32-48e7-0547-9073-74758296df21"],
 " is also complementary to the missing angle of the right triangle (marked \
in red), I simply defined the triangle\[CloseCurlyQuote]s angle as ",
 Cell[BoxData[
  FormBox[
   FormBox[
    SubscriptBox["\[Theta]", "lean"],
    TraditionalForm], TraditionalForm]],ExpressionUUID->
  "60216933-581d-9f4a-8e9c-841079bad27b"],
 ". In the new diagram below, with the angle defined, the triangle between ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "849e76bc-b873-8e48-8e69-12ecfded5d8e"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "d59ebdee-c36f-404e-a1bb-126c1991c53d"],
 " is now shown."
}], "Text",
 CellChangeTimes->{{3.9293546184036617`*^9, 3.9293546199188967`*^9}, {
