Cell[TextData[{
 "Implementation of these thee formulas for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "1"], TraditionalForm]],ExpressionUUID->
  "628966e0-217b-45f9-8d84-a4370170a8aa"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "n"], TraditionalForm]],ExpressionUUID->
  "b4fecb0c-a077-4389-9a1f-5ac20c431ee2"],
 " using the sum of all past angles to represent ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "f81f782d-e2b0-4581-b88c-2ee69008b83d"],
 ":"
}], "CodeText",
 CellChangeTimes->{{3.9924422581544724`*^9, 3.992442284343647*^9}, {
  3.992467746121683*^9, 3.992467746836852*^9}, {3.992467812534623*^9, 
  3.99246784321319*^9}, {3.9925922893420877`*^9, 
  3.992592314802619*^9}},ExpressionUUID->"22a8eb77-fea3-4557-b6c2-\
20c79c3d2e80"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"thetaVarsFunc", "[", 
    RowBox[{"numPoints_Integer", ",", " ", "thetaLean_Real"}], "]"}], " ", ":=",
    " ", "\n", "\t", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"thetaAdjVars", " ", "=", " ", 
        RowBox[{"Unique", "[", "\"\<thetaAdj\>\"", "]"}]}], ",", " ", 
       "firstTheta"}], "}"}], ",", "\n", "\t", "\n", "\t", 
     RowBox[{
      RowBox[{"If", "[", "\n", "\t\t", 
       RowBox[{
        RowBox[{"thetaLean", " ", ">=", " ", "0"}], ",", " ", "\n", "\t\t", 
        RowBox[{"firstTheta", " ", "=", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Pi", "/", "2"}], " ", "+", " ", "thetaLean"}], ")"}], 
          " ", "-", " ", 
          RowBox[{"thetaAdjVars", "[", "1", "]"}]}]}], ",", " ", "\n", "\t\t", 
        RowBox[{"firstTheta", " ", "=", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Pi", "/", "2"}], " ", "+", " ", "thetaLean"}], ")"}], 
          " ", "-", " ", 
          RowBox[{"thetaAdjVars", "[", "1", "]"}]}]}]}], "]"}], ";", "\n", 
      "\t\t", "\n", "\t", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Table", "[", "\n", "\t\t", 
         RowBox[{
          RowBox[{"Which", "[", "\n", "\t\t\t", 
           RowBox[{
            RowBox[{"n", "==", "1"}], ",", " ", "\n", "\t\t\t", "firstTheta", 
            ",", "\n", "\t\t\t", "True", ",", "\n", "\t\t\t", 
            RowBox[{
             RowBox[{"Sum", "[", 
              RowBox[{
               RowBox[{"thetaAdjVars", "[", "m", "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"m", ",", " ", "2", ",", " ", "n"}], "}"}]}], "]"}], "+",
              " ", "firstTheta"}]}], "]"}], ",", " ", "\n", "\t\t", 
          RowBox[{"{", 
           RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], 
         "]"}], ",", " ", "\n", "\t", "thetaAdjVars"}], "}"}]}]}], "\n", 
    "]"}]}], ";"}]], "Code",
 CellChangeTimes->{{3.992426805286147*^9, 3.99242681081077*^9}, {
  3.992513022168312*^9, 3.992513029447467*^9}, {3.992592282933468*^9, 
  3.992592284682097*^9}, {3.992602875935396*^9, 
  3.992602922220356*^9}},ExpressionUUID->"1a3deeff-1425-40be-b652-\
f643cfaeb14b"],

Cell[TextData[{
 "With all of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "n"], TraditionalForm]],ExpressionUUID->
  "c879bed2-281c-415b-91bd-744f98eb6cc1"],
 " variables defined, I could calculate the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "n"], TraditionalForm]],ExpressionUUID->
  "a71ffe39-c55a-46b3-bfc4-0a1b0445c03b"],
 " point variables via simple trigonometry. Each coordinate, or ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "n"], TraditionalForm]],ExpressionUUID->
  "6037d0e4-9252-4786-a25a-427aea28ae40"],
 ", will be a transformation from the last coordinate in the sequence. To do \
this, I redefined ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "d3882691-90cd-43b8-b48e-5405b02dbb74"],
 " using the same formula in Model V2 that relates ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "7c3f433b-1f49-4c43-a41b-0b495d5b4362"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "8728b828-7cf9-492d-87b8-96893aeb408d"],
 ", and  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "tail"], TraditionalForm]],ExpressionUUID->
  "feadec14-5d29-4097-b39e-3290c0651a7d"],
 ":"
}], "Text",
 CellChangeTimes->{{3.99242681595566*^9, 3.9924268316542253`*^9}, {
   3.9924269672537317`*^9, 3.992426985349269*^9}, {3.992427058181831*^9, 
   3.992427196925643*^9}, {3.992427243838944*^9, 3.992427256946658*^9}, {
   3.9924283426062813`*^9, 3.9924283632840357`*^9}, {3.992428440914689*^9, 
