 ")"
}], "Text",
 CellChangeTimes->{{3.99242681595566*^9, 3.9924268316542253`*^9}, {
  3.9924269672537317`*^9, 3.992426985349269*^9}, {3.992427058181831*^9, 
  3.992427196925643*^9}, {3.992427243838944*^9, 3.992427256946658*^9}, {
  3.9924283426062813`*^9, 3.9924283632840357`*^9}, {3.992428440914689*^9, 
