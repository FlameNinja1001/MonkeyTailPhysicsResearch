b1adb8b33ddc"],

Cell["\<\
Using Wolfram\[CloseCurlyQuote]s built-in Midpoint function to compute the \
center of masses:\
\>", "CodeText",
 CellChangeTimes->{
  3.99244235691253*^9, {3.992592435614058*^9, 
   3.992592435732904*^9}},ExpressionUUID->"2f3086d3-9712-4c96-a02f-\
c49a60f2fdff"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"pVars", " ", "=", " ", 
   RowBox[{"pVarsFunc", "[", 
    RowBox[{
    "numPoints", ",", " ", "hTail", ",", " ", "thetaLean", ",", " ", 
     "listOfDistances", ",", " ", "thetaVars"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"mVars", " ", "=", " ", 
   RowBox[{"Table", "[", "\n", "\t", 
    RowBox[{
     RowBox[{"Midpoint", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"pVars", "[", 
         RowBox[{"[", "n", "]"}], "]"}], ",", " ", 
        RowBox[{"pVars", "[", 
         RowBox[{"[", 
          RowBox[{"n", "+", "1"}], "]"}], "]"}]}], "}"}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], "\n", 
    "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.992429706480315*^9, 3.992429708289136*^9}, {
  3.9925924374874973`*^9, 3.992592439013946*^9}, {3.992593257462973*^9, 
  3.992593261931279*^9}},
 CellLabel->
  "In[125]:=",ExpressionUUID->"fdbaecee-27a4-4131-8d93-630509b58121"],

Cell["\<\
With the center of masses defined, I set up the torque equilibrium equation \
from the past two models. Before doing that, however, I redefined the masses. \
Mass is a similar constant to distance, in that in real tails, it changes \
between joints. For simplicity\[CloseCurlyQuote]s sake, however, I defined it \
as a single constant:\
\>", "Text",
 CellChangeTimes->{{3.9924297840613823`*^9, 3.992429835642281*^9}, {
  3.992429979252898*^9, 3.992429986050687*^9}, {3.9924300328885393`*^9, 
  3.992430126788211*^9}, {3.992430162063816*^9, 3.9924301819042253`*^9}, {
  3.992442435188746*^9, 3.99244244334699*^9}, {3.992598326203429*^9, 
  3.992598346075508*^9}, {3.992598733855364*^9, 3.992598736831396*^9}, {
  3.9926032546824703`*^9, 
  3.9926032602035103`*^9}},ExpressionUUID->"e2378fb8-b6f6-4f47-a41e-\
ec8967497bda"],

Cell["\<\
Using the ConstantArray function to create an n-sized list of masses:\
\>", "CodeText",
 CellChangeTimes->{{3.9924424474598503`*^9, 
  3.9924424667295837`*^9}},ExpressionUUID->"216e8ca5-57b9-4141-9130-\
e1f869d0f251"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mTailConst", " ", "=", " ", "8"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"listOfMasses", " ", "=", " ", 
  RowBox[{"Table", "[", 
   RowBox[{"mTailConst", ",", " ", "numPoints"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.992430201586566*^9, 3.992430203436946*^9}, 
   3.9924390585182323`*^9, {3.992592470770549*^9, 3.992592481818815*^9}},
 CellLabel->
  "In[127]:=",ExpressionUUID->"53812b31-833a-4f83-b811-91d1eeb7fd80"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"8", ",", "8", ",", "8", ",", "8", ",", "8", ",", "8"}], 
  "}"}]], "Output",
 CellChangeTimes->{
  3.992439058785111*^9, {3.99243968046132*^9, 3.992439682144813*^9}, 
   3.99244276627492*^9, 3.992509669066792*^9, 3.992513099980969*^9, 
   3.992545393908687*^9, 3.99254553276812*^9, 3.9925456372889843`*^9, 
   3.992545758278524*^9, {3.992547168522155*^9, 3.9925471850554667`*^9}, 
   3.992547586763054*^9, 3.992554350851391*^9, 3.992591781259225*^9, {
   3.992592472272389*^9, 3.992592482526174*^9}, 3.992592733857678*^9, 
   3.992593902580001*^9, 3.9925963144336023`*^9},
 CellLabel->
  "Out[128]=",ExpressionUUID->"74eb05d9-cb34-46bb-b2a8-ef9469037dce"]
}, Open  ]],

Cell["\<\
I needed to slightly tweak it from the previous two models because the tail \
now has multiple joints. The torque on the tail now is a summation of the \
torque of every individual joint of the tail. This can be represented by the \
following:\
\>", "Text",
 CellChangeTimes->{{3.9924297840613823`*^9, 3.992429835642281*^9}, {
  3.992429979252898*^9, 3.992429986050687*^9}, {3.9924300328885393`*^9, 
  3.992430126788211*^9}, {3.992430162063816*^9, 3.992430178918331*^9}, {
  3.992430333248941*^9, 3.9924303736643457`*^9}, {3.992430412941063*^9, 
  3.992430481540447*^9}, {3.992430522211628*^9, 3.992430532630219*^9}, {
  3.9924424767413387`*^9, 3.9924424862241917`*^9}, {3.9925983497675037`*^9, 
  3.9925983531209393`*^9}, {3.9926032743732166`*^9, 
  3.9926033010374184`*^9}},ExpressionUUID->"2ecec401-c4ef-4aa7-8d41-\
de92a3e4bac7"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["\[Sum]", TraditionalForm]],ExpressionUUID->
  "c7f848e1-3b2f-814a-98ea-c58538596548"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "04a12140-8841-9449-8a6e-836369085388"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "1"], TraditionalForm]],ExpressionUUID->
  "9d589aaa-383f-ec4e-b202-904e2de0146d"],
 ".x * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "837eb154-c072-1e41-9a4e-4af772e5225a"],
 " + ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "2"], TraditionalForm]],ExpressionUUID->
  "67cbf15f-60a3-a34a-a73c-72086b955323"],
 ".x * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "10d52fa0-0d4b-7644-b31e-44b849a2e14b"],
 " + ... +  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "n"], TraditionalForm]],ExpressionUUID->
  "846b31b4-4698-9b4d-8a79-540ef17f7706"],
 ".x * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "f7af3c7b-3910-dc47-bb3e-c078fc8bdf01"]
}], "Text",
 CellChangeTimes->{{3.9924297840613823`*^9, 3.992429835642281*^9}, {
  3.992429979252898*^9, 3.992429986050687*^9}, {3.9924300328885393`*^9, 
  3.992430126788211*^9}, {3.992430162063816*^9, 3.992430178918331*^9}, {
  3.992430333248941*^9, 3.9924303736643457`*^9}, {3.992430412941063*^9, 
  3.992430481540447*^9}, {3.992430522211628*^9, 3.992430532630219*^9}, {
  3.9924424767413387`*^9, 3.9924424862241917`*^9}, {3.9925983497675037`*^9, 
  3.9925983531209393`*^9}, {3.9926032743732166`*^9, 
  3.992603282665472*^9}},ExpressionUUID->"4a9672eb-41b2-b548-9b2d-\
41a64c51d5dd"],

Cell["\<\
Implementing the summation in Wolfram Language by creating a list for each \
torque, and then summing them up using the Total function:\
\>", "CodeText",
 CellChangeTimes->{
  3.9924424909473658`*^9},ExpressionUUID->"0fe02ea9-809e-4a33-961f-\
8faa2d03ff50"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"torqueVars", " ", "=", " ", 
    RowBox[{"Table", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"torqueAtPoint", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"listOfMasses", "[", 
         RowBox[{"[", "n", "]"}], "]"}], ",", " ", 
        RowBox[{"mVars", "[", 
         RowBox[{"[", "n", "]"}], "]"}]}], "]"}], ",", " ", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], "]"}]}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Total", "[", "torqueVars", "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.992430537815002*^9, 3.992430544191409*^9}, {
  3.992592504839736*^9, 3.992592513579604*^9}, {3.992603307311762*^9, 
  3.9926033178954334`*^9}},ExpressionUUID->"e4e4e279-13a3-4a91-babb-\
b5aa386f0844"],

Cell["\<\
Now, to create the equilibrium, I added this total torque to the torque on \
the head, and set it equal to zero:\
\>", "Text",
 CellChangeTimes->{{3.992430546160564*^9, 3.992430574793579*^9}, {
   3.992430647446924*^9, 3.992430686038555*^9}, {3.9924307408162403`*^9, 
   3.992430754278891*^9}, {3.9924385025856943`*^9, 3.992438584663288*^9}, {
   3.992438640573579*^9, 3.992438675778263*^9}, {3.9924389067790003`*^9, 
   3.9924389453976717`*^9}, {3.9924425400360193`*^9, 
   3.9924425947238703`*^9}, {3.9925983574591312`*^9, 3.992598382559623*^9}, 
   3.9926033217682343`*^9},ExpressionUUID->"74f9e66d-0215-461c-b450-\
4f6937391077"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],ExpressionUUID->
  "b0ba972b-538d-fa43-aac8-ef0dec9c1add"],
 " + ",
 Cell[BoxData[
  FormBox["\[Sum]", TraditionalForm]],ExpressionUUID->
  "6da82aa2-901c-df47-b2f5-71b8c7d8804c"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "c93f2b3d-0cdb-d74b-b926-793aad78a9bc"],
 " = 0"
}], "Text",
 CellChangeTimes->{{3.992430546160564*^9, 3.992430574793579*^9}, {
   3.992430647446924*^9, 3.992430686038555*^9}, {3.9924307408162403`*^9, 
   3.992430754278891*^9}, {3.9924385025856943`*^9, 3.992438584663288*^9}, {
   3.992438640573579*^9, 3.992438675778263*^9}, {3.9924389067790003`*^9, 
   3.9924389453976717`*^9}, {3.9924425400360193`*^9, 
   3.9924425947238703`*^9}, {3.9925983574591312`*^9, 3.992598382559623*^9}, 
   3.9926033226463814`*^9},ExpressionUUID->"2d244990-5d47-d14e-ac72-\
2d6ae42a7755"],

Cell[TextData[{
 "Just like the previous NSolve functions in Wolfram for the previous two \
models, I computed each of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "7acf62df-650a-4647-b330-e11ca6e4a779"],
 " values. Before computing the values, I defined constraints such that all \
of the joints do not fold on each other."
}], "Text",
 CellChangeTimes->{{3.992430546160564*^9, 3.992430574793579*^9}, {
  3.992430647446924*^9, 3.992430686038555*^9}, {3.9924307408162403`*^9, 
  3.992430754278891*^9}, {3.9924385025856943`*^9, 3.992438584663288*^9}, {
  3.992438640573579*^9, 3.992438675778263*^9}, {3.9924389067790003`*^9, 
  3.9924389453976717`*^9}, {3.9924425400360193`*^9, 3.9924425947238703`*^9}, {
  3.9925983574591312`*^9, 
  3.992598382559623*^9}},ExpressionUUID->"e9110fb4-8d2b-fd40-ad32-\
cf3e238cd1e6"],

Cell[TextData[{
 "Implementing constraints by once again using the symbolic ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "81c92978-7263-463b-8d12-0020976b9cb5"],
 ". These were found to produce the most \[OpenCurlyDoubleQuote]natural\
\[CloseCurlyDoubleQuote] results:"
}], "CodeText",
 CellChangeTimes->{
  3.992442588732627*^9, {3.992598390880487*^9, 
   3.992598393113414*^9}},ExpressionUUID->"27f9dfcd-b8d8-4ff9-aa3e-\
98001e1a7f69"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"lowerBound", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"upperBound", " ", "=", " ", 
   RowBox[{"2", "Pi"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"constraints", " ", "=", " ", 
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", " ", "<", " ", 
       RowBox[{"thetaAdjVars", "[", "1", "]"}], " ", "<", " ", "Pi"}], "}"}], 
     ",", "\n", "\t", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"lowerBound", " ", "<=", " ", 
        RowBox[{"thetaAdjVars", "[", "n", "]"}], " ", "<", " ", 
        "upperBound"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"n", ",", " ", "2", ",", " ", "numPoints"}], "}"}]}], "]"}]}],
     "\n", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{
  3.992439038272984*^9, {3.992439138154262*^9, 3.9924391412218847`*^9}, {
   3.992592521011835*^9, 3.992592529515367*^9}, {3.992592806391341*^9, 
   3.9925928133969707`*^9}, {3.9926033282635098`*^9, 3.992603342243557*^9}, {
   3.9926084607081547`*^9, 
   3.9926084636081657`*^9}},ExpressionUUID->"3bdebb6e-dceb-47cd-a03e-\
b44ccafce62e"],

Cell["\<\
 With the constraints defined, I could use a process similar to V2\
\[CloseCurlyQuote]s NMinimize function to compute the optimal joint angles:\
\>", "Text",
 CellChangeTimes->{{3.992438950260206*^9, 3.992439027179831*^9}, {
  3.992439695229824*^9, 3.992439748434547*^9}, {3.992442602857543*^9, 
  3.9924426071338167`*^9}, {3.9925984091595097`*^9, 
  3.992598435432671*^9}},ExpressionUUID->"a43bdc87-f6bf-491b-9447-\
0f15f5338d1b"],

Cell["\<\
Defining the objective as the sum of the torques, and then minimizing the \
squared error:\
\>", "CodeText",
 CellChangeTimes->{{3.9924426128251333`*^9, 
  3.992442634112012*^9}},ExpressionUUID->"b8fb71a7-dce6-4309-932c-\
cef1bf6bd563"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"objective", " ", "=", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"torqueAtPoint", "[", 
        RowBox[{"mHead", ",", " ", "mH"}], "]"}], " ", "+", " ", 
       RowBox[{"Total", "[", "torqueVars", "]"}]}], ")"}], "^", "2"}]}], 
   ";"}], "\n", "\t\t"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"output", " ", "=", " ", 
    RowBox[{"NMinimize", "[", "\n", "\t", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"objective", ",", " ", "constraints"}], "}"}], ",", "\n", "\t", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"thetaAdjVars", "[", "n", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", " ", "numPoints"}], "}"}]}], "]"}]}], "\n", 
     "]"}]}], ";"}], "\t"}]}], "Input",
 CellChangeTimes->{{3.992439015782524*^9, 3.992439028276684*^9}, {
   3.992439149208548*^9, 3.992439152034925*^9}, {3.992440359426385*^9, 
   3.992440360679812*^9}, 3.9925925398828697`*^9, {3.992592776418103*^9, 
   3.9925927836163893`*^9}},
 CellLabel->
  "In[134]:=",ExpressionUUID->"bbc4b820-e07b-409b-9b4f-e6df02eb7c89"],

Cell[TextData[{
 "With each of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "43746611-cb04-45e0-b5a8-0435f903e2f8"],
 " values defined, I could plug them back into the symbolic expressions and \
view the outputs by reassigning the physical values from output into the \
symbolic values of thetaAdjVars, and then recomputing the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "n"], TraditionalForm]],ExpressionUUID->
  "98fea0ed-3017-45af-8faa-3c17953b3352"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "n"], TraditionalForm]],ExpressionUUID->
  "c0fc9951-b44c-4825-ae8a-f569e5ca8146"],
 " values:"
}], "Text",
 CellChangeTimes->{{3.992439229258428*^9, 3.992439298651322*^9}, {
  3.9924393352078667`*^9, 3.992439353840773*^9}, {3.992598566295515*^9, 
  3.992598601897092*^9}, {3.9925987402180557`*^9, 
  3.992598740466013*^9}},ExpressionUUID->"efb72c9e-7606-4895-be18-\
670648f7a337"],

Cell["\<\
Reassigning thetaAdjVars to be actual values instead of symbolic ones:\
\>", "CodeText",
 CellChangeTimes->{{3.992442647272934*^9, 
  3.992442659142373*^9}},ExpressionUUID->"7998c34a-1139-4417-a481-\
ee025d410b6c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"thetaAdjs", " ", "=", " ", 
   RowBox[{"Values", "[", 
    RowBox[{"output", "[", 
     RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{3.99243930001608*^9, 3.992592550236196*^9},
 CellLabel->
  "In[136]:=",ExpressionUUID->"2202d2c1-a701-4dfd-a9ff-cad87b887d42"],

Cell[TextData[{
 "Using the newly assigned ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "a48623dc-f6de-4747-ae69-8f480419c82c"],
 " list to reassign the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "n"], TraditionalForm]],ExpressionUUID->
  "1fbe4514-d015-4ea2-b8f7-fc69834df983"],
 " values:"
}], "CodeText",
 CellChangeTimes->{{3.9924427118122787`*^9, 
  3.9924427517380037`*^9}},ExpressionUUID->"682a74d9-4dea-4a61-a499-\
8f8925f4b52a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"thetaVarsFuncEval", "[", 
    RowBox[{
    "numPoints_Integer", ",", " ", "thetaLean_Real", ",", " ", 
     "thetaAdjEval_List"}], "]"}], " ", ":=", " ", "\n", "\t", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "firstTheta", "}"}], ",", "\n", "\t    ", 
     RowBox[{
      RowBox[{"If", "[", "\n", "\t\t    ", 
       RowBox[{
        RowBox[{"thetaLean", " ", ">=", " ", "0"}], ",", " ", "\n", 
        "\t\t    ", 
        RowBox[{"firstTheta", " ", "=", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Pi", "/", "2"}], " ", "+", " ", "thetaLean"}], ")"}], 
          " ", "-", " ", 
          RowBox[{"thetaAdjEval", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}]}], ",", " ", "\n", "\t\t    ", 
        RowBox[{"firstTheta", " ", "=", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Pi", "/", "2"}], " ", "+", " ", "thetaLean"}], ")"}], 
          " ", "-", " ", 
          RowBox[{"thetaAdjEval", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}]}]}], "]"}], ";", "\n", "\t\t", 
      RowBox[{"Table", "[", "\n", "\t\t\t", 
       RowBox[{
        RowBox[{"Which", "[", "\n", "\t\t\t\t", 
         RowBox[{
          RowBox[{"n", "==", "1"}], ",", " ", "\n", "\t\t\t\t", "firstTheta", 
          ",", "\n", "\t\t\t\t", "True", ",", "\n", "\t\t\t\t", 
          RowBox[{
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{"thetaAdjEval", "[", 
              RowBox[{"[", "m", "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"m", ",", " ", "2", ",", " ", "n"}], "}"}]}], "]"}], "+",
            " ", "firstTheta"}]}], "]"}], ",", " ", "\n", "\t\t\t", 
        RowBox[{"{", 
         RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], "\n", 
       "\t\t", "]"}]}]}], "\n", "\t", "]"}]}], ";"}]], "Code",
