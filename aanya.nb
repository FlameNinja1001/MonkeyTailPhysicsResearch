Cell[BoxData[
 RowBox[{"p5Visual", " ", "=", " ", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"p3", "[", 
      RowBox[{"[", "1", "]"}], "]"}], " ", "+", " ", 
     RowBox[{"dTailConst", "*", 
      RowBox[{"Cos", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"90", " ", "+", " ", "thetaLean", "-", "thetaAdjValue"}], 
         ")"}], " ", "Degree"}], "]"}]}]}], ",", " ", 
    RowBox[{
     RowBox[{"p3", "[", 
      RowBox[{"[", "2", "]"}], "]"}], " ", "+", " ", 
     RowBox[{"dTailConst", "*", 
