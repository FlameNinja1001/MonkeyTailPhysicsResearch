Cell[TextData[{
 "Implementing trigonometric functions to solve for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "6ae134ec-e653-406a-b6bd-dd13ddbf81f9"],
 " in the Wolfram Language:"
}], "CodeText",
 CellChangeTimes->{{3.992441188923299*^9, 
  3.992441204753735*^9}},ExpressionUUID->"7fce29c7-c4ca-4f64-8eb0-\
191681483933"],

Cell[BoxData[
 RowBox[{
  RowBox[{"p1", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"p2", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "-", 
      RowBox[{"dHead", "*", 
       RowBox[{"Cos", "[", 
        RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"p2", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "-", 
      RowBox[{"dHead", "*", 
       RowBox[{"Sin", "[", 
        RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}]}], "}"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.99209509573956*^9, 3.992095152566937*^9}},
 CellLabel->"In[84]:=",ExpressionUUID->"4024ce34-5fc2-4029-b060-3ec946e59027"],

Cell[TextData[{
 "I applied the same transformation process to derive ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "6dfd6820-c4b9-43a3-89a5-0cd7638f962e"],
 " from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "1acd41fd-e47c-40e4-bd71-0522df157d70"],
 ". Forming a right triangle from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "85f90e55-185e-440c-b81c-f53a3ead65c2"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "aeea2ab0-2ae1-4e32-bddf-e002d8bb0ecc"],
 ", the congruency with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "e9f9e2c9-692a-4fe1-9902-85c6e74dc8f6"],
 " stays the same as before:"
}], "Text",
