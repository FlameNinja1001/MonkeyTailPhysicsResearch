Cell[TextData[{
 "Defining ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "2cd4e411-c685-4b9e-8748-8796d6afc912"],
 " in Wolfram Language using the currently unknown variable ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "11a3f7b6-9b6e-40b0-b88c-524027e55761"],
 ":"
}], "CodeText",
 CellChangeTimes->{{3.992441910451952*^9, 
  3.992441943097193*^9}},ExpressionUUID->"d9283592-8170-4ae2-bd36-\
8edfa1d87828"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "thetaAdj", "]"}], "\n", 
 RowBox[{
  RowBox[{"p5", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"p3", "[", 
       RowBox[{"[", "1", "]"}], "]"}], " ", "+", " ", 
      RowBox[{"dTailConst", "*", 
       RowBox[{"Cos", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"90", " ", "+", " ", "thetaLean", "-", "thetaAdj"}], ")"}], 
         " ", "Degree"}], "]"}]}]}], ",", " ", 
     RowBox[{
      RowBox[{"p3", "[", 
       RowBox[{"[", "2", "]"}], "]"}], " ", "+", " ", 
      RowBox[{"dTailConst", "*", 
       RowBox[{"Sin", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"90", " ", "+", " ", "thetaLean", "-", "thetaAdj"}], ")"}], 
         " ", "Degree"}], "]"}]}]}]}], "}"}]}], ";"}]}], "Input",
 CellChangeTimes->{
  3.992112681451087*^9, {3.992112901407383*^9, 3.992112950513897*^9}, {
   3.992113151235607*^9, 3.992113153100049*^9}, {3.992114772370968*^9, 
   3.9921147757144947`*^9}, {3.992161791789257*^9, 3.992161792138014*^9}, 
   3.99254727715051*^9, {3.992547610120409*^9, 3.992547614382186*^9}},
 CellLabel->
  "In[103]:=",ExpressionUUID->"88215ad0-85a1-4c15-8dd7-2986488037e0"],

Cell[TextData[{
 "As a result of recalculating ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "d66203de-2470-4ef9-809b-626f79cea8e1"],
 ", the midpoint between ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "d156c170-6263-4a4c-881d-9a31e47e8845"],
 " and  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "06583d46-75a4-48bc-b505-ebe8b5b0821c"],
 ",  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "4"], TraditionalForm]],ExpressionUUID->
  "e68bc3dd-fa63-4ed1-80c4-d946de93e4ca"],
 " also needed to be recalculated:"
}], "CodeText",
 CellChangeTimes->{{3.992112980302924*^9, 3.992113008635346*^9}, {
  3.992597634012143*^9, 
  3.992597645343742*^9}},ExpressionUUID->"719e1795-bb8c-4f9e-b4fe-\
d55a91408e1b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"p4", " ", "=", " ", 
   RowBox[{"Midpoint", "[", 
    RowBox[{"{", 
     RowBox[{"p3", ",", "p5"}], "}"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9921130178423853`*^9, 3.992113023865211*^9}},
 CellLabel->
  "In[105]:=",ExpressionUUID->"10f1b3a7-3c87-4e58-954d-0c7a493bf407"],

Cell[TextData[{
 "I then solved for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "1d26f2e9-c004-4151-b95a-bf57412e66d6"],
 ", but instead of using NSolve, I used Wolfram\[CloseCurlyQuote]s NMinimize \
function because there is multiple solutions.  NMinimize works by finding the \
values which make the objective, the sum of the torques in this case, closest \
to zero. This will output an error value and each of the magnitudes for the \
",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "eef65135-dd47-4823-92a5-6f05c4f60d52"],
 " values. When the error is anything above a near-zero value, it is \
unsolvable given the constraints. "
}], "Text",
 CellChangeTimes->{{3.992547379122067*^9, 3.9925474204969883`*^9}, {
   3.992597649024189*^9, 3.9925976631022453`*^9}, {3.992598445274379*^9, 
   3.992598492774729*^9}, {3.9925987033638906`*^9, 3.992598714361136*^9}, 
   3.9926025720055714`*^9},ExpressionUUID->"6863b261-58d8-4d37-b9c4-\
4f041cc4e5ce"],

Cell["\<\
NMinimize first begins with defining the squared error to minimize:\
\>", "CodeText",
 CellChangeTimes->{{3.9925474252777452`*^9, 
  3.992547441425571*^9}},ExpressionUUID->"f94d6a1e-b5c6-486a-88ff-\
f252067500e6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"objective", " ", "=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"torqueAtPoint", "[", 
       RowBox[{"mTail", ",", " ", "p4"}], "]"}], " ", "+", " ", 
      RowBox[{"torqueAtPoint", "[", 
       RowBox[{"mHead", ",", "p1"}], "]"}]}], ")"}], "^", "2"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{
  3.992547370180601*^9, {3.992547594535014*^9, 3.99254759534606*^9}},
 CellLabel->
  "In[106]:=",ExpressionUUID->"2230f0e2-d3e1-41b9-93a1-1e5f36373947"],

Cell["I then defined constraints to prevent multiple solutions:", "CodeText",
 CellChangeTimes->{{3.992547449379689*^9, 3.992547468932815*^9}, {
  3.9925976653861933`*^9, 
  3.992597666984438*^9}},ExpressionUUID->"786d653d-9120-4840-8e9c-\
e2fd6ee3bd43"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"constraints", "=", 
  RowBox[{"0", "<=", "thetaAdj", "<=", "360"}]}]], "Input",
 CellChangeTimes->{{3.992547470492115*^9, 3.992547476581016*^9}, 
   3.992547598714168*^9},
 CellLabel->
  "In[107]:=",ExpressionUUID->"2e3e9285-abc0-4288-a543-1bc89fdb400d"],

Cell[BoxData[
 RowBox[{"0", "\[LessEqual]", "thetaAdj", "\[LessEqual]", "360"}]], "Output",
 CellChangeTimes->{3.992547599210513*^9, 3.992554349008678*^9, 
  3.99259178018617*^9, 3.992592732613134*^9, 3.992593901580076*^9, 
  3.992596313636175*^9},
 CellLabel->
  "Out[107]=",ExpressionUUID->"8795bb05-6e8d-4668-9403-67a7116682d9"]
}, Open  ]],

Cell[TextData[{
 "Now, given these values, I used NMinimize to find the solution that makes \
the squared error closest to zero, and instead of solving for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "44c66e24-2a5f-4010-af2e-965e109dcff8"],
 ", I solved for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "9bad2deb-b95f-4b18-b238-fb9ec3064b74"],
 ":"
}], "CodeText",
 CellChangeTimes->{{3.992113031538157*^9, 3.992113037122189*^9}, {
  3.992113169446151*^9, 3.992113205577938*^9}, {3.9925472824739857`*^9, 
  3.992547311785128*^9}, {3.992597668977108*^9, 3.992597672648374*^9}, {
  3.992602608044876*^9, 
  3.992602614409357*^9}},ExpressionUUID->"f56550ab-a104-44fd-abf5-\
d1ee50da2520"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"output", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"NMinimize", "[", "\n", "   ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"objective", ",", " ", "constraints"}], "}"}], ",", " ", 
      "thetaAdj"}], "\n", "   ", "]"}], "[", 
    RowBox[{"[", "2", "]"}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9921132253167562`*^9, 3.992113233084573*^9}, {
   3.992114935899324*^9, 3.992114936929109*^9}, 3.992115260419682*^9, 
   3.992123765791855*^9, {3.9921247463888397`*^9, 3.9921247465552263`*^9}, {
   3.992269602373124*^9, 3.9922696307091*^9}, 3.992547484289052*^9, 
   3.992547600846415*^9},
 CellLabel->
  "In[108]:=",ExpressionUUID->"f9faf343-a37f-48f3-a205-72b7753ab0e1"],

Cell[BoxData[
 RowBox[{"thetaAdj", "\[Rule]", "135.83770196374246`"}]], "Output",
 CellChangeTimes->{3.9925476011585217`*^9, 3.992554349750827*^9, 
  3.9925917803051777`*^9, 3.992592733056192*^9, 3.992593901672737*^9, 
  3.992596313737653*^9},
 CellLabel->
  "Out[108]=",ExpressionUUID->"fd9498f4-0ac1-4b9b-b036-e09bbafcd18c"]
}, Open  ]],

Cell["I then extracted the raw value inside the larger list:", "CodeText",
