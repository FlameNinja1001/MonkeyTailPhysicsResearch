Cell[TextData[{
 "This is when the monkey is standing perfectly upright. However, the monkey \
will not always be standing perfectly upright. Thus, I factored in a 7th \
variable, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "af0b0699-6f5a-6f4a-86d0-ca3b93f8adf3"],
 ". In my diagram and in Wolfram Language, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "3aaa5b87-c456-f347-9e6c-3c9434b912dc"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "6"], TraditionalForm]],ExpressionUUID->
  "6eca7ed5-d0d5-3a4d-8489-92a5ab67dca7"],
 " looked like this:"
}], "Text",
