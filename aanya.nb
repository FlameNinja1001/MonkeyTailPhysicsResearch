Cell["\<\
With this, I modified the function from V1 to visualize the V2 model. Note, \
however, that, because the tail is now rotating, and has a limit between 0 \
and 180 degrees, there are going to be some physically impossible \
combinations of givens. This will result in a perfectly flat tail. I will \
circumvent this later, however.\
\>", "Text",
 CellChangeTimes->{{3.992124649235635*^9, 3.992124680091261*^9}, {
  3.992124878277014*^9, 3.9921249492658587`*^9}, {3.992597688584281*^9, 
  3.992597710569669*^9}, {3.9926026340882187`*^9, 
  3.9926026487255325`*^9}},ExpressionUUID->"721d174e-23ef-488a-971c-\
082038f7da93"],

Cell["\<\
Defining a function for all the prior computations listed above:\
\>", "CodeText",
 CellChangeTimes->{{3.9924420572247667`*^9, 3.9924420656637697`*^9}, 
   3.992511912021517*^9},ExpressionUUID->"44b911c3-5b80-4bb4-af3e-\
b62048ffe6e9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"drawMonkey2", "[", "thetaLean_", "]"}], ":=", "\n", "\t", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "p1", ",", "p2", ",", "p3", ",", "p4", ",", "p5", ",", "p6", ",", 
      "p5Visual", ",", "p4Visual", ",", "thetaAdjValue", ",", "dTailConst", ",",
       " ", "output"}], "}"}], ",", "\n", "\t", "\n", "\t\t", 
    RowBox[{
     RowBox[{"dTailConst", " ", "=", " ", "5"}], ";", "\n", "\t\t", 
     RowBox[{"p6", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ";", "\n", "\t\t", 
     RowBox[{"p2", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "hHead"}], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", " ", 
        RowBox[{"hHead", "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], ";", "\n",
      "\t    ", 
     RowBox[{"p3", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "hTail"}], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", " ", 
        RowBox[{"hTail", "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], ";", "\n",
      "\t    ", 
     RowBox[{"p1", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"p2", "[", 
          RowBox[{"[", "1", "]"}], "]"}], " ", "-", " ", 
         RowBox[{"dHead", "*", 
          RowBox[{"Cos", "[", 
           RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], ",", " ", 
        RowBox[{
         RowBox[{"p2", "[", 
          RowBox[{"[", "2", "]"}], "]"}], " ", "-", " ", 
         RowBox[{"dHead", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}]}], "}"}]}], ";", 
     "\n", "\t    \t\t\t", "\n", "\t    ", 
     RowBox[{"p5", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"p3", "[", 
          RowBox[{"[", "1", "]"}], "]"}], " ", "+", " ", 
         RowBox[{"dTailConst", "*", 
          RowBox[{"Cos", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"90", " ", "+", " ", "thetaLean", "-", "thetaAdj"}], 
             ")"}], " ", "Degree"}], "]"}]}]}], ",", " ", 
        RowBox[{
         RowBox[{"p3", "[", 
          RowBox[{"[", "2", "]"}], "]"}], " ", "+", " ", 
         RowBox[{"dTailConst", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"90", " ", "+", " ", "thetaLean", "-", "thetaAdj"}], 
             ")"}], " ", "Degree"}], "]"}]}]}]}], "}"}]}], ";", "\n", 
     "\t    ", 
     RowBox[{"p4", " ", "=", " ", 
      RowBox[{"Midpoint", "[", 
       RowBox[{"{", 
        RowBox[{"p3", ",", " ", "p5"}], "}"}], "]"}]}], ";", "\n", "\t   ", 
     "\n", "\t   ", 
     RowBox[{"objective", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"torqueAtPoint", "[", 
          RowBox[{"mTail", ",", " ", "p4"}], "]"}], " ", "+", " ", 
         RowBox[{"torqueAtPoint", "[", 
          RowBox[{"mHead", ",", "p1"}], "]"}]}], ")"}], "^", "2"}]}], ";", 
     "\n", "\t   ", 
     RowBox[{"constraints", " ", "=", " ", 
      RowBox[{"0", " ", "<=", " ", "thetaAdj", " ", "<=", " ", "360"}]}], ";",
      "\n", "\t   ", "\n", "\t   ", 
     RowBox[{"output", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"NMinimize", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"objective", ",", " ", "constraints"}], "}"}], ",", " ", 
          "thetaAdj"}], "]"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", "\t   ", 
     RowBox[{"thetaAdjValue", " ", "=", " ", 
      RowBox[{"Values", "@", "output"}]}], ";", "\n", "\t   ", "\n", "\t   ", 
     
     RowBox[{"p5Visual", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"p3", "[", 
          RowBox[{"[", "1", "]"}], "]"}], " ", "+", " ", 
         RowBox[{"dTailConst", "*", 
          RowBox[{"Cos", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"90", " ", "+", " ", "thetaLean", "-", "thetaAdjValue"}],
              ")"}], " ", "Degree"}], "]"}]}]}], ",", " ", 
        RowBox[{
         RowBox[{"p3", "[", 
          RowBox[{"[", "2", "]"}], "]"}], " ", "+", " ", 
         RowBox[{"dTailConst", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"90", " ", "+", " ", "thetaLean", "-", "thetaAdjValue"}],
              ")"}], " ", "Degree"}], "]"}]}]}]}], "}"}]}], ";", "\n", "\t\t", 
     RowBox[{"Graphics", "[", 
      RowBox[{
       RowBox[{"{", "\n", "\t\t\t", 
        RowBox[{"Blue", ",", 
         RowBox[{"{", "\n", "\t\t\t\t", 
          RowBox[{
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{"p1", ",", "p2"}], "}"}], "]"}], ",", "\n", "\t\t\t\t", 
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{"p6", ",", "p3"}], "}"}], "]"}], ",", "\n", "\t\t\t\t", 
           RowBox[{"Line", "[", 
            RowBox[{"{", 
