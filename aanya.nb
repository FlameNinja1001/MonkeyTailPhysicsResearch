Cell[TextData[{
 "This time, the angle from the horizontal to the new horizontal axis for the \
unit circle is ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "2"], TraditionalForm]],ExpressionUUID->
  "37ea752d-bc67-6943-aa9d-7cbdf1bcb17e"],
 ". This means that the total angle, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "3"], TraditionalForm]],ExpressionUUID->
  "29515f32-e10f-5648-b93e-4e034126deb8"],
 ", is the sum of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj3"], TraditionalForm]],ExpressionUUID->
  "2bf71c29-2ee6-ca48-b49f-26240cf349a3"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "2"], TraditionalForm]],ExpressionUUID->
  "4bc1ebf1-dc7e-ac48-88e7-17474f97c48d"],
 ":"
}], "Text",
