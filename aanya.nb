              Part[$CellContext`thetaAdjEval, $CellContext`m], \
{$CellContext`m, 
               2, $CellContext`n}] + $CellContext`firstTheta], \
{$CellContext`n, 
            1, $CellContext`numPoints}]], $CellContext`pEvals = \
{{-0.4110438076762634, 0.9116155923255147}, {0.2561602062696075, 
