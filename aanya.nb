Cell[TextData[{
 "In this case, I knew the the length, the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "5be99863-99c8-6a4d-9052-5f901e2f82d5"],
 " constant, and the angle, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "e9e796dc-d4b1-a44c-a4c1-5acf60c82226"],
 ". Because ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "9fb9c33b-9092-3a4f-81f1-9a9d394b0f2f"],
 " is with respect to the horizontal, I defined any given ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "n"], TraditionalForm]],ExpressionUUID->
  "2c3e0f1e-c3df-de43-aa98-84f7775ba470"],
 " coordinate as the following:"
}], "Text",
 CellChangeTimes->{{3.9926030450437317`*^9, 
  3.9926030895211163`*^9}},ExpressionUUID->"940edb46-6a01-1a4b-b90e-\
41c48ed3cf03"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "n"], " "}], TraditionalForm]],ExpressionUUID->
  "7e62bdc4-7016-544a-b45a-d43f319d2bad"],
 "= ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", 
     RowBox[{"n", "-", "1"}]], " "}], TraditionalForm]],ExpressionUUID->
  "29d00d54-8d66-c14b-af61-94acd4c06225"],
 " + (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "tail"], " "}], TraditionalForm]],ExpressionUUID->
  "d0e09191-3691-8a4c-ad98-797fe108d6a1"],
 " * cos(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "e4c51c02-b151-5f44-9fd1-80315279d81d"],
 "), ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "tail"], " "}], TraditionalForm]],ExpressionUUID->
  "eb2e4de9-8858-c441-81f4-e1b8cd10df7b"],
 " * sin(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "2ab069fa-02ee-3144-a39e-dc292f796302"],
 ")); n \[GreaterEqual] 1"
}], "Text",
 CellChangeTimes->{{3.99242681595566*^9, 3.9924268316542253`*^9}, {
   3.9924269672537317`*^9, 3.992426985349269*^9}, {3.992427058181831*^9, 
   3.992427196925643*^9}, {3.992427243838944*^9, 3.992427256946658*^9}, {
   3.9924283426062813`*^9, 3.9924283632840357`*^9}, {3.992428440914689*^9, 
   3.992428508029765*^9}, {3.9924285875910263`*^9, 3.992428592161234*^9}, {
   3.992428694607253*^9, 3.9924288026147327`*^9}, {3.992429547736376*^9, 
   3.992429584315475*^9}, {3.9924471782497063`*^9, 3.99244718720131*^9}, {
   3.992447226014073*^9, 3.992447231642888*^9}, {3.992447267338966*^9, 
   3.9924473075442677`*^9}, {3.992447848477474*^9, 3.992447906482706*^9}, {
   3.992592324778256*^9, 3.9925924025153418`*^9}, {3.9925954060668383`*^9, 
   3.9925954127888117`*^9}, 3.992595625175288*^9, {3.9925956936906967`*^9, 
   3.992595712618218*^9}, {3.9925958222535343`*^9, 3.992595863634849*^9}, {
   3.992598214439296*^9, 3.992598298918353*^9}, {3.992598529579605*^9, 
   3.992598552427783*^9}, {3.992598718487774*^9, 3.992598726887692*^9}, {
   3.9926018674302425`*^9, 3.9926018804341736`*^9}, {3.992603027844036*^9, 
   3.9926030308726482`*^9}},ExpressionUUID->"484ee98b-d465-cd42-ad99-\
d6a058f0da67"],

Cell["\<\
This formula can be implemented in the Wolfram Language using Table and an \
empty variable \[OpenCurlyDoubleQuote]p\[CloseCurlyDoubleQuote] to keep track \
of the last known point. Note that I added numPoints by 1 for the total \
number of points, as each joint has a start and endpoint, thus meaning that \
for example for 3 joints, there are actually 4 points:\
\>", "Text",
 CellChangeTimes->{{3.99242681595566*^9, 3.9924268316542253`*^9}, {
   3.9924269672537317`*^9, 3.992426985349269*^9}, {3.992427058181831*^9, 
   3.992427196925643*^9}, {3.992427243838944*^9, 3.992427256946658*^9}, {
   3.9924283426062813`*^9, 3.9924283632840357`*^9}, {3.992428440914689*^9, 
   3.992428508029765*^9}, {3.9924285875910263`*^9, 3.992428592161234*^9}, {
   3.992428694607253*^9, 3.9924288026147327`*^9}, {3.992429547736376*^9, 
   3.992429584315475*^9}, {3.9924471782497063`*^9, 3.99244718720131*^9}, {
   3.992447226014073*^9, 3.992447231642888*^9}, {3.992447267338966*^9, 
   3.9924473075442677`*^9}, {3.992447848477474*^9, 3.992447906482706*^9}, {
   3.992592324778256*^9, 3.9925924025153418`*^9}, {3.9925954060668383`*^9, 
   3.9925954127888117`*^9}, 3.992595625175288*^9, {3.9925956936906967`*^9, 
   3.992595712618218*^9}, {3.9925958222535343`*^9, 3.992595863634849*^9}, {
   3.992598214439296*^9, 3.992598298918353*^9}, {3.992598529579605*^9, 
   3.992598552427783*^9}, {3.992598718487774*^9, 3.992598726887692*^9}, {
   3.9926018674302425`*^9, 
   3.992601876870371*^9}},ExpressionUUID->"01adbfae-f9e3-c147-9311-\
659b9baab8fd"],

Cell[TextData[{
 "Implementation of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "n"], TraditionalForm]],ExpressionUUID->
  "ab44ca6c-8944-4ebb-afe7-d789830dd6e5"],
 " formula recursively in the Wolfram Language:"
}], "CodeText",
 CellChangeTimes->{{3.992442303839573*^9, 
  3.992442319230948*^9}},ExpressionUUID->"cea39da1-dec5-42d1-8e78-\
eaa12fe735ba"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"pVarsFunc", "[", 
    RowBox[{
    "numPoints_Integer", ",", " ", "hTail_Real", ",", " ", "thetaLean_Real", ",",
      " ", "distances_List", ",", " ", "theta_List"}], "]"}], " ", ":=", " ", 
   "\n", "\t", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "p", "}"}], ",", "\n", "\t\t", 
     RowBox[{"Table", "[", "\n", "\t\t\t", 
      RowBox[{
       RowBox[{"Which", "[", "\n", "\t\t\t\t", 
        RowBox[{
         RowBox[{"n", "==", "1"}], ",", " ", "\n", "\t\t\t\t", 
         RowBox[{"p", " ", "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "hTail"}], "*", 
             RowBox[{"Sin", "[", "thetaLean", "]"}]}], ",", " ", 
            RowBox[{"hTail", "*", 
             RowBox[{"Cos", "[", "thetaLean", "]"}]}]}], "}"}]}], ",", "\n", 
         "\t\t\t\t", 
         RowBox[{"n", ">=", "2"}], ",", " ", "\n", "\t\t\t\t", 
         RowBox[{"p", " ", "+=", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"distances", "[", 
              RowBox[{"[", 
               RowBox[{"n", "-", "1"}], "]"}], "]"}], "*", 
             RowBox[{"Cos", "[", 
              RowBox[{"theta", "[", 
               RowBox[{"[", 
                RowBox[{"n", "-", "1"}], "]"}], "]"}], "]"}]}], ",", " ", 
            "\n", "\t\t\t\t\t", 
            RowBox[{
             RowBox[{"distances", "[", 
              RowBox[{"[", 
               RowBox[{"n", "-", "1"}], "]"}], "]"}], "*", 
             RowBox[{"Sin", "[", 
              RowBox[{"theta", "[", 
               RowBox[{"[", 
                RowBox[{"n", "-", "1"}], "]"}], "]"}], "]"}]}]}], "}"}]}]}], 
        "]"}], ",", "\n", "\t\t\t\t", 
       RowBox[{"{", 
        RowBox[{"n", ",", " ", "1", ",", " ", 
         RowBox[{"numPoints", "+", "1"}]}], "}"}]}], "\n", "\t\t\t", "]"}]}], 
    "\n", "\t", "]"}]}], ";"}]], "Code",
 CellChangeTimes->{{3.99242881265384*^9, 3.992428815441949*^9}, 
   3.9925924132613077`*^9, {3.9926031096604404`*^9, 
   3.9926031556550617`*^9}},ExpressionUUID->"da6b1833-59c6-4dcb-9aa4-\
3538736d0457"],

Cell["\<\
With the points solved for, I algorithmically calculated the center of \
masses. Each center of mass is simply the midpoint between the endpoints of a \
joint. Thus, I used the following formula knowing that there is n+1 total \
number of points:\
\>", "Text",
 CellChangeTimes->{{3.99242681595566*^9, 3.9924268316542253`*^9}, {
   3.9924269672537317`*^9, 3.992426985349269*^9}, {3.992427058181831*^9, 
   3.992427196925643*^9}, {3.992427243838944*^9, 3.992427256946658*^9}, {
   3.9924283426062813`*^9, 3.9924283632840357`*^9}, {3.992428440914689*^9, 
   3.992428508029765*^9}, {3.9924285875910263`*^9, 3.992428592161234*^9}, {
   3.992428694607253*^9, 3.992428800596725*^9}, {3.992429431698173*^9, 
   3.992429448344366*^9}, {3.992429538396015*^9, 3.992429545007667*^9}, {
   3.9924295889379663`*^9, 3.99242969743328*^9}, {3.9924423262708597`*^9, 
   3.992442349004857*^9}, {3.9925983032479362`*^9, 3.992598320809457*^9}, 
   3.9926031646151886`*^9},ExpressionUUID->"e0a3933a-f3a9-4083-a682-\
caede70afb9b"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "n"], " "}], TraditionalForm]],ExpressionUUID->
  "e356b326-1084-cb4e-9d99-b8f1740387aa"],
 "=  midpoint(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "n"], TraditionalForm]],ExpressionUUID->
