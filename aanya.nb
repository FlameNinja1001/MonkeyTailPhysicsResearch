$CellContext`numPoints$$}]]; $CellContext`error = 
        Part[$CellContext`output, 1]; $CellContext`thetaAdjs = Values[
          
          Part[$CellContext`output, 
           
           2]]; $CellContext`thetas = \
$CellContext`thetaVarsFuncEval[$CellContext`numPoints$$, \
$CellContext`thetaLean$$, $CellContext`thetaAdjs]; $CellContext`pEvals = \
$CellContext`pVarsFunc[$CellContext`numPoints$$, $CellContext`hTail, \
