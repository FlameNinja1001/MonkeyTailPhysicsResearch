Cell[TextData[{
 "In V1, recall ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "57592068-ddc6-4f88-aa36-3467ba5567f1"],
 " was defined as the following:"
}], "Text",
 CellChangeTimes->{{3.9921006037133503`*^9, 3.992100622324725*^9}, {
  3.992112560594152*^9, 3.992112565902768*^9}, {3.992112666101972*^9, 
  3.992112771642489*^9}, {3.9921128088760357`*^9, 3.992112976802414*^9}, {
  3.992113080218974*^9, 3.992113106086329*^9}, {3.992426992229374*^9, 
  3.9924269945582542`*^9}, {3.992441851560953*^9, 3.99244185371099*^9}, {
  3.99244196607198*^9, 3.992441971152405*^9}, {3.992547219500305*^9, 
  3.99254727054673*^9}, {3.99255454013698*^9, 3.992554551305415*^9}, {
  3.992591199570836*^9, 3.992591335034568*^9}, {3.992591417807701*^9, 
  3.992591507651742*^9}, {3.9925976066891727`*^9, 3.9925976296804457`*^9}, {
  3.992601591631201*^9, 
  3.992601606145481*^9}},ExpressionUUID->"5bd4b65e-f092-440c-a9e1-\
f65592315ea1"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "24508511-7051-e248-a22f-9071a641dcd1"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "e8e10064-f1b2-8b4a-9926-78e290f2cfd8"],
 " + (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "578a76d1-ae8a-5f46-8019-3c57bc98c31b"],
 "*cos(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "d1ecbcb2-4cd8-6749-8ffc-c25532abbb57"],
 "),",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "e78a4063-8d92-8b46-89e2-a794551ca50b"],
 "*sin(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "d4c72ed9-dbab-b945-aa47-444d9374b522"],
 "))"
}], "Text",
 CellChangeTimes->{{3.9921006037133503`*^9, 3.992100622324725*^9}, {
  3.992112560594152*^9, 3.992112565902768*^9}, {3.992112666101972*^9, 
  3.992112771642489*^9}, {3.9921128088760357`*^9, 3.992112976802414*^9}, {
  3.992113080218974*^9, 3.992113106086329*^9}, {3.992426992229374*^9, 
  3.9924269945582542`*^9}, {3.992441851560953*^9, 3.99244185371099*^9}, {
  3.99244196607198*^9, 3.992441971152405*^9}, {3.992547219500305*^9, 
  3.99254727054673*^9}, {3.99255454013698*^9, 3.992554551305415*^9}, {
  3.992591199570836*^9, 3.992591335034568*^9}, {3.992591417807701*^9, 
  3.992591507651742*^9}, {3.9925976066891727`*^9, 3.9925976296804457`*^9}, {
  3.992601591631201*^9, 
  3.992601609552702*^9}},ExpressionUUID->"e620ba52-34f6-2244-9881-\
ca5f7b8447b3"],

Cell[TextData[{
 "However, as this diagram shows, because the angle to calculate isn\
\[CloseCurlyQuote]t a perfect 90 anymore, it\[CloseCurlyQuote]s not ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "608614bb-3702-7345-9d22-f8a3d11bbee3"],
 " exactly. The angle can still be defined, however, using the new ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "c15a1589-5ba4-1a4e-a58b-74229a84cc4d"],
 ". It\[CloseCurlyQuote]s shown in the image that the angle for the triangle, \
as well as ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "43400a08-dc85-4144-a3c1-9c38bd333326"],
 ", are part of a larger angle defined by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "ddb1f8ab-724c-5340-a00a-19c95dcf912c"],
 " and a 90 degree angle. Knowing that, I subtracted  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "97c8411e-53e7-0f4a-a3d9-e9ab6c34c4f3"],
 " from the larger angle to get it and then solve for the remaining parts of \
the model:"
}], "Text",
 CellChangeTimes->{{3.9921006037133503`*^9, 3.992100622324725*^9}, {
   3.992112560594152*^9, 3.992112565902768*^9}, {3.992112666101972*^9, 
   3.992112771642489*^9}, {3.9921128088760357`*^9, 3.992112976802414*^9}, {
   3.992113080218974*^9, 3.992113106086329*^9}, {3.992426992229374*^9, 
   3.9924269945582542`*^9}, {3.992441851560953*^9, 3.99244185371099*^9}, {
   3.99244196607198*^9, 3.992441971152405*^9}, {3.992547219500305*^9, 
   3.99254727054673*^9}, {3.99255454013698*^9, 3.992554551305415*^9}, {
   3.992591199570836*^9, 3.992591335034568*^9}, {3.992591417807701*^9, 
   3.992591507651742*^9}, {3.9925976066891727`*^9, 3.9925976296804457`*^9}, {
   3.992601591631201*^9, 3.9926016115601444`*^9}, 
   3.992602543435562*^9},ExpressionUUID->"10fd468c-cdd4-e84d-887e-\
f63842bb97c8"],

