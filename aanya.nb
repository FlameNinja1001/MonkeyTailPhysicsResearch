   RowBox[{" ", 
    RowBox[{"90", "+", 
     SubscriptBox["\[Theta]", "lean"]}]}], TraditionalForm]],ExpressionUUID->
  "b4a9725d-6f3c-074e-b296-bff74bbcdb3f"],
 "-",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "16d0f739-dffa-e748-99ed-8f9a3a3dc762"],
 "),",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "7b987dcb-56a9-414b-acd2-fe5c3c57999a"],
 "*sin(",
 Cell[BoxData[
  FormBox[
   RowBox[{"90", "+", 
    SubscriptBox["\[Theta]", "lean"]}], TraditionalForm]],ExpressionUUID->
  "274dcf9e-1f5b-fc45-ac2a-1dd96fd13b83"],
 "-",
 Cell[BoxData[
  FormBox[
