Cell[TextData[{
 "Creating symbolic values for the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "481904a3-82b5-46b1-ac04-afba7055731e"],
 " values to be solved later:"
}], "CodeText",
 CellChangeTimes->{{3.99244218764997*^9, 
  3.9924422131880302`*^9}},ExpressionUUID->"536cd9a8-84c0-4121-b74e-\
00ed6c273b45"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"thetaAdjVars", "[", "n", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", " ", "numPoints"}], "}"}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.9924250319804783`*^9, 3.992425065090556*^9}, 
   3.992439049294832*^9, {3.992442194412589*^9, 3.992442194841529*^9}, {
   3.992591854263054*^9, 3.992591910560192*^9}, {3.9925928837269697`*^9, 
