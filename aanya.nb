     ImageSizeCache->{
      813.1199999999999, {204.09487313097344`, 209.8268065565266}},
     SingleEvaluation->True],
    Deinitialization:>None,
    DynamicModuleValues:>{},
    Initialization:>({$CellContext`drawMonkey2[
         Pattern[$CellContext`thetaLean, 
          Blank[]]] := 
       Module[{$CellContext`p1, $CellContext`p2, $CellContext`p3, \
$CellContext`p4, $CellContext`p5, $CellContext`p6, $CellContext`p5Visual, \
$CellContext`p4Visual, $CellContext`thetaAdjValue, $CellContext`dTailConst, \
$CellContext`output}, $CellContext`dTailConst = 
          5; $CellContext`p6 = {0, 
           0}; $CellContext`p2 = {(-$CellContext`hHead) 
            Sin[$CellContext`thetaLean Degree], $CellContext`hHead 
            Cos[$CellContext`thetaLean 
              Degree]}; $CellContext`p3 = {(-$CellContext`hTail) 
            Sin[$CellContext`thetaLean Degree], $CellContext`hTail 
            Cos[$CellContext`thetaLean Degree]}; $CellContext`p1 = {
           Part[$CellContext`p2, 1] - $CellContext`dHead 
            Cos[$CellContext`thetaLean Degree], 
            Part[$CellContext`p2, 2] - $CellContext`dHead 
            Sin[$CellContext`thetaLean Degree]}; $CellContext`p5 = {
           Part[$CellContext`p3, 1] + $CellContext`dTailConst 
             Cos[(90 + $CellContext`thetaLean - $CellContext`thetaAdj) 
               Degree], 
            Part[$CellContext`p3, 2] + $CellContext`dTailConst 
             Sin[(90 + $CellContext`thetaLean - $CellContext`thetaAdj) 
               Degree]}; $CellContext`p4 = 
          Midpoint[{$CellContext`p3, $CellContext`p5}]; \
$CellContext`objective = ($CellContext`torqueAtPoint[$CellContext`mTail, \
$CellContext`p4] + $CellContext`torqueAtPoint[$CellContext`mHead, \
$CellContext`p1])^2; $CellContext`constraints = 
          0 <= $CellContext`thetaAdj <= 360; $CellContext`output = Part[
            Part[
             
             NMinimize[{$CellContext`objective, $CellContext`constraints}, \
$CellContext`thetaAdj], 2], 1]; $CellContext`thetaAdjValue = 
          Values[$CellContext`output]; $CellContext`p5Visual = {
           Part[$CellContext`p3, 1] + $CellContext`dTailConst 
             Cos[(90 + $CellContext`thetaLean - $CellContext`thetaAdjValue) 
               Degree], 
            Part[$CellContext`p3, 2] + $CellContext`dTailConst 
             Sin[(90 + $CellContext`thetaLean - $CellContext`thetaAdjValue) 
               Degree]}; Graphics[{Blue, {
             Line[{$CellContext`p1, $CellContext`p2}], 
             Line[{$CellContext`p6, $CellContext`p3}], 
             Line[{$CellContext`p2, $CellContext`p3}], 
