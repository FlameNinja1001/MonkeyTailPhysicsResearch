Cell[TextData[{
 "Defining these constants in Wolfram Language as well as redefining ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "b70e9e7b-08f8-49b4-8817-11d979e3c3ff"],
 ". A critical thing to note is that because this model begins to get \
computationally expensive, I switched to radians instead of degrees for all \
angles:"
}], "CodeText",
 CellChangeTimes->{
  3.9924421531097116`*^9, {3.992591737082636*^9, 3.992591754913043*^9}, {
   3.992598040891382*^9, 
   3.992598041510942*^9}},ExpressionUUID->"7c1cbbb7-c109-479c-885e-\
3cab7e795452"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"hTail", " ", "=", " ", "1.0"}], ";"}], " "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"mHead", " ", "=", " ", "10.0"}], ";", " ", 
   RowBox[{"hHead", " ", "=", " ", "5.0"}], ";", " ", 
   RowBox[{"dHead", " ", "=", " ", "1.0"}], ";"}], " "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"p0", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0"}], "}"}]}], ";"}], " "}], "\n", 
 RowBox[{
  RowBox[{"thetaLean", " ", "=", " ", 
   RowBox[{
    RowBox[{"Pi", "/", "6"}], " ", "-", " ", "0.1"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"pH", " ", "=", " ", 
   RowBox[{"{", "\n", "\t", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "hHead"}], "*", 
      RowBox[{"Sin", "[", "thetaLean", "]"}]}], ",", "\n", "\t", 
     RowBox[{"hHead", "*", 
      RowBox[{"Cos", "[", "thetaLean", "]"}]}]}], "\n", "}"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"mH", " ", "=", " ", 
   RowBox[{"{", "\n", "\t", 
    RowBox[{
     RowBox[{
      RowBox[{"pH", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "-", 
      RowBox[{"dHead", "*", 
       RowBox[{"Cos", "[", "thetaLean", "]"}]}]}], ",", "\n", "\t", 
     RowBox[{
      RowBox[{"pH", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "-", 
      RowBox[{"dHead", "*", 
       RowBox[{"Sin", "[", "thetaLean", "]"}]}]}]}], "\n", "}"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9924292597898397`*^9, 3.992429286400412*^9}, {
  3.9924396724006863`*^9, 3.992439672439506*^9}, {3.9925916102495747`*^9, 
  3.9925916439723263`*^9}, {3.992591769336074*^9, 3.992591773982017*^9}},
 CellLabel->
  "In[113]:=",ExpressionUUID->"96843a68-0abb-4e9b-9aa1-a586a929b0d3"],

Cell[TextData[{
 "For simplicity\[CloseCurlyQuote]s sake, I always used the same constant for \
the length of each tail segment, even though that is not the case in nature. \
To do this, I defined a ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "12129e78-70c4-453a-8b76-d6c61b28c539"],
 " and then computationally created a list of it as a constant using Wolfram \
Language\[CloseCurlyQuote]s Table function. "
}], "Text",
 CellChangeTimes->{{3.9924182846744537`*^9, 3.992418319051136*^9}, {
   3.992418350578918*^9, 3.992418412636354*^9}, {3.992418475915766*^9, 
   3.992418615624667*^9}, {3.992418649433734*^9, 3.992418668332036*^9}, {
