        RowBox[{"p1", ",", "p2"}], "}"}], "]"}]}], ";", "\t", "\n", "\t", 
     RowBox[{"thetaTail", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"ArcTan", "[", 
