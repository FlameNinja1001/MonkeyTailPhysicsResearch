Cell[BoxData[
 RowBox[{
  RowBox[{"torqueOnPivot", "[", 
   RowBox[{"mass_", ",", "p1_", ",", "p2_", ",", "gravity_"}], "]"}], ":=", 
  " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "centerOfMass", ",", "xDist", ",", "yDist", ",", "thetaTail", ",", 
      "radius"}], "}"}], ",", "\n", "\t", 
    RowBox[{
     RowBox[{"centerOfMass", " ", "=", " ", 
      RowBox[{"Midpoint", "[", 
       RowBox[{"{", 
        RowBox[{"p1", ",", "p2"}], "}"}], "]"}]}], ";", "\t", "\n", "\t", 
     RowBox[{"thetaTail", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"ArcTan", "[", 
         RowBox[{
          RowBox[{"centerOfMass", "[", 
           RowBox[{"[", "2", "]"}], "]"}], ",", 
          RowBox[{"centerOfMass", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "/", "Degree"}], "//", 
       "FullSimplify"}]}], ";", "\n", "\t", 
     RowBox[{"radius", " ", "=", " ", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"centerOfMass", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "^", "2"}], ")"}], "+", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"centerOfMass", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "^", "2"}], ")"}]}], "]"}]}], ";", 
     "\n", "\t", 
     RowBox[{"(*", 
      RowBox[{"Return", " ", "torque", " ", "now"}], "*)"}], "\n", "\t", 
     RowBox[{"mass", "*", "gravity", "*", "radius", "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"thetaTail", " ", "Degree"}], "]"}]}]}]}], "\n", 
   "]"}]}]], "Code",
 CellChangeTimes->{3.991927193428369*^9},
 CellLabel->
