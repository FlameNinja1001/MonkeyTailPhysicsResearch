Cell[BoxData[
 RowBox[{
  RowBox[{"torqueOnPivot", "[", 
   RowBox[{"mass_", ",", "p1_", ",", "p2_", ",", "pPivot_", ",", "gravity_"}],
    "]"}], ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "centerOfMass", ",", "xDist", ",", "yDist", ",", "thetaTail", ",", 
      "radius"}], "}"}], ",", "\n", "\t", 
    RowBox[{
     RowBox[{"centerOfMass", " ", "=", " ", 
      RowBox[{"Midpoint", "[", 
       RowBox[{"{", 
        RowBox[{"p1", ",", "p2"}], "}"}], "]"}]}], ";", "\n", "\t", 
     RowBox[{"xDist", " ", "=", " ", 
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"pPivot", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "-", 
        RowBox[{"centerOfMass", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";", "\n", "\t", 
     RowBox[{"yDist", " ", "=", " ", 
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"pPivot", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "-", 
        RowBox[{"centerOfMass", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], ";", "\n", "\t", 
     RowBox[{"thetaTail", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"ArcTan", "[", 
         RowBox[{"yDist", ",", "xDist"}], "]"}], "/", "Degree"}], "//", 
       "FullSimplify"}]}], ";", "\n", "\t", 
     RowBox[{"radius", " ", "=", " ", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"xDist", "^", "2"}], "+", 
        RowBox[{"yDist", "^", "2"}]}], "]"}]}], ";", "\n", "\t", 
     RowBox[{"(*", 
      RowBox[{"Return", " ", "torque", " ", "now"}], "*)"}], "\n", "\t", 
     RowBox[{"mass", "*", "gravity", "*", "radius", "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"thetaTail", " ", "Degree"}], "]"}]}]}]}], "\n", 
   "]"}]}]], "Code",
 CellChangeTimes->{{3.9919043321817093`*^9, 3.991904400981399*^9}, {
