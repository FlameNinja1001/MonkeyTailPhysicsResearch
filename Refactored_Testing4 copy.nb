Cell[BoxData[{
 RowBox[{"Dynamic", "[", "error", "]"}], "\n", 
 RowBox[{"Manipulate", "[", "\t", "\n", "\t", 
  RowBox[{
   RowBox[{
    RowBox[{"hTail", " ", "=", " ", "1.0"}], ";", " ", "\n", "\t", 
    RowBox[{"mHead", " ", "=", " ", "10.0"}], ";", " ", 
    RowBox[{"hHead", " ", "=", " ", "5.0"}], ";", " ", 
    RowBox[{"dHead", " ", "=", " ", "1.0"}], ";", " ", "\n", "\t", 
    RowBox[{"p0", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}]}], ";", " ", "\n", "    ", 
    RowBox[{"listOfDistances", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{"dTailConst", ",", " ", "numPoints"}], "]"}]}], ";", "\n", 
    "    ", 
    RowBox[{"listOfMasses", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{"mTailConst", ",", " ", "numPoints"}], "]"}]}], ";", "\n", 
    "    ", 
    RowBox[{"lowerBound", " ", "=", " ", "0"}], ";", "\n", "    ", 
    RowBox[{"upperBound", " ", "=", " ", 
     RowBox[{"2", "Pi"}]}], ";", "\n", "    ", "\n", "    ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"thetaVars", ",", " ", "thetaAdjVars"}], "}"}], " ", "=", " ", 
     RowBox[{"thetaVarsFunc", "[", 
      RowBox[{"numPoints", ",", " ", "thetaLean"}], "]"}]}], ";", "\n", "\t", 
    
    RowBox[{"pVars", " ", "=", " ", 
     RowBox[{"pVarsFunc", "[", 
      RowBox[{
      "numPoints", ",", " ", "hTail", ",", " ", "thetaLean", ",", " ", 
       "listOfDistances", ",", " ", "thetaVars"}], "]"}]}], ";", "\n", "\t", 
    RowBox[{"mVars", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "\t\t", 
      RowBox[{
       RowBox[{"Midpoint", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"pVars", "[", 
           RowBox[{"[", "n", "]"}], "]"}], ",", " ", 
          RowBox[{"pVars", "[", 
           RowBox[{"[", 
            RowBox[{"n", "+", "1"}], "]"}], "]"}]}], "}"}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], "\n", 
      "\t", "]"}]}], ";", "\n", "\t", 
    RowBox[{"torqueVars", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "\t\t", 
      RowBox[{
       RowBox[{"torqueAtPoint", "[", 
        RowBox[{
         RowBox[{"listOfMasses", "[", 
          RowBox[{"[", "n", "]"}], "]"}], ",", " ", 
         RowBox[{"mVars", "[", 
          RowBox[{"[", "n", "]"}], "]"}]}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], "\n", 
      "\t", "]"}]}], ";", "\n", "\t\t", "\n", "\t", 
    RowBox[{"pH", " ", "=", " ", 
     RowBox[{"{", "\n", "\t\t", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "hHead"}], "*", 
        RowBox[{"Sin", "[", "thetaLean", "]"}]}], ",", "\n", "\t\t", 
       RowBox[{"hHead", "*", 
        RowBox[{"Cos", "[", "thetaLean", "]"}]}]}], "\n", "\t", "}"}]}], ";", 
    "\n", "\t", 
    RowBox[{"mH", " ", "=", " ", 
     RowBox[{"{", "\n", "\t\t", 
      RowBox[{
       RowBox[{
        RowBox[{"pH", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "-", 
        RowBox[{"dHead", "*", 
         RowBox[{"Cos", "[", "thetaLean", "]"}]}]}], ",", "\n", "\t\t", 
       RowBox[{
        RowBox[{"pH", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "-", 
        RowBox[{"dHead", "*", 
         RowBox[{"Sin", "[", "thetaLean", "]"}]}]}]}], "\n", "\t", "}"}]}], ";",
     "\n", "\t", "\n", "\t", 
    RowBox[{"constraints", " ", "=", " ", 
     RowBox[{"Join", "[", "\n", "\t    ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", " ", "<", " ", 
         RowBox[{"thetaAdjVars", "[", "1", "]"}], " ", "<", " ", "Pi"}], 
        "}"}], ",", "\n", "\t\t", 
       RowBox[{"Table", "[", "\n", "\t\t\t", 
        RowBox[{
         RowBox[{"lowerBound", " ", "<=", " ", 
          RowBox[{"thetaAdjVars", "[", "n", "]"}], " ", "<", " ", 
          "upperBound"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"n", ",", " ", "2", ",", " ", "numPoints"}], "}"}]}], "\n", 
        "\t\t", "]"}]}], "\n", "\t", "]"}]}], ";", "\n", "\t\t", "\n", "\t", 
    RowBox[{"objective", " ", "=", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"torqueAtPoint", "[", 
         RowBox[{"mHead", ",", " ", "mH"}], "]"}], " ", "+", " ", 
        RowBox[{"Total", "[", "torqueVars", "]"}]}], ")"}], "^", "2"}]}], ";",
     "\n", "\t\t", "\n", "\t", 
    RowBox[{"output", " ", "=", " ", 
     RowBox[{"NMinimize", "[", "\n", "\t\t", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"objective", ",", " ", "constraints"}], "}"}], ",", "\n", 
       "\t\t", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"thetaAdjVars", "[", "n", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", " ", "numPoints"}], "}"}]}], "]"}]}], "\n", "\t", 
      "]"}]}], ";", "\t\t", "\n", "\t", 
    RowBox[{"error", " ", "=", " ", 
     RowBox[{"output", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", "\t", 
    RowBox[{"thetaAdjs", " ", "=", " ", 
     RowBox[{"Values", "[", 
      RowBox[{"output", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ";", "\n", "\t", 
    RowBox[{"thetas", " ", "=", " ", 
     RowBox[{"thetaVarsFuncEval", "[", 
      RowBox[{"numPoints", ",", " ", "thetaLean", ",", " ", "thetaAdjs"}], 
      "]"}]}], ";", "\t\t", "\n", "\t", 
    RowBox[{"pEvals", " ", "=", " ", 
     RowBox[{"pVarsFunc", "[", 
      RowBox[{
      "numPoints", ",", " ", "hTail", ",", " ", "thetaLean", ",", " ", 
       "listOfDistances", ",", " ", "thetas"}], "]"}]}], ";", " \t\t", "\n", 
    "\t", 
    RowBox[{"Graphics", "[", "\n", "\t\t", 
     RowBox[{
      RowBox[{"{", "\n", "\t\t\t", 
       RowBox[{
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"{", "\n", "\t\t\t\t", 
           RowBox[{"Blue", ",", " ", 
            RowBox[{"Line", "[", 
             RowBox[{"{", 
              RowBox[{"p0", ",", "pH"}], "}"}], "]"}], ",", " ", 
            RowBox[{"Line", "[", 
             RowBox[{"{", 
              RowBox[{"mH", ",", " ", "pH"}], "}"}], "]"}]}], "}"}], ",", " ", 
          RowBox[{"{", "Blue", "}"}], ",", "\n", "\t\t\t\t", 
          RowBox[{"Table", "[", "\n", "\t\t\t\t\t", 
           RowBox[{
            RowBox[{"Line", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"pEvals", "[", 
                RowBox[{"[", "n", "]"}], "]"}], ",", " ", 
               RowBox[{"pEvals", "[", 
                RowBox[{"[", 
                 RowBox[{"n", "+", "1"}], "]"}], "]"}]}], "}"}], "]"}], ",", 
            " ", 
            RowBox[{"{", 
             RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], 
           "\n", "\t\t\t\t", "]"}]}], "\n", "\t\t\t", "]"}], ",", "\n", 
        "\t\t\t", "LightGray", ",", " ", "Dashed", ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Line", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}], ",", 
