Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"pVarsFunc", "[", 
    RowBox[{
    "numPoints_Integer", ",", " ", "hTail_Real", ",", " ", "thetaLean_Real", ",",
      " ", "distances_List", ",", " ", "theta_List"}], "]"}], " ", ":=", " ", 
   
   RowBox[{"Module", "[", "\n", "\t", 
    RowBox[{
     RowBox[{"{", "p", "}"}], ",", "\n", "\t", 
     RowBox[{"Table", "[", "\n", "\t\t", 
      RowBox[{
       RowBox[{"Which", "[", "\n", "\t\t\t", 
        RowBox[{
         RowBox[{"n", "==", "1"}], ",", " ", "\n", "\t\t\t", 
         RowBox[{"p", " ", "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "hTail"}], "*", 
             RowBox[{"Sin", "[", "thetaLean", "]"}]}], ",", " ", 
            RowBox[{"hTail", "*", 
             RowBox[{"Cos", "[", "thetaLean", "]"}]}]}], "}"}]}], ",", "\n", 
         "\t\t\t", 
         RowBox[{"n", ">=", "2"}], ",", " ", "\n", "\t\t\t", 
         RowBox[{"p", " ", "+=", " ", 
          RowBox[{"{", "\n", "\t\t\t\t", 
           RowBox[{
            RowBox[{
             RowBox[{"distances", "[", 
              RowBox[{"[", 
               RowBox[{"n", "-", "1"}], "]"}], "]"}], "*", 
             RowBox[{"Cos", "[", 
              RowBox[{"theta", "[", 
               RowBox[{"[", 
                RowBox[{"n", "-", "1"}], "]"}], "]"}], "]"}]}], ",", " ", 
            "\n", "\t\t\t\t", 
            RowBox[{
             RowBox[{"distances", "[", 
              RowBox[{"[", 
               RowBox[{"n", "-", "1"}], "]"}], "]"}], "*", 
             RowBox[{"Sin", "[", 
              RowBox[{"theta", "[", 
               RowBox[{"[", 
                RowBox[{"n", "-", "1"}], "]"}], "]"}], "]"}]}]}], "\n", 
           "\t\t\t", "}"}]}]}], "\n", "\t\t", "]"}], ",", "\n", "\t\t", 
       RowBox[{"{", 
        RowBox[{"n", ",", " ", "1", ",", " ", 
         RowBox[{"numPoints", "+", "1"}]}], "}"}]}], "]"}]}], "\n", "]"}]}], 
  ";"}]], "Code",
