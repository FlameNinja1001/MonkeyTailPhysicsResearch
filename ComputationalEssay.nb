AAAA3TH/MwAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAIoz5t8AAAAAdMf8zwAA
AIDuyM8AAACA7sjPAAAAgO7IzwCgov8DIQKtZQ==
     "], {{0, 960.}, {960., 0}}, {0, 255},
     ColorFunction->RGBColor],
    BoxForm`ImageTag["Byte", ColorSpace -> "RGB", Interleaving -> True],
    Selectable->False],
   DefaultBaseStyle->"ImageGraphics",
   ImageSizeRaw->{960., 960.},
   PlotRange->{{0, 960.}, {0, 960.}}]], "Input",ExpressionUUID->
  "861cf030-34be-45c9-a9bd-3c1514bad60e"],
 "\nWith this diagram, it\[CloseCurlyQuote]s proven how:\n\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "h"], TraditionalForm]],ExpressionUUID->
  "a122f3f3-9abe-4ae5-aa10-528021cf56ee"],
 " = arctan(",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["d", "head"], 
    SubscriptBox["h", "head"]], TraditionalForm]],ExpressionUUID->
  "55294ebc-0523-4aa5-9701-d570b2177904"],
 ")+",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "6dd75402-a9ed-453e-90d8-99bba5b14dce"],
 "\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "t"], TraditionalForm]],ExpressionUUID->
  "d592609e-2572-4d13-b852-1a65bf2b35d3"],
 " = arctan(",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["d", "tail"], 
    RowBox[{"2", 
     SubscriptBox["h", "tail"]}]], TraditionalForm]],ExpressionUUID->
  "a5167710-9d7b-4f31-97b7-fc3e0b7e2271"],
 ")-",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "44775ada-d7b1-44ed-907a-63a0b1302ccb"],
 "\n\nWith ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "t"], TraditionalForm]],ExpressionUUID->
  "e2599c8f-2b23-4e35-a390-5b89975eb1a6"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "h"], TraditionalForm]],ExpressionUUID->
  "4e7e04f8-dbee-49c0-b09d-a0c2273e4285"],
 " defined, we can plug them into the torque equations and simplify from \
there. Let\[CloseCurlyQuote]s begin with the head equation.\n\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],ExpressionUUID->
  "a4d1b42b-5f5a-4420-929b-29d115249527"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "head"], TraditionalForm]],ExpressionUUID->
  "a2e7d326-8113-4b1e-9a75-169aa46c8218"],
 " * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "head"], TraditionalForm]],ExpressionUUID->
  "14bac94c-5994-4694-8ff8-f25113d52dfe"],
 " * sin(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "h"], TraditionalForm]],ExpressionUUID->
  "23ef66f7-cd9a-4586-bc22-41dddf3de4f1"],
 ")\n\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],ExpressionUUID->
  "f69dc05c-d103-45e5-bbf9-f097ec217f0b"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "head"], TraditionalForm]],ExpressionUUID->
  "80e30a3a-92f0-4ab9-911f-79fcbe564736"],
 " * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "head"], TraditionalForm]],ExpressionUUID->
  "ee57d3f1-5e8b-44b9-9861-46ef566d1aa0"],
 " * sin(arctan(",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["d", "head"], 
    SubscriptBox["h", "head"]], TraditionalForm]],ExpressionUUID->
  "70757adb-b720-42d6-9200-7bd2fd5bd3a0"],
 ")+",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "336ba21a-88e3-4391-9155-b2c47327cdc1"],
 ")\n\nInside of the sine function is an addition of two angles. Using this, \
we can expand, and then simplify it with the sum of sines identity:\nsin(A+B) \
= sinAcosB + cosAsinB\n\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],ExpressionUUID->
  "26c5868a-931e-484b-ba58-60720c9827b9"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "head"], TraditionalForm]],ExpressionUUID->
  "9e7c7e13-ebbe-4823-b89a-e1cf29be7702"],
 " * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "head"], TraditionalForm]],ExpressionUUID->
  "27e8e07b-3326-4a87-851f-5be2716894b2"],
 " * (sin(arctan(",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["d", "head"], 
    SubscriptBox["h", "head"]], TraditionalForm]],ExpressionUUID->
  "9e409477-d7a9-4d59-8cf5-e8220570849f"],
 ")cos(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "7af5a761-e1c2-4fdc-9b86-04cf5ed4acd1"],
 ")+cos(arctan(",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["d", "head"], 
    SubscriptBox["h", "head"]], TraditionalForm]],ExpressionUUID->
  "3eb732c4-d5e0-4cd4-8f1c-24a6690a0b81"],
 ")sin(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "d6bc23d8-56cf-409a-a679-1e8169105a45"],
 "))\n\nIt seems complex, but the sine and cosine of arctan(",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["d", "head"], 
    SubscriptBox["h", "head"]], TraditionalForm]],ExpressionUUID->
  "74523365-32ac-4a99-9573-9d62774b773f"],
 ") can actually be defined using ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "head"], TraditionalForm]],ExpressionUUID->
  "8964a6d0-dde9-4010-95de-a0fdf115ee2c"],
 "! Let\[CloseCurlyQuote]s examine that with the diagram below:\n\nWe end up \
with:\n\nsin(arctan(",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["d", "head"], 
    SubscriptBox["h", "head"]], TraditionalForm]],ExpressionUUID->
  "a849575d-6866-4d52-be95-63cfb98b5f1c"],
 ")) = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["d", "head"], 
    SubscriptBox["r", "head"]], TraditionalForm]],ExpressionUUID->
  "f480c53e-8a9d-4196-9b32-adeab867e438"],
 "\n\ncos(arctan(",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["d", "head"], 
    SubscriptBox["h", "head"]], TraditionalForm]],ExpressionUUID->
  "b766ae8d-bbe8-45a8-b7d8-e90501c67d3a"],
 ")) = ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["h", "head"], 
    SubscriptBox["r", "head"]], TraditionalForm]],ExpressionUUID->
  "808aa509-cc17-4411-9760-00ef5a0b2898"],
 "\n\nGiven this, let\[CloseCurlyQuote]s plug it in to the equation.\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],ExpressionUUID->
  "ec4ab493-b79c-4a0f-825d-1368a87a94b3"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "head"], TraditionalForm]],ExpressionUUID->
  "7f4d5adb-39cd-4773-9c42-dc2cbeff311d"],
 " * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "head"], TraditionalForm]],ExpressionUUID->
  "561f45c4-02d4-415c-81b8-556a6272bb3d"],
 " * (",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     SubscriptBox["d", 
      RowBox[{"head", " "}]], "*", " ", 
     RowBox[{"cos", "(", 
      FormBox[
       SubscriptBox["\[Theta]", "lean"],
       TraditionalForm], ")"}]}], 
    SubscriptBox["r", "head"]], TraditionalForm]],ExpressionUUID->
  "259d143d-7ceb-43de-ada0-1311ed2b5d7f"],
 "+",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     SubscriptBox["h", 
      RowBox[{"head", " "}]], "*", " ", 
     RowBox[{"sin", "(", 
      FormBox[
       SubscriptBox["\[Theta]", "lean"],
       TraditionalForm], ")"}]}], 
    SubscriptBox["r", "head"]], TraditionalForm]],ExpressionUUID->
  "ac3dc3d5-9e44-408d-bdc2-5cabddc9cc2c"],
 ")\n\nSince every part of the identity has r_head on the denominator, and we \
are multiplying it by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "head"], TraditionalForm]],ExpressionUUID->
  "6bacfbb8-3394-47e5-a394-e07277faea1e"],
 ", we get a much simpler equation for the torque of the head:\n\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],ExpressionUUID->
  "45168eb4-cf8e-4083-ac33-b82f28f3c9c2"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "head"], TraditionalForm]],ExpressionUUID->
  "5f4a4e91-d4b1-4094-913e-725014bda9d1"],
 " * (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", 
     RowBox[{"head", " "}]], "*", " ", 
    RowBox[{"cos", "(", 
     FormBox[
      SubscriptBox["\[Theta]", "lean"],
      TraditionalForm], ")"}]}], TraditionalForm]],ExpressionUUID->
  "d22bcbeb-de61-43c0-901a-2d52210ba1e2"],
 "+",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["h", 
     RowBox[{"head", " "}]], "*", " ", 
    RowBox[{"sin", "(", 
     FormBox[
      SubscriptBox["\[Theta]", "lean"],
      TraditionalForm], ")"}]}], TraditionalForm]],ExpressionUUID->
  "89d362e4-0876-48bf-831d-62a0ea4fabfb"],
 ")\n\nThe torque of the tail is the same, except instead of adding the two \
angles, we must subtract them, as the diagram shows. This means we use the \
difference of sines identity, sin(A-B) = sinAcosB-cosAsinB. We also must \
remember that the distance (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "4f1df9ef-7937-4318-a05f-3c06b06698da"],
 ") is divided by two:\n\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "2fe33266-ce25-43ca-929a-bf815807ff42"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "73d4e8d7-4dbe-427f-932d-a25f3e41ffd6"],
 " * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "tail"], TraditionalForm]],ExpressionUUID->
  "51d6f5e9-ef16-462b-bce3-8b9e7cf85c45"],
 " * sin(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "t"], TraditionalForm]],ExpressionUUID->
  "5908c0d2-26f1-442a-b080-e11f6affcc30"],
 ")\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "775393f4-f583-4580-bce4-72b02f1e4a35"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "fe0bfc02-a640-4e65-bf4b-ae8b42f78ef1"],
 " * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "tail"], TraditionalForm]],ExpressionUUID->
  "b2e1aaf3-b6ab-49cc-a185-959d8b2c4cff"],
 " * sin(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"arctan", "(", 
     FormBox[
      FractionBox[
       SubscriptBox["d", "tail"], 
       RowBox[{"2", 
        SubscriptBox["h", "tail"]}]],
      TraditionalForm], ")"}], "-", 
    FormBox[
     SubscriptBox["\[Theta]", "lean"],
     TraditionalForm]}], TraditionalForm]],ExpressionUUID->
  "86bf9615-88e4-4318-8650-2a86d8b9b8b2"],
 ")\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "3475061d-6853-42ee-b769-7007b82d3447"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "b24f2fc5-65ca-4025-830f-856d1cd16293"],
 " * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "tail"], TraditionalForm]],ExpressionUUID->
  "06cc80dd-0c0b-47af-b413-81e2445fbff2"],
 " * (sin(arctan(",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["d", "tail"], 
    RowBox[{"2", 
     SubscriptBox["h", "tail"]}]], TraditionalForm]],ExpressionUUID->
  "5f88962c-650a-4d88-8484-2222b5e524fe"],
 ")cos(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "96032a2c-b6f0-458d-be1c-8fe24146eed0"],
 ")-cos(arctan(",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["d", "tail"], 
    RowBox[{"2", 
     SubscriptBox["h", "tail"]}]], TraditionalForm]],ExpressionUUID->
  "fef1e4f9-9f02-40e7-acd1-a59b1d83d23e"],
 ")sin(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "1c5da6d1-a32d-4bf0-b7f4-0cbf91a797b8"],
 "))\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "0f28fc8e-d604-4542-bd37-ca1a92b68b52"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "c7757307-30fe-4a8a-83bf-5ba7c93353e4"],
 " * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "tail"], TraditionalForm]],ExpressionUUID->
  "ac29b497-c31f-4324-90ae-ed252e43309c"],
 " * (",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     SubscriptBox["d", "tail"], 
     RowBox[{"cos", "(", 
      FormBox[
       SubscriptBox["\[Theta]", "lean"],
       TraditionalForm], ")"}]}], 
    RowBox[{"2", 
     SubscriptBox["r", "tail"]}]], TraditionalForm]],ExpressionUUID->
  "f080da26-3195-419e-8ed4-2dbf567983af"],
 "-",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     SubscriptBox["h", "tail"], 
     RowBox[{"sin", "(", 
      FormBox[
       SubscriptBox["\[Theta]", "lean"],
       TraditionalForm], ")"}]}], 
    RowBox[{"2", 
     SubscriptBox["r", "tail"]}]], TraditionalForm]],ExpressionUUID->
  "01728db2-375a-4e20-928f-5bbe71e2be22"],
 ")\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "4120ad6f-2be4-42e6-82d8-a12a5b74e908"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "fe3bf41f-c14e-463b-b344-8802d7d0d98d"],
 " *  (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "tail"], 
    RowBox[{"cos", "(", 
     FormBox[
      SubscriptBox["\[Theta]", "lean"],
      TraditionalForm], ")"}]}], TraditionalForm]],ExpressionUUID->
  "89446bf6-d5f4-45f5-abde-6ee247d2dab4"],
 "-",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["h", "tail"], 
    RowBox[{"sin", "(", 
     FormBox[
      SubscriptBox["\[Theta]", "lean"],
      TraditionalForm], ")"}]}], TraditionalForm]],ExpressionUUID->
  "eee8df93-95bd-4658-9483-668174ae49c0"],
 ")\n\nThe finished model is the following, where we set both torques equal \
to each other.\n\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],ExpressionUUID->
  "ddeb9c4e-0670-4a65-9945-54f8b5cac18d"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "head"], TraditionalForm]],ExpressionUUID->
  "b7f7560b-bbce-4b7d-9ca4-8fd0d71fd124"],
 " * (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", 
     RowBox[{"head", " "}]], "*", " ", 
    RowBox[{"cos", "(", 
     FormBox[
      SubscriptBox["\[Theta]", "lean"],
      TraditionalForm], ")"}]}], TraditionalForm]],ExpressionUUID->
  "1579d73c-4c9a-4363-9495-7e3debc5e606"],
 "+",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["h", 
     RowBox[{"head", " "}]], "*", " ", 
    RowBox[{"sin", "(", 
     FormBox[
      SubscriptBox["\[Theta]", "lean"],
      TraditionalForm], ")"}]}], TraditionalForm]],ExpressionUUID->
  "b2c86ced-b856-4328-9544-dfda1a57b034"],
 ") = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "56034b5e-86c1-4020-8e73-e9ec9e1e977e"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "71a68633-cf36-44b2-ab07-4a5621dd0961"],
 " *  (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "tail"], 
    RowBox[{"cos", "(", 
     FormBox[
      SubscriptBox["\[Theta]", "lean"],
      TraditionalForm], ")"}]}], TraditionalForm]],ExpressionUUID->
  "588ce977-3d41-4142-8f0b-81432cb80eea"],
 "-",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["h", "tail"], 
    RowBox[{"sin", "(", 
     FormBox[
      SubscriptBox["\[Theta]", "lean"],
      TraditionalForm], ")"}]}], TraditionalForm]],ExpressionUUID->
  "e3b2a391-9194-41d5-9149-f7b293615277"],
 ")\n\nTo model the monkey tilting itself, we must change ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "c74d02a0-096f-4153-8aaa-c1349b0ef9d7"],
 ". If we changed ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "2d8bb9b4-c093-45a1-a49b-30ea3c45f192"],
 ", however, the system would just fall. To accommodate for this, we must \
make one or more of the six variables unknown such that the model can \
automatically adjust it to keep the torques in equilibrium. In this example, \
we will solve for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "969902e9-d6cb-4334-a73a-8240d37be5a9"],
 " as our unknown variable.\n\nThis will be achieved with the Wolfram \
Language. To start the simulation, we define the constants = all variables \
besides d_tail."
}], "Text",
 CellChangeTimes->{{3.9293546184036617`*^9, 3.9293546199188967`*^9}, {
   3.991843023893482*^9, 3.991843098671399*^9}, {3.991843141651308*^9, 
   3.991843153204752*^9}, {3.9918432145448112`*^9, 3.991843314639442*^9}, {
   3.991843367531785*^9, 3.991843482849601*^9}, {3.991843529523225*^9, 
   3.991843563288316*^9}, {3.99184359410602*^9, 3.9918436278691387`*^9}, {
   3.9918436914439497`*^9, 3.991843723147058*^9}, {3.991843789397196*^9, 
   3.9918438381344337`*^9}, {3.99184392692651*^9, 3.991844022786091*^9}, {
   3.991844093496125*^9, 3.9918441019339437`*^9}, {3.991844140124487*^9, 
   3.991844288216073*^9}, {3.991844434010304*^9, 3.991844463089705*^9}, 
   3.991844536742257*^9, {3.991844571327832*^9, 3.991844681795814*^9}, {
   3.991844719772691*^9, 3.9918447236166487`*^9}, {3.99184475520887*^9, 
   3.991844812664764*^9}, {3.991900660775463*^9, 3.991900688971546*^9}, {
   3.991900729486137*^9, 3.9919007895352983`*^9}, {3.991901415519161*^9, 
   3.991901558521984*^9}, {3.991901612081134*^9, 3.991901873321487*^9}, {
   3.991901966594462*^9, 3.991902031905037*^9}, {3.991902066001555*^9, 
   3.991902119420312*^9}, {3.991902164200292*^9, 3.9919022705054607`*^9}, {
   3.99190278807376*^9, 3.9919028913216267`*^9}, {3.99190293358051*^9, 
   3.991903134249188*^9}, {3.9919032240534286`*^9, 3.991903324589549*^9}, {
   3.9919034062311087`*^9, 3.991903419125595*^9}, {3.991903471088574*^9, 
   3.991903597660206*^9}, {3.991928666147277*^9, 3.991928691460561*^9}, {
   3.991928733055315*^9, 3.991928851738813*^9}, {3.9919288930456953`*^9, 
   3.991929005467946*^9}, {3.99192904826562*^9, 3.991929244567896*^9}, {
   3.9919903207816153`*^9, 3.9919903325476723`*^9}, {3.991991432369656*^9, 
   3.991991478606983*^9}, {3.99199187596874*^9, 3.9919919269921017`*^9}, {
   3.991992328868251*^9, 3.991992343943532*^9}, {3.99199250669311*^9, 
   3.991992511971764*^9}, {3.991992595943885*^9, 3.9919926234082212`*^9}, {
   3.991992681603623*^9, 3.9919927237886868`*^9}, {3.99199338094503*^9, 
   3.991993491743717*^9}, {3.9919935268091784`*^9, 3.991993545731331*^9}, {
   3.991993586936273*^9, 3.991993599315505*^9}, {3.991999098818658*^9, 
   3.991999120089863*^9}},ExpressionUUID->"9b79198e-7897-462b-8630-\
68f1f3d31553"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"g", " ", "=", " ", "9.81"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"m", "/", "s"}], "*)"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"mHead", " ", "=", " ", "1"}], ";"}], " ", 
  RowBox[{"(*", "kg", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"dHead", " ", "=", " ", "1"}], ";"}], " ", 
  RowBox[{"(*", "m", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"hHead", " ", "=", " ", "5"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"mTail", " ", "=", " ", "1"}], ";"}], " ", 
  RowBox[{"(*", "kg", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"hTail", " ", "=", " ", "1"}], ";"}], " ", 
  RowBox[{"(*", "m", "*)"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"thetaLean", " ", "=", " ", "15"}], ";"}], " ", 
  RowBox[{"(*", "degrees", "*)"}]}]}], "Code",
 CellChangeTimes->{{3.991815092339835*^9, 3.991815096115572*^9}, {
  3.9918152291416388`*^9, 3.991815314520664*^9}, {3.991838032309401*^9, 
  3.9918380970051413`*^9}, {3.991838130860958*^9, 3.991838183760466*^9}, {
  3.9918382336683683`*^9, 3.991838234485955*^9}, {3.991838564647468*^9, 
