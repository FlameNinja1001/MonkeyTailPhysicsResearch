   3.991995302150591*^9, 3.991995341984984*^9}, {3.991995380476668*^9, 
   3.991995397087257*^9}, {3.9919955016590223`*^9, 3.991995539370191*^9}, {
   3.991995860004785*^9, 3.991995917214114*^9}, {3.99199601388794*^9, 
   3.9919961594638853`*^9}, {3.991996212771714*^9, 3.991996295023238*^9}, {
   3.992037091229911*^9, 3.9920370935139303`*^9}, {3.992037147765498*^9, 
   3.9920371558064127`*^9}},ExpressionUUID->"6f678598-b46d-45ab-81e9-\
f26a42d88268"],

Cell[BoxData[
 RowBox[{
  RowBox[{"torqueOnPivot", "[", 
   RowBox[{"mass_", ",", "p1_", ",", "p2_", ",", "gravity_"}], "]"}], ":=", 
  " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "centerOfMass", ",", "xDist", ",", "yDist", ",", "thetaTail", ",", 
      "radius"}], "}"}], ",", "\n", "\t", 
    RowBox[{
     RowBox[{"centerOfMass", " ", "=", " ", 
      RowBox[{"Midpoint", "[", 
       RowBox[{"{", 
        RowBox[{"p1", ",", "p2"}], "}"}], "]"}]}], ";", "\t", "\n", "\t", 
     RowBox[{"thetaTail", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"ArcTan", "[", 
         RowBox[{
          RowBox[{"centerOfMass", "[", 
           RowBox[{"[", "2", "]"}], "]"}], ",", 
          RowBox[{"centerOfMass", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "/", "Degree"}], "//", 
       "FullSimplify"}]}], ";", "\n", "\t", 
     RowBox[{"radius", " ", "=", " ", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"centerOfMass", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "^", "2"}], ")"}], "+", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"centerOfMass", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "^", "2"}], ")"}]}], "]"}]}], ";", 
     "\n", "\t", 
     RowBox[{"(*", 
      RowBox[{"Return", " ", "torque", " ", "now"}], "*)"}], "\n", "\t", 
     RowBox[{"mass", "*", "gravity", "*", "radius", "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"thetaTail", " ", "Degree"}], "]"}]}]}]}], "\n", 
   "]"}]}]], "Code",
 CellChangeTimes->{3.9919293755836906`*^9, 3.99194791621848*^9},
 CellLabel->
  "In[1234]:=",ExpressionUUID->"88a28632-a137-4a7e-b31b-0c48ac224fa5"],

Cell[TextData[{
 "The next step of this process is finding ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "0a3571b0-e625-483b-ad70-09e3e26c531c"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "696f6fe7-2baf-459c-a74d-c3cd83f0b200"],
 ". We can do this by creating expressions for them that rely on ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "77329da0-5369-40a5-8f9b-c1929fff1703"],
 " and then solving for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "52d333bc-8669-4de2-8539-93fb3e3f4eb6"],
 " using NSolve. Let\[CloseCurlyQuote]s first redefine our constants, with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "6f11b842-a43f-4cad-978c-6b7e3cdcd94c"],
 " now as a given compared to above when it was the unknown."
}], "Text",
 CellChangeTimes->{{3.991996543164551*^9, 
  3.991996636503759*^9}},ExpressionUUID->"b8af59ae-1ee1-4225-807c-\
38bd18d78a08"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"g", " ", "=", " ", "9.81"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"mHead", " ", "=", " ", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dHead", " ", "=", " ", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"hHead", " ", "=", " ", "5"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"mTail", " ", "=", " ", "2"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"hTail", " ", "=", " ", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"dTailConst", " ", "=", " ", "3"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"thetaLean", " ", "=", " ", "15"}], ";"}]}], "Code",
 CellChangeTimes->{
  3.991929384204686*^9, 3.991947921198415*^9, {3.9919895201828957`*^9, 
   3.9919895321820793`*^9}, {3.992080179169489*^9, 3.99208018222471*^9}},
 CellLabel->
  "In[1235]:=",ExpressionUUID->"2c33ceb3-e688-437c-8ba8-b1bd5bb1b7e9"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s now solve for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "9c90cf08-335d-46a7-9f14-e88e64c95ac5"],
 ".  Because ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "709b9cbd-6c81-48fc-8305-53bba40a6b14"],
 " is technically part of the body, but it is ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "tail"], TraditionalForm]],ExpressionUUID->
  "f41a6f23-2b13-4a54-a3a1-b174d2e9e6db"],
 " high up on the body, it\[CloseCurlyQuote]s modified by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Theta]", "lean"], " "}], TraditionalForm]],ExpressionUUID->
  "eb6580cf-0240-4c88-bd30-ff171ad15280"],
 "and  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "tail"], TraditionalForm]],ExpressionUUID->
  "7818f291-2edc-4453-9ab1-8593e1843e7d"],
 ". This relationship can by represented by the following expression and \
diagram, with a right triangle (marked in red) moving up to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "e61638ec-4419-4e14-8ace-eb2235b887ad"],
 ":\n",
 Cell[BoxData[
  GraphicsBox[
   TagBox[RasterBox[CompressedData["
