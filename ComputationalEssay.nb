  FormBox[
   RowBox[{
    SubscriptBox["\[Theta]", "lean"], " "}], TraditionalForm]],ExpressionUUID->
  "7f71f183-5362-43e0-80d1-75ef02578041"],
 "))\n\nThis can be entered into Wolfram Language with the following line of \
code:"
}], "Text",
