   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "469d61d8-0843-4d97-b371-1f79542b5011"],
 ", it\[CloseCurlyQuote]s slightly more complex, but we can represent it \
symbolically by using ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "48330600-3245-4740-adb6-2cb4507449d2"],
 ". Notice how, in the following diagram, we can create a right triangle \
using ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "92ab64cc-0664-44c0-adfa-53933ab2ad4c"],
 " as the hypotenuse, and the x and y coordinates for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "b8f16055-439a-4b65-aeb4-be4e2149852b"],
 " as the legs.\n\[LineSeparator]Also notice how part of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "902ffebc-b16c-4e3a-87dc-f34d8af84815"],
 " is in the angle that the triangle makes. The specific part, as this \
diagram shows, can actually be calculated by the following expression:\n\n\
180-",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "69de0015-a3af-441d-a7a8-e1ff771ac74c"],
 "-",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "3cd029cf-6fc8-4949-8c62-6416d3f580e9"],
 "\n\nWhich can be represented in Wolfram by the following line of code:"
}], "Text",
 CellChangeTimes->{
  3.991996786810734*^9, {3.991997503762938*^9, 3.991997515377739*^9}, {
   3.991997551293169*^9, 3.9919975806897287`*^9}, {3.991997623093213*^9, 
   3.991997657604932*^9}, {3.991998110067182*^9, 3.991998136586851*^9}, {
   3.991998191827361*^9, 3.991998195137241*^9}, {3.991998274878636*^9, 
   3.9919982992582417`*^9}},ExpressionUUID->"614801d0-1d64-4a09-a99c-\
83d74e4bbe15"],

Cell[BoxData[
 RowBox[{
  RowBox[{"p2", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"p1", "[", 
       RowBox[{"[", "1", "]"}], "]"}], " ", "+", " ", 
      RowBox[{"dTailConst", "*", 
       RowBox[{"Cos", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"180", "-", "thetaLean", "-", "thetaAdj"}], ")"}], " ", 
         "Degree"}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"p1", "[", 
       RowBox[{"[", "2", "]"}], "]"}], " ", "+", " ", 
      RowBox[{"dTailConst", "*", 
       RowBox[{"Sin", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"180", "-", "thetaLean", "-", "thetaAdj"}], ")"}], " ", 
         "Degree"}], "]"}]}]}]}], "}"}]}], ";"}]], "Code",
 CellChangeTimes->{{3.99199679009562*^9, 3.991996799197044*^9}},
 CellLabel->
  "In[781]:=",ExpressionUUID->"30b42878-71c1-443f-877a-8fa4641beece"],

Cell[TextData[{
 "Now, since we know ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "0f12c655-3f81-46f1-aa85-4303b6268edc"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "9e99ed3f-9f28-4355-be1d-e124d1886b71"],
 " as the start and endpoints of the tail, we can calculate the torque on the \
tail through the function defined earlier. Then, we can set it equal to the \
torque of the head from the Model V1, and solve for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "18d7f8d5-03e8-43bd-b2bb-b2fac0a1bdfb"],
 " with the following piece of code."
}], "Text",
 CellChangeTimes->{
  3.991996791536162*^9, {3.991998858593671*^9, 3.991998925845018*^9}, {
   3.991999051858283*^9, 
   3.991999053898929*^9}},ExpressionUUID->"c569c044-0b0d-494f-bfc2-\
a38b1d1f8916"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NSolve", "[", "\n", "\t", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"torqueOnPivot", "[", 
      RowBox[{"mTail", ",", "p1", ",", "p2", ",", "9.81"}], "]"}], "==", "\n",
      "\t", 
     RowBox[{
      RowBox[{"mHead", "*", "dHead", "*", 
       RowBox[{"Cos", "[", 
        RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], "+", 
      RowBox[{"hHead", "*", 
       RowBox[{"Sin", "[", 
        RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}]}], "&&", "\n", "\t", 
    RowBox[{"0", " ", "<=", " ", "thetaAdj", " ", "<=", " ", "180"}]}], ",", 
   "\n", "\t", "thetaAdj"}], "\n", "]"}]], "Code",
 CellChangeTimes->{3.9919895262654533`*^9},
 CellLabel->
  "In[782]:=",ExpressionUUID->"d94779da-ef7c-443a-996e-bc9252ed7bfa"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{"thetaAdj", "\[Rule]", "89.43840900342931`"}], "}"}], 
  "}"}]], "Output",
 CellChangeTimes->{
  3.991989639788385*^9, {3.991989724974826*^9, 3.991989741035997*^9}, 
   3.9919898290635757`*^9, 3.991989960850988*^9, {3.991990088826375*^9, 
   3.991990105913843*^9}, 3.991992548939085*^9, 3.991993882952071*^9, 
   3.991993959696947*^9, 3.991994651817924*^9, 3.9919963079910383`*^9, 
   3.991999065414356*^9},
 CellLabel->
  "Out[782]=",ExpressionUUID->"ad8935ae-b6a0-427b-beeb-31121eafdbe7"]
}, Open  ]],

Cell[TextData[{
 "Finally, just like the previous model, we now use DynamicModule and a \
slider that changes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "7c9181ce-c013-4de2-822d-7495955d2181"],
 ". We need to be careful to distinguish between the points used to solve \
(local variables p1 and p2) and the points used to draw (coord1, coord2, \
coord3, coord4, coord5, coord6) due to memory allocation. The simulation is \
visualized below:"
}], "Text",
 CellChangeTimes->{{3.99199893926355*^9, 
  3.9919990471348753`*^9}},ExpressionUUID->"2ef6ac2a-3391-46d0-95ff-\
ff39c29a95cb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DynamicModule", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"thetaLeanString", "=", "\"\<\[Theta]_lean = \>\""}], ",", 
     RowBox[{"p1", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"p2", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"val1", "=", "0"}], ",", 
     RowBox[{"val2", "=", "0"}], ",", 
     RowBox[{"coord1", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"coord2", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"coord3", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"coord4", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"coord5", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"coord6", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}]}], "}"}], ",", "\n", "\t", "\n", "\t", 
   RowBox[{"Column", "[", 
    RowBox[{"{", "\n", "\t\t", 
     RowBox[{
      RowBox[{"Slider", "[", 
       RowBox[{
        RowBox[{"Dynamic", "[", "thetaLean", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "89.9"}], ",", "89.9"}], "}"}]}], "]"}], ",", "\n", 
      "\t\t", 
      RowBox[{"Dynamic", "[", 
       RowBox[{"StringJoin", "[", 
        RowBox[{"thetaLeanString", " ", ",", " ", 
         RowBox[{"ToString", "[", "thetaLean", "]"}], ",", 
         " ", "\"\<\[Degree]\>\""}], "]"}], "]"}], ",", "\n", "\t\t", 
      RowBox[{
       RowBox[{"Dynamic", "[", "\n", "\t\t\t", 
        RowBox[{
         RowBox[{"p1", " ", "=", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "hTail"}], "*", 
             RowBox[{"Sin", "[", 
              RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", 
            RowBox[{"hTail", "*", 
             RowBox[{"Cos", "[", 
              RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], ";", 
         "\n", "\t\t\t", 
         RowBox[{"p2", " ", "=", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"p1", "[", 
              RowBox[{"[", "1", "]"}], "]"}], " ", "+", " ", 
             RowBox[{"dTailConst", "*", 
              RowBox[{"Cos", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"180", "-", "thetaLean", "-", "thetaAdj"}], ")"}], " ",
                 "Degree"}], "]"}]}]}], ",", 
            RowBox[{
             RowBox[{"p1", "[", 
              RowBox[{"[", "2", "]"}], "]"}], " ", "+", " ", 
             RowBox[{"dTailConst", "*", 
              RowBox[{"Sin", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"180", "-", "thetaLean", "-", "thetaAdj"}], ")"}], " ",
                 "Degree"}], "]"}]}]}]}], "}"}]}], ";", "\n", "\t\t\t", 
         RowBox[{"val1", "=", "\n", "\t\t\t", 
          RowBox[{"NSolve", "[", "\n", "\t\t\t\t", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"torqueOnPivot", "[", 
               RowBox[{"mTail", ",", "p1", ",", "p2", ",", "9.81"}], "]"}], "==",
               "\n", "\t\t\t\t", 
              RowBox[{
               RowBox[{"mHead", "*", "dHead", "*", 
                RowBox[{"Cos", "[", 
                 RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], "+", 
               RowBox[{"hHead", "*", 
                RowBox[{"Sin", "[", 
                 RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}]}], "&&", 
             "\n", "\t\t\t\t", 
             RowBox[{
             "0", " ", "<=", " ", "thetaAdj", " ", "<=", " ", "180"}]}], ",", 
            "\n", "\t\t\t\t", "thetaAdj"}], "\n", "\t\t\t", "]"}]}], ";", 
         "\n", "\t\t\t", 
         RowBox[{"val2", "=", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"thetaLean", ">=", "0"}], ",", 
            RowBox[{"First", "@", 
             RowBox[{"Flatten", "[", 
              RowBox[{"Values", "[", "val1", "]"}], "]"}]}], ",", 
            RowBox[{"Last", "@", 
             RowBox[{"Flatten", "[", 
              RowBox[{"Values", "[", "val1", "]"}], "]"}]}]}], "]"}]}], ";", 
         "\n", "\t\t\t", 
         RowBox[{"coord1", "=", "p1"}], ";", "\n", "\t\t\t", 
         RowBox[{"coord2", "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"coord1", "[", 
              RowBox[{"[", "1", "]"}], "]"}], " ", "+", " ", 
             RowBox[{"dTailConst", "*", 
              RowBox[{"Cos", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"180", "-", "thetaLean", "-", "val2"}], ")"}], " ", 
                "Degree"}], "]"}]}]}], ",", 
            RowBox[{
             RowBox[{"coord1", "[", 
              RowBox[{"[", "2", "]"}], "]"}], " ", "+", " ", 
             RowBox[{"dTailConst", "*", 
              RowBox[{"Sin", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"180", "-", "thetaLean", "-", "val2"}], ")"}], " ", 
                "Degree"}], "]"}]}]}]}], "}"}]}], ";", "\n", "\t\t\t", 
         RowBox[{"coord3", "=", 
          RowBox[{"Midpoint", "[", 
           RowBox[{"{", 
            RowBox[{"coord1", ",", "coord2"}], "}"}], "]"}]}], ";", "\n", 
         "\t\t\t", 
         RowBox[{"coord4", "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "hHead"}], "*", 
             RowBox[{"Sin", "[", 
              RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", 
            RowBox[{"hHead", "*", 
             RowBox[{"Cos", "[", 
              RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], ";", 
         "\n", "\t\t\t", 
         RowBox[{"coord5", "=", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0"}], "}"}]}], ";", "\n", "\t\t\t", 
         RowBox[{"coord6", " ", "=", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"coord4", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "+", 
             RowBox[{"dHead", "*", 
              RowBox[{"Cos", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"180", "-", "thetaLean"}], ")"}], " ", "Degree"}], 
               "]"}]}]}], ",", 
            RowBox[{
             RowBox[{"coord4", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "-", 
             RowBox[{"dHead", "*", 
              RowBox[{"Sin", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"180", "-", "thetaLean"}], ")"}], " ", "Degree"}], 
               "]"}]}]}]}], "}"}]}], ";", "\n", "\t\t\t", "\"\<\>\""}], "\n", 
        "\t\t", "]"}], "\t\t\t\t", "\n", "\t\t", 
       RowBox[{"Graphics", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Blue", ",", 
           RowBox[{"Dynamic", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Line", "[", 
               RowBox[{"{", 
                RowBox[{"coord5", ",", "coord4"}], "}"}], "]"}], ",", 
              RowBox[{"Line", "[", 
               RowBox[{"{", 
                RowBox[{"coord4", ",", "coord6"}], "}"}], "]"}], ",", 
              RowBox[{"Line", "[", 
               RowBox[{"{", 
                RowBox[{"coord2", ",", "coord1"}], "}"}], "]"}]}], "}"}], 
            "]"}]}], "}"}], ",", 
         RowBox[{"ImageSize", "->", "Medium"}], ",", 
         RowBox[{"PlotRange", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "1"}], ",", "10"}], "}"}]}], "}"}]}]}], "]"}]}]}], 
     "\n", "\t", "}"}], "]"}]}], "\n", "]"}]], "Code",
 CellChangeTimes->{3.991947938466017*^9, 3.991989361389205*^9},
 CellLabel->
  "In[783]:=",ExpressionUUID->"bf6b98ab-b7ad-4954-a583-5cc10ef4661d"],

Cell[BoxData[
 DynamicModuleBox[{$CellContext`thetaLeanString$$ = 
  "\[Theta]_lean = ", $CellContext`p1$$ = {
  Rational[-1, 2] 2^Rational[-1, 2] (-1 + 3^Rational[1, 2]), Rational[1, 2] 
   2^Rational[-1, 2] (1 + 3^Rational[1, 2])}, $CellContext`p2$$ = {
  Rational[-1, 2] 2^Rational[-1, 2] (-1 + 3^Rational[1, 2]) + 
   3 Cos[Degree (165 - $CellContext`thetaAdj)], 
   Rational[1, 2] 2^Rational[-1, 2] (1 + 3^Rational[1, 2]) + 
   3 Sin[Degree (
       165 - $CellContext`thetaAdj)]}, $CellContext`val1$$ = \
{{$CellContext`thetaAdj -> 89.43840900342931}}, $CellContext`val2$$ = 
  89.43840900342931, $CellContext`coord1$$ = {
  Rational[-1, 2] 2^Rational[-1, 2] (-1 + 3^Rational[1, 2]), Rational[1, 2] 
   2^Rational[-1, 2] (1 + 3^Rational[1, 2])}, $CellContext`coord2$$ = {
  0.4891983572127832, 3.8711745188855327`}, $CellContext`coord3$$ = {
  0.11518965605513126`, 2.4185501725873007`}, $CellContext`coord4$$ = {
  Rational[-5, 2] 2^Rational[-1, 2] (-1 + 3^Rational[1, 2]), Rational[5, 2] 
   2^Rational[-1, 2] (1 + 3^Rational[1, 2])}, $CellContext`coord5$$ = {0, 
  0}, $CellContext`coord6$$ = {
  Rational[-5, 2] 2^Rational[-1, 2] (-1 + 3^Rational[1, 2]) + 
   Rational[-1, 2] 2^Rational[-1, 2] (1 + 3^Rational[1, 2]), 
   Rational[-1, 2] 2^Rational[-1, 2] (-1 + 3^Rational[1, 2]) + 
   Rational[5, 2] 2^Rational[-1, 2] (1 + 3^Rational[1, 2])}}, 
  TagBox[GridBox[{
     {
      SliderBox[Dynamic[$CellContext`thetaLean], {-89.9, 89.9}]},
     {
      DynamicBox[
       ToBoxes[$CellContext`thetaLeanString$$ <> 
        ToString[$CellContext`thetaLean] <> "\[Degree]", StandardForm],
       ImageSizeCache->{117.00634765625, {1.8170166015625, 11.57}}]},
     {
      RowBox[{
       DynamicBox[
        ToBoxes[$CellContext`p1$$ = {(-$CellContext`hTail) 
            Sin[$CellContext`thetaLean Degree], $CellContext`hTail 
            Cos[$CellContext`thetaLean Degree]}; $CellContext`p2$$ = {
           Part[$CellContext`p1$$, 1] + $CellContext`dTailConst 
             Cos[(180 - $CellContext`thetaLean - $CellContext`thetaAdj) 
               Degree], 
            Part[$CellContext`p1$$, 2] + $CellContext`dTailConst 
             Sin[(180 - $CellContext`thetaLean - $CellContext`thetaAdj) 
               Degree]}; $CellContext`val1$$ = NSolve[
            
            And[$CellContext`torqueOnPivot[$CellContext`mTail, \
$CellContext`p1$$, $CellContext`p2$$, 
               9.81] == $CellContext`mHead $CellContext`dHead 
               Cos[$CellContext`thetaLean Degree] + $CellContext`hHead 
               Sin[$CellContext`thetaLean Degree], 0 <= $CellContext`thetaAdj <= 
             180], $CellContext`thetaAdj]; $CellContext`val2$$ = 
          If[$CellContext`thetaLean >= 0, 
            First[
             Flatten[
              Values[$CellContext`val1$$]]], 
            Last[
             Flatten[
              
              Values[$CellContext`val1$$]]]]; $CellContext`coord1$$ = \
$CellContext`p1$$; $CellContext`coord2$$ = {
           Part[$CellContext`coord1$$, 1] + $CellContext`dTailConst 
             Cos[(180 - $CellContext`thetaLean - $CellContext`val2$$) Degree],
             Part[$CellContext`coord1$$, 2] + $CellContext`dTailConst 
             Sin[(180 - $CellContext`thetaLean - $CellContext`val2$$) 
               Degree]}; $CellContext`coord3$$ = 
          Midpoint[{$CellContext`coord1$$, $CellContext`coord2$$}]; \
$CellContext`coord4$$ = {(-$CellContext`hHead) 
            Sin[$CellContext`thetaLean Degree], $CellContext`hHead 
            Cos[$CellContext`thetaLean Degree]}; $CellContext`coord5$$ = {0, 
           0}; $CellContext`coord6$$ = {
           Part[$CellContext`coord4$$, 1] + $CellContext`dHead 
