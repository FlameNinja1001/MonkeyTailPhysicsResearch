 CellLabel->
  "In[1225]:=",ExpressionUUID->"8b316891-cc46-4475-8f26-493f8b82e012"],

Cell[TextData[{
 "We then set up the model defined above using the NSolve function, which can \
automatically solve for unknowns, such as ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "2efcad76-c6e9-47c7-9624-609805a8674f"],
 ", in an equation. Doing that with the above parameters yields the following \
result."
}], "Text",
 CellChangeTimes->{{3.99190227519729*^9, 3.991902275854611*^9}, {
  3.991902348282752*^9, 3.9919023868802967`*^9}, {3.9919991231925783`*^9, 
  3.9919991237647867`*^9}},ExpressionUUID->"b4eb0987-774e-46ca-a39b-\
6c88bb75d9de"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NSolve", "[", "\n", "\t", 
  RowBox[{
   RowBox[{
    RowBox[{"mHead", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"dHead", "*", 
        RowBox[{"Cos", "[", 
         RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], "+", 
       RowBox[{"hHead", "*", 
        RowBox[{"Sin", "[", 
         RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], ")"}]}], "==", 
    RowBox[{"mTail", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"dTail", "*", 
           RowBox[{"Cos", "[", 
            RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ")"}], "/", "2"}], 
        ")"}], "-", 
       RowBox[{"hTail", "*", 
        RowBox[{"Sin", "[", 
         RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], ")"}]}]}], ",", 
   "\n", "\t", "dTail"}], "]"}]], "Code",
 CellChangeTimes->{
  3.991840322657197*^9, {3.9919023631853228`*^9, 3.9919023641122837`*^9}, 
   3.991907599137916*^9, 3.991907651080515*^9},
 CellLabel->
  "In[1232]:=",ExpressionUUID->"4eeea633-52f6-439f-94ba-b07cf20edf7f"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{"dTail", "\[Rule]", "5.215390309173472`"}], "}"}], "}"}]], "Output",\

 CellChangeTimes->{{3.991840497576198*^9, 3.991840502418158*^9}, 
   3.991841178107341*^9, {3.991841314979292*^9, 3.991841334582686*^9}, 
   3.9918416813661757`*^9, 3.991900211625662*^9, 3.991900408715494*^9, 
   3.9919025781511993`*^9, 3.9919073042816153`*^9, {3.9919075761124783`*^9, 
   3.991907576324671*^9}, {3.9919076541679163`*^9, 3.991907674988295*^9}, 
   3.99190775217782*^9, 3.991929397213524*^9, 3.991947924008039*^9, 
   3.991989363682344*^9, 3.9919896392542343`*^9, {3.991989724733789*^9, 
   3.9919897407367077`*^9}, 3.991989828794436*^9, 3.991989959564096*^9, {
   3.991990087853918*^9, 3.991990105568865*^9}, 3.991992547924882*^9, 
