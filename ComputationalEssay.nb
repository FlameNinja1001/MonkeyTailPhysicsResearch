AAD2o58BAAAA+9HPAAAAgP3oZwAAAMB+9DMAAABgP/oZAAAAsB/9DAAAANgv
MzNzchVlW/Y4AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAQNP3/0YW3Ug=

     "], {{0, 960.}, {960., 0}}, {0, 255},
     ColorFunction->RGBColor],
    BoxForm`ImageTag["Byte", ColorSpace -> "RGB", Interleaving -> True],
    Selectable->False],
   DefaultBaseStyle->"ImageGraphics",
   ImageSizeRaw->{960., 960.},
   PlotRange->{{0, 960.}, {0, 960.}}]], "Input",ExpressionUUID->
  "19428011-aaaa-4e98-a1d5-3c1a49102754"],
 "\[LineSeparator]Notice how part of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "902ffebc-b16c-4e3a-87dc-f34d8af84815"],
 " is in the angle that the triangle makes. The specific angle, as this \
diagram shows the one with two arcs, can actually be calculated by the \
following expression:\n\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "f31aab41-bcc5-411a-a821-3c11c34a6ea1"],
 "-90-",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "8324453d-144c-42d6-987d-b0f1792cf92c"],
 "\n\nKnowing ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "099ab0b2-4859-4c13-b201-aa1612aeb771"],
 " will always be the hypotenuse, we can use this new angle to calculate for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "afaec21c-f9d6-4862-96f1-87ca92da714b"],
 " with the following equation:\n\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "3e3de382-59d0-4a02-9a74-8ca7eaa6c9df"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "0e0104f2-1498-4532-ad2b-e8d600d1d1f7"],
 " + (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "e4168b30-0eb0-4109-8fcd-0e748848acf7"],
 "*cos(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "e26540aa-b4d9-462c-9b9b-d271c7478592"],
 "-90-",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "7d568e4b-9509-4cb6-886e-5c2cbde073cf"],
 "),",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "1a415b24-5e1f-4fee-bb67-4fdf048eed43"],
 "*sin(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "3bf56920-2c08-4fd6-b1ea-3035a78ecba0"],
 "-90-",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "77da092d-99e7-4ef1-ab4e-8d5ae667d8ab"],
 "))\n\nWhich can be represented in Wolfram by the following line of code:"
}], "Text",
 CellChangeTimes->{
  3.991996786810734*^9, {3.991997503762938*^9, 3.991997515377739*^9}, {
   3.991997551293169*^9, 3.9919975806897287`*^9}, {3.991997623093213*^9, 
   3.991997657604932*^9}, {3.991998110067182*^9, 3.991998136586851*^9}, {
   3.991998191827361*^9, 3.991998195137241*^9}, {3.991998274878636*^9, 
   3.9919982992582417`*^9}, {3.9920363227529097`*^9, 
   3.9920363485192137`*^9}, {3.992036534042034*^9, 3.992036583952232*^9}, {
   3.992036625134193*^9, 3.992036813433775*^9}, {3.992036845333207*^9, 
   3.992036865138281*^9}, 3.9920369097276154`*^9, {3.99203718625496*^9, 
   3.9920371911658087`*^9}, {3.992082448586135*^9, 3.992082449088189*^9}, {
   3.9920825468695583`*^9, 3.9920825575291653`*^9}, {3.9920826261872253`*^9, 
   3.992082631132069*^9}},ExpressionUUID->"614801d0-1d64-4a09-a99c-\
83d74e4bbe15"],

Cell[BoxData[
 RowBox[{
  RowBox[{"p2", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"p1", "[", 
       RowBox[{"[", "1", "]"}], "]"}], " ", "+", " ", 
      RowBox[{"dTailConst", "*", 
       RowBox[{"Cos", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"thetaAdj", "-", "90", "-", "thetaLean"}], ")"}], " ", 
         "Degree"}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"p1", "[", 
       RowBox[{"[", "2", "]"}], "]"}], " ", "+", " ", 
      RowBox[{"dTailConst", "*", 
       RowBox[{"Sin", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"thetaAdj", "-", "90", "-", "thetaLean"}], ")"}], " ", 
         "Degree"}], "]"}]}]}]}], "}"}]}], ";"}]], "Code",
 CellChangeTimes->{{3.99199679009562*^9, 3.991996799197044*^9}, {
  3.9920826363194733`*^9, 3.992082646244101*^9}},
 CellLabel->
  "In[1244]:=",ExpressionUUID->"30b42878-71c1-443f-877a-8fa4641beece"],

Cell[TextData[{
 "Now, since we know ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "0f12c655-3f81-46f1-aa85-4303b6268edc"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "9e99ed3f-9f28-4355-be1d-e124d1886b71"],
 " as the start and endpoints of the tail, we can calculate the torque on the \
tail through the function defined earlier. Then, we can set it equal to the \
torque of the head from the Model V1, and solve for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "18d7f8d5-03e8-43bd-b2bb-b2fac0a1bdfb"],
 " with the following piece of code."
}], "Text",
 CellChangeTimes->{
  3.991996791536162*^9, {3.991998858593671*^9, 3.991998925845018*^9}, {
   3.991999051858283*^9, 
   3.991999053898929*^9}},ExpressionUUID->"c569c044-0b0d-494f-bfc2-\
a38b1d1f8916"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NSolve", "[", "\n", "\t", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"torqueOnPivot", "[", 
      RowBox[{"mTail", ",", "p1", ",", "p2", ",", "9.81"}], "]"}], "==", "\n",
      "\t", 
     RowBox[{
      RowBox[{"mHead", "*", "dHead", "*", 
       RowBox[{"Cos", "[", 
        RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], "+", 
      RowBox[{"hHead", "*", 
       RowBox[{"Sin", "[", 
        RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}]}], "&&", "\n", "\t", 
    RowBox[{"0", " ", "<=", " ", "thetaAdj", " ", "<=", " ", "180"}]}], ",", 
   "\n", "\t", "thetaAdj"}], "\n", "]"}]], "Code",
 CellChangeTimes->{3.9919895262654533`*^9},
 CellLabel->
  "In[1245]:=",ExpressionUUID->"d94779da-ef7c-443a-996e-bc9252ed7bfa"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{"thetaAdj", "\[Rule]", "29.43840900342931`"}], "}"}], 
  "}"}]], "Output",
 CellChangeTimes->{
  3.991989639788385*^9, {3.991989724974826*^9, 3.991989741035997*^9}, 
   3.9919898290635757`*^9, 3.991989960850988*^9, {3.991990088826375*^9, 
   3.991990105913843*^9}, 3.991992548939085*^9, 3.991993882952071*^9, 
   3.991993959696947*^9, 3.991994651817924*^9, 3.9919963079910383`*^9, 
   3.991999065414356*^9, {3.992036922816298*^9, 3.9920369251145077`*^9}, 
   3.992037215670274*^9, 3.992080219650731*^9, 3.9920824644140778`*^9, 
   3.992082659099216*^9, 3.992084088418128*^9},
 CellLabel->
  "Out[1245]=",ExpressionUUID->"a82e03d0-e68c-4e9b-92df-ab959b70a849"]
}, Open  ]],

Cell[TextData[{
 "Finally, just like the previous model, we now use DynamicModule and a \
slider that changes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "7c9181ce-c013-4de2-822d-7495955d2181"],
 ". We need to be careful to distinguish between the points used to solve \
(local variables p1 and p2) and the points used to draw (coord1, coord2, \
coord3, coord4, coord5, coord6) due to memory allocation. The simulation is \
visualized below:"
}], "Text",
 CellChangeTimes->{{3.99199893926355*^9, 
  3.9919990471348753`*^9}},ExpressionUUID->"2ef6ac2a-3391-46d0-95ff-\
ff39c29a95cb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DynamicModule", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"thetaLeanString", "=", "\"\<\[Theta]_lean = \>\""}], ",", 
     RowBox[{"p1", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"p2", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"val1", "=", "0"}], ",", 
     RowBox[{"val2", "=", "0"}], ",", 
     RowBox[{"coord1", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"coord2", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"coord3", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"coord4", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"coord5", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", 
     RowBox[{"coord6", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}]}], "}"}], ",", "\n", "\t", "\n", "\t", 
   RowBox[{"Column", "[", 
    RowBox[{"{", "\n", "\t\t", 
     RowBox[{
      RowBox[{"Slider", "[", 
       RowBox[{
        RowBox[{"Dynamic", "[", "thetaLean", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "89.9"}], ",", "89.9"}], "}"}]}], "]"}], ",", "\n", 
      "\t\t", 
      RowBox[{"Dynamic", "[", 
       RowBox[{"StringJoin", "[", 
        RowBox[{"thetaLeanString", " ", ",", " ", 
         RowBox[{"ToString", "[", "thetaLean", "]"}], ",", 
         " ", "\"\<\[Degree]\>\""}], "]"}], "]"}], ",", "\n", "\t\t", 
      RowBox[{
       RowBox[{"Dynamic", "[", "\n", "\t\t\t", 
        RowBox[{
         RowBox[{"p1", " ", "=", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "hTail"}], "*", 
             RowBox[{"Sin", "[", 
              RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", 
            RowBox[{"hTail", "*", 
             RowBox[{"Cos", "[", 
              RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], ";", 
         "\n", "\t\t\t", 
         RowBox[{"p2", " ", "=", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"p1", "[", 
              RowBox[{"[", "1", "]"}], "]"}], " ", "+", " ", 
             RowBox[{"dTailConst", "*", 
              RowBox[{"Cos", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"180", "-", "thetaLean", "-", "thetaAdj"}], ")"}], " ",
                 "Degree"}], "]"}]}]}], ",", 
            RowBox[{
             RowBox[{"p1", "[", 
              RowBox[{"[", "2", "]"}], "]"}], " ", "+", " ", 
             RowBox[{"dTailConst", "*", 
              RowBox[{"Sin", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"180", "-", "thetaLean", "-", "thetaAdj"}], ")"}], " ",
