Cell[BoxData[
 DynamicModuleBox[{$CellContext`dTail$$ = Dynamic[
   Part[
    Part[
     Values[
      NSolve[$CellContext`mHead ($CellContext`dHead 
          Cos[$CellContext`thetaLean Degree] + $CellContext`hHead 
          Sin[$CellContext`thetaLean 
            Degree]) == $CellContext`mTail (($CellContext`dTail$$ 
           Cos[$CellContext`thetaLean Degree])/2 - $CellContext`hTail 
         Sin[$CellContext`thetaLean Degree]), $CellContext`dTail$$]], 1], 
    1]], $CellContext`thetaLeanString$$ = "\[Theta]_lean = "}, 
  TagBox[GridBox[{
     {
      SliderBox[Dynamic[$CellContext`thetaLean], {-89.9, 89.9}]},
     {
      DynamicBox[
       ToBoxes[$CellContext`thetaLeanString$$ <> 
        ToString[$CellContext`thetaLean] <> "\[Degree]", StandardForm],
       ImageSizeCache->{117.00634765625, {1.8170166015625, 11.57}}]},
     {""},
     {
      GraphicsBox[
       {RGBColor[0, 0, 1], 
        DynamicBox[Typeset`ToBoxes[
          Rotate[{
            Line[{{0, 0}, {0, $CellContext`hHead}}], 
            
            Line[{{0, $CellContext`hTail}, {$CellContext`dTail$$, \
$CellContext`hTail}}], 
            
            Line[{{0, $CellContext`hHead}, {-$CellContext`dHead, \
$CellContext`hHead}}]}, $CellContext`thetaLean Degree, {0, 0}], StandardForm, 
          Graphics],
         ImageSizeCache->{{173.2656428579792, 
          282.5577856568275}, {-11.882997430097106`, 98.55142498038944}}]},
       ImageSize->Medium,
       PlotRange->{{-10, 10}, {-1, 10}}]}
    },
