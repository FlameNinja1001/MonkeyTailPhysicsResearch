Cell[CellGroupData[{

Cell["Model V2 - Self-Balancing Tail with Variable Rotation", "Section",
 CellChangeTimes->{{3.929354612578005*^9, 3.929354616192994*^9}, {
  3.929355210549653*^9, 3.9293552190879917`*^9}, {3.9918429510719347`*^9, 
  3.991842958992612*^9}, {3.991902603837475*^9, 
  3.99190260972873*^9}},ExpressionUUID->"e8a0458b-9a9a-4f2c-b0e2-\
e43b9f94ed10"],

Cell[TextData[{
 "Our model now works, however it is inaccurate to any animal\
\[CloseCurlyQuote]s behavior in nature. An animal cannot grow or shrink its \
tail in real-time. Instead, to counterbalance its mass, it will change the \
angle of its tail. To achieve this, we need to adjust our model and define a \
new constant for the angle of the tail, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "dynamic"], TraditionalForm]],ExpressionUUID->
  "4247fcf8-d8b2-49fc-bb69-20ac98409d74"],
 "."
}], "Text",
 CellChangeTimes->{{3.9293546184036617`*^9, 3.9293546199188967`*^9}, {
   3.991843023893482*^9, 3.991843098671399*^9}, {3.991843141651308*^9, 
   3.991843153204752*^9}, {3.9918432145448112`*^9, 3.991843314639442*^9}, {
   3.991843367531785*^9, 3.991843482849601*^9}, {3.991843529523225*^9, 
   3.991843563288316*^9}, {3.99184359410602*^9, 3.9918436278691387`*^9}, {
   3.9918436914439497`*^9, 3.991843723147058*^9}, {3.991843789397196*^9, 
   3.9918438381344337`*^9}, {3.99184392692651*^9, 3.991844022786091*^9}, {
   3.991844093496125*^9, 3.9918441019339437`*^9}, {3.991844140124487*^9, 
   3.991844288216073*^9}, {3.991844434010304*^9, 3.991844463089705*^9}, 
   3.991844536742257*^9, {3.991844571327832*^9, 3.991844681795814*^9}, {
   3.991844719772691*^9, 3.9918447236166487`*^9}, {3.99184475520887*^9, 
   3.991844812664764*^9}, {3.991900660775463*^9, 3.991900688971546*^9}, {
   3.991900729486137*^9, 3.9919007895352983`*^9}, {3.991901415519161*^9, 
   3.991901558521984*^9}, {3.991901612081134*^9, 3.991901873321487*^9}, {
   3.991901966594462*^9, 3.991902031905037*^9}, {3.991902066001555*^9, 
   3.991902119420312*^9}, {3.991902164200292*^9, 3.9919022705054607`*^9}, {
   3.9919026130265217`*^9, 3.991902717309389*^9}, {3.9919286260625057`*^9, 
   3.991928628264051*^9}},ExpressionUUID->"6f678598-b46d-45ab-81e9-\
f26a42d88268"],

Cell[BoxData[
 RowBox[{
  RowBox[{"torqueOnPivot", "[", 
   RowBox[{"mass_", ",", "p1_", ",", "p2_", ",", "gravity_"}], "]"}], ":=", 
  " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "centerOfMass", ",", "xDist", ",", "yDist", ",", "thetaTail", ",", 
      "radius"}], "}"}], ",", "\n", "\t", 
    RowBox[{
     RowBox[{"centerOfMass", " ", "=", " ", 
      RowBox[{"Midpoint", "[", 
       RowBox[{"{", 
        RowBox[{"p1", ",", "p2"}], "}"}], "]"}]}], ";", "\t", "\n", "\t", 
     RowBox[{"thetaTail", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"ArcTan", "[", 
         RowBox[{
          RowBox[{"centerOfMass", "[", 
           RowBox[{"[", "2", "]"}], "]"}], ",", 
          RowBox[{"centerOfMass", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "/", "Degree"}], "//", 
       "FullSimplify"}]}], ";", "\n", "\t", 
     RowBox[{"radius", " ", "=", " ", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"centerOfMass", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "^", "2"}], ")"}], "+", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"centerOfMass", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "^", "2"}], ")"}]}], "]"}]}], ";", 
     "\n", "\t", 
     RowBox[{"(*", 
      RowBox[{"Return", " ", "torque", " ", "now"}], "*)"}], "\n", "\t", 
     RowBox[{"mass", "*", "gravity", "*", "radius", "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"thetaTail", " ", "Degree"}], "]"}]}]}]}], "\n", 
   "]"}]}]], "Code",
