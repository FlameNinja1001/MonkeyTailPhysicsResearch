     "], {{0, 960.}, {960., 0}}, {0, 255},
     ColorFunction->RGBColor],
    BoxForm`ImageTag["Byte", ColorSpace -> "RGB", Interleaving -> True],
    Selectable->False],
   DefaultBaseStyle->"ImageGraphics",
   ImageSizeRaw->{960., 960.},
   PlotRange->{{0, 960.}, {0, 960.}}]], "Input",ExpressionUUID->
  "d6593441-4c81-4a78-b95f-1dcd58edd8c3"],
 "\nNotice how now, the angle between the tail and the body is no longer 90 \
degrees. This means that calculating for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "t"], TraditionalForm]],ExpressionUUID->
  "acfbaa4c-ec51-48c6-81dc-b29b50544900"],
 " and the torque of the tail is slightly more complex. We can calculate it \
by representing the joint where the tail connects to the tail and the tip of \
the tail as coordinates ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "9a722243-a535-4b66-bcab-3857df2aa844"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "116a174f-80a6-41ff-82b8-a7e7073c2b47"],
 ", with the center of mass as the midpoint between them.\n",
 Cell[BoxData[
  GraphicsBox[
   TagBox[RasterBox[CompressedData["
