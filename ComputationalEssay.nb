            Part[$CellContext`coord4$$, 2] - $CellContext`dHead 
            Sin[(180 - $CellContext`thetaLean) Degree]}; "", StandardForm],
        ImageSizeCache->{0., {0., 7.8975}}], " ", 
       GraphicsBox[
