                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"-", "dHead"}], ",", "hHead"}], "}"}]}], "}"}], 
                "]"}]}], "}"}], ",", 
             RowBox[{"thetaLean", " ", "Degree"}], ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}]}], "]"}], "]"}]}], "\n", "\t\t", 
