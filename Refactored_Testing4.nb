    "\t", 
    RowBox[{"Graphics", "[", "\n", "\t\t", 
     RowBox[{
      RowBox[{"{", "\n", "\t\t\t", 
       RowBox[{"Blue", ",", " ", 
        RowBox[{"Join", "[", 
