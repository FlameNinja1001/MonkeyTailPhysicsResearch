              RowBox[{"[", 
               RowBox[{"n", "-", "1"}], "]"}], "]"}], "*", 
             RowBox[{"Cos", "[", 
              RowBox[{"theta", "[", 
               RowBox[{"[", 
                RowBox[{"n", "-", "1"}], "]"}], "]"}], "]"}]}], ",", " ", 
            "\n", "\t\t\t\t", 
