              RowBox[{"p0", ",", "pH"}], "}"}], "]"}], ",", " ", 
            RowBox[{"Line", "[", 
             RowBox[{"{", 
              RowBox[{"mH", ",", " ", "pH"}], "}"}], "]"}]}], "}"}], ",", " ",
           "\n", "\t\t\t\t", 
          RowBox[{"Table", "[", "\n", "\t\t\t\t\t", 
           RowBox[{
            RowBox[{"Line", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"pEvals", "[", 
                RowBox[{"[", "n", "]"}], "]"}], ",", " ", 
               RowBox[{"pEvals", "[", 
                RowBox[{"[", 
                 RowBox[{"n", "+", "1"}], "]"}], "]"}]}], "}"}], "]"}], ",", 
            " ", 
            RowBox[{"{", 
             RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], 
           "\n", "\t\t\t\t", "]"}]}], "\n", "\t\t\t", "]"}], ",", "\n", 
        "\t\t\t", "LightGray", ",", " ", "Dashed", ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Line", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"10", ",", "0"}], "}"}]}], "}"}], "]"}], ",", " ", 
          RowBox[{"Line", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", "10"}], "}"}]}], "}"}], "]"}]}], "}"}]}], 
       "\n", "\t\t", "}"}], ",", " ", "\n", "\t\t", 
      RowBox[{"ImageSize", " ", "->", " ", "Large"}], ",", " ", 
      RowBox[{"PlotRange", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "}"}]}]}], "\n", "\t", 
     "]"}]}], ",", "\n", "\t", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"upperBound", ",", " ", 
       RowBox[{"7", 
        RowBox[{"Pi", "/", "6"}]}], ",", " ", "\"\<Upper Bound\>\""}], "}"}], 
     ",", " ", "0", ",", " ", 
     RowBox[{"2", "Pi"}], ",", " ", 
