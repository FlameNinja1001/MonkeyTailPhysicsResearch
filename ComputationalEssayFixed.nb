   3.99259747202188*^9}, {3.992598757839549*^9, 3.99259875926333*^9}, 
   3.9926015395333157`*^9, {3.9926146670997972`*^9, 3.992614668487796*^9}, {
   3.9926151042452097`*^9, 3.992615107451022*^9}, {3.992615641945334*^9, 
   3.99261570439085*^9}, 
   3.992615830248248*^9},ExpressionUUID->"23917c66-1620-4596-9bde-\
e9d3de20baa0"],

Cell["F = m \:22c5 g ,", "Text",
 CellChangeTimes->{{3.9926146712834873`*^9, 3.992614673402608*^9}, {
   3.992614709477728*^9, 3.992614714291088*^9}, {3.992614777181168*^9, 
