Cell[BoxData[{
 RowBox[{
  RowBox[{"lowerBound", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"upperBound", " ", "=", " ", 
   RowBox[{"2", "Pi"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"constraints", " ", "=", " ", 
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", " ", "<", " ", 
       RowBox[{"thetaAdjVars", "[", "1", "]"}], " ", "<", " ", "Pi"}], "}"}], 
     ",", "\n", "\t", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"lowerBound", " ", "<=", " ", 
        RowBox[{"thetaAdjVars", "[", "n", "]"}], " ", "<", " ", 
        "upperBound"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"n", ",", " ", "2", ",", " ", "numPoints"}], "}"}]}], "]"}]}],
     "\n", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{
  3.992439038272984*^9, {3.992439138154262*^9, 3.9924391412218847`*^9}, {
