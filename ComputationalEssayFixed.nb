Cell[TextData[{
 "In this case, I knew the the length, the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "aa89dba4-4593-4a1a-97c3-1fc34f309acc"],
 " constant, and the angle, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "4ea1d5a9-fff7-40ab-8b1d-2d908583a668"],
 ". Because ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "e8044564-ee5a-4438-bdb0-8b19c690ebb9"],
 " is with respect to the horizontal, I defined any given ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "n"], TraditionalForm]],ExpressionUUID->
  "0c7fa10f-1b65-4553-a15a-182a5c6ae85d"],
 " coordinate as the following:"
}], "Text",
 CellChangeTimes->{{3.9926030450437317`*^9, 
  3.9926030895211163`*^9}},ExpressionUUID->"90d816ac-781e-49d1-be45-\
e670cb4c9689"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "n"], " "}], TraditionalForm]],ExpressionUUID->
  "b8d02715-d3a4-4b25-93cc-2ea481435a60"],
 "= ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", 
     RowBox[{"n", "-", "1"}]], " "}], TraditionalForm]],ExpressionUUID->
  "d22d25dc-1d71-470a-a42a-2a314eb6e283"],
 " + (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "tail"], " "}], TraditionalForm]],ExpressionUUID->
  "c9efc5b0-cca5-4e4c-9ab1-9f527454dab8"],
 " \:22c5 cos(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "39ca34fc-b635-4f67-b4ce-b065090e35a6"],
 "), ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "tail"], " "}], TraditionalForm]],ExpressionUUID->
  "879346fa-01ee-4450-b1b1-00931ac800da"],
 " \:22c5 sin(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "14de5450-ab87-4f89-85ad-6aabd4fcb69b"],
 ")); ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "96f8c9b5-7bfa-4404-a022-3b3e4bc01989"],
 " \[GreaterEqual] 2"
}], "Text",
