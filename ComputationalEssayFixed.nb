Cell[TextData[{
 "Notice a pattern here between ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "2"], TraditionalForm]],ExpressionUUID->
  "9bf562e1-2372-3c47-9d92-cfb890d80974"],
