61fab58ddadc"],

Cell[TextData[{
 "With ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "1"], TraditionalForm]],ExpressionUUID->
  "926692ff-876d-8445-b1c7-8df36cf76347"],
 " solved for, I began computing for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj2"], TraditionalForm]],ExpressionUUID->
  "058013d9-6de3-f845-8c1e-13737f1e71ec"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "2"], TraditionalForm]],ExpressionUUID->
  "a89722d4-7213-3846-a62d-380e26adc137"],
 ". To do so, I defined a new reference frame following a straight extension \
from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "8e091ed4-6437-b94a-b7b2-481088fe6e67"],
 ", essentially creating a new unit circle to draw the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj2"], TraditionalForm]],ExpressionUUID->
  "f2b147f7-faa4-514f-9ee6-5396711fb953"],
 " around. Notice that when the extension is drawn, the axis ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj2"], TraditionalForm]],ExpressionUUID->
  "c7105a63-60a5-354f-aa11-78023b9ce814"],
 " is rotationally transformed from the true horizontal. To get the larger \
angle shown below, which is labeled ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "2"], TraditionalForm]],ExpressionUUID->
  "9f0ba1d1-b53c-bc4f-9d0d-7c4b9e1409f4"],
 ", I took the total angle between the new ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj2"], TraditionalForm]],ExpressionUUID->
  "261d7db8-ea02-0042-b3db-bec570525259"],
 " and the original horizontal:"
}], "Text",
