    Typeset`keyframeActionsQ$$ = False, Typeset`keyframeList$$ = {}}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, 
      "Variables" :> {$CellContext`dTailConst$$ = 
        1, $CellContext`mTailConst$$ = 1, $CellContext`numPoints$$ = 
        6, $CellContext`thetaLean$$ = Rational[1, 7] Pi}, 
      "ControllerVariables" :> {}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$, Typeset`keyframeActionsQ$$, 
        Typeset`keyframeList$$}, 
      "Body" :> ($CellContext`hTail = 1.; $CellContext`mHead = 
        1.; $CellContext`hHead = 5.; $CellContext`dHead = 
        1.; $CellContext`p0 = {0, 0}; $CellContext`listOfDistances = 
        Table[$CellContext`dTailConst$$, $CellContext`numPoints$$]; \
$CellContext`listOfMasses = 
        Table[$CellContext`mTailConst$$, $CellContext`numPoints$$]; \
$CellContext`lowerBound = 0; $CellContext`upperBound = 
        2 Pi; {$CellContext`thetaVars, $CellContext`thetaAdjVars} = \
$CellContext`thetaVarsFunc[$CellContext`numPoints$$, \
$CellContext`thetaLean$$]; $CellContext`pVars = \
$CellContext`pVarsFunc[$CellContext`numPoints$$, $CellContext`hTail, \
$CellContext`thetaLean$$, $CellContext`listOfDistances, \
$CellContext`thetaVars]; $CellContext`mVars = Table[
          Midpoint[{
            Part[$CellContext`pVars, $CellContext`n], 
            Part[$CellContext`pVars, $CellContext`n + 1]}], {$CellContext`n, 
           1, $CellContext`numPoints$$}]; $CellContext`torqueVars = Table[
          $CellContext`torqueAtPoint[
           Part[$CellContext`listOfMasses, $CellContext`n], 
