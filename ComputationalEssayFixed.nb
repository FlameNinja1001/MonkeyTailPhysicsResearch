       Hold[$CellContext`mTailConst$$], 1, "Tail Mass"}, 0.1, 10, ControlType -> 
      Manipulator}, {{
       Hold[$CellContext`numPoints$$], 6, "Number of Joints"}, 1, 10, 1, 
      ControlType -> Manipulator}, {{
       Hold[$CellContext`dTailConst$$], 1, "Tail length"}, 1, 10, ControlType -> 
      Manipulator}}, Typeset`size$$ = {
    576., {285.134033203125, 290.865966796875}}, Typeset`update$$ = 0, 
