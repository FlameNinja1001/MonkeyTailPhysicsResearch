Cell[TextData[{
 "With the pivot points defined, I began computing for the adjustment angle \
",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "dd4f024c-7197-46bf-bf72-fcb913df1b85"],
 ". Because each ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "0f78fcf8-02ee-46db-9b90-94638dc99eba"],
 "-numbered joint is rotating, I need to index the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "c935fdf6-33bf-48aa-9112-2eaa64f1f76f"],
 " angles each as ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", 
    RowBox[{"adj", " ", "n"}]], TraditionalForm]],ExpressionUUID->
  "340fd18b-d1c1-44ef-9f9d-bfebfa9afac8"],
 ". In the above tail with three joints, the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", 
    RowBox[{"adj", " ", "n"}]], TraditionalForm]],ExpressionUUID->
  "9d687801-cd98-4a17-a759-178ee7bd23cb"],
 " angles were defined as the following:"
}], "Text",
