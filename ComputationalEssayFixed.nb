Cell["\<\
Taking into account the prior helper functions, as well as the formulas \
listed earlier, I visualized the multi-jointed tail simulation with a \
Manipulate:\
\>", "CodeText",
 CellChangeTimes->{{3.992592682116405*^9, 3.992592706842729*^9}, {
  3.9925986283808537`*^9, 
  3.992598629549307*^9}},ExpressionUUID->"7ec294ba-be19-4184-af29-\
367dabcdf6bc"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Dynamic", "[", "error", "]"}], "\n", 
 RowBox[{"Manipulate", "[", "\n", "\t", 
  RowBox[{
   RowBox[{
    RowBox[{"hTail", " ", "=", " ", "1.0"}], ";", " ", "\n", "\t", 
    RowBox[{"mHead", " ", "=", " ", "1.0"}], ";", " ", 
    RowBox[{"hHead", " ", "=", " ", "5.0"}], ";", " ", 
    RowBox[{"dHead", " ", "=", " ", "1.0"}], ";", " ", "\n", "\t", 
    RowBox[{"p0", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0"}], "}"}]}], ";", " ", "\n", "\t", 
    RowBox[{"listOfDistances", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{"dTailConst", ",", " ", "numPoints"}], "]"}]}], ";", "\n", "\t", 
    RowBox[{"listOfMasses", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{"mTailConst", ",", " ", "numPoints"}], "]"}]}], ";", "\n", "\t", 
    RowBox[{"lowerBound", " ", "=", " ", "0"}], ";", "\n", "\t", 
    RowBox[{"upperBound", " ", "=", " ", 
     RowBox[{"2", "Pi"}]}], ";", "\n", "    ", "\n", "\t", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"thetaVars", ",", " ", "thetaAdjVars"}], "}"}], " ", "=", " ", 
     RowBox[{"thetaVarsFunc", "[", 
      RowBox[{"numPoints", ",", " ", "thetaLean"}], "]"}]}], ";", "\n", "\t", 
    
    RowBox[{"pVars", " ", "=", " ", 
     RowBox[{"pVarsFunc", "[", 
      RowBox[{
      "numPoints", ",", " ", "hTail", ",", " ", "thetaLean", ",", " ", 
       "listOfDistances", ",", " ", "thetaVars"}], "]"}]}], ";", "\n", "\t", 
    RowBox[{"mVars", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Midpoint", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"pVars", "[", 
           RowBox[{"[", "n", "]"}], "]"}], ",", " ", 
          RowBox[{"pVars", "[", 
           RowBox[{"[", 
            RowBox[{"n", "+", "1"}], "]"}], "]"}]}], "}"}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], "]"}]}],
     ";", "\n", "\t", 
    RowBox[{"torqueVars", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"torqueAtPoint", "[", 
        RowBox[{
         RowBox[{"listOfMasses", "[", 
          RowBox[{"[", "n", "]"}], "]"}], ",", " ", 
         RowBox[{"mVars", "[", 
          RowBox[{"[", "n", "]"}], "]"}]}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], "]"}]}],
     ";", "\n", "\t\t", "\n", "\t", 
    RowBox[{"pH", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "hHead"}], "*", 
        RowBox[{"Sin", "[", "thetaLean", "]"}]}], ",", " ", 
       RowBox[{"hHead", "*", 
        RowBox[{"Cos", "[", "thetaLean", "]"}]}]}], "}"}]}], ";", "\n", "\t", 
    
    RowBox[{"mH", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"pH", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "-", 
        RowBox[{"dHead", "*", 
         RowBox[{"Cos", "[", "thetaLean", "]"}]}]}], ",", " ", 
       RowBox[{
        RowBox[{"pH", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "-", 
        RowBox[{"dHead", "*", 
         RowBox[{"Sin", "[", "thetaLean", "]"}]}]}]}], "}"}]}], ";", "\n", 
    "\t", "\n", "\t", 
    RowBox[{"constraints", " ", "=", " ", 
     RowBox[{"Join", "[", "\n", "\t    ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", " ", "<", " ", 
         RowBox[{"thetaAdjVars", "[", "1", "]"}], " ", "<", " ", "Pi"}], 
        "}"}], ",", "\n", "\t\t", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"lowerBound", " ", "<=", " ", 
          RowBox[{"thetaAdjVars", "[", "n", "]"}], " ", "<", " ", 
          "upperBound"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"n", ",", " ", "2", ",", " ", "numPoints"}], "}"}]}], 
        "]"}]}], "\n", "\t", "]"}]}], ";", "\n", "\t\t", "\n", "\t", 
    RowBox[{"objective", " ", "=", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"torqueAtPoint", "[", 
         RowBox[{"mHead", ",", " ", "mH"}], "]"}], " ", "+", " ", 
        RowBox[{"Total", "[", "torqueVars", "]"}]}], ")"}], "^", "2"}]}], ";",
     "\n", "\t\t", "\n", "\t", 
    RowBox[{"output", " ", "=", " ", 
     RowBox[{"NMinimize", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"objective", ",", " ", "constraints"}], "}"}], ",", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"thetaAdjVars", "[", "n", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", " ", "numPoints"}], "}"}]}], "]"}]}], "]"}]}], ";",
     "\t\t", "\n", "\t", 
    RowBox[{"error", " ", "=", " ", 
     RowBox[{"output", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", "\t", 
    RowBox[{"thetaAdjs", " ", "=", " ", 
     RowBox[{"Values", "[", 
      RowBox[{"output", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ";", "\n", "\t", 
    RowBox[{"thetas", " ", "=", " ", 
     RowBox[{"thetaVarsFuncEval", "[", 
      RowBox[{"numPoints", ",", " ", "thetaLean", ",", " ", "thetaAdjs"}], 
      "]"}]}], ";", "\t\t", "\n", "\t", 
    RowBox[{"pEvals", " ", "=", " ", 
     RowBox[{"pVarsFunc", "[", 
      RowBox[{
      "numPoints", ",", " ", "hTail", ",", " ", "thetaLean", ",", " ", 
       "listOfDistances", ",", " ", "thetas"}], "]"}]}], ";", "\n", "\t\t\t", 
    "\n", "\t", 
    RowBox[{"Graphics", "[", 
     RowBox[{
      RowBox[{"{", "\n", "\t\t", 
       RowBox[{
        RowBox[{"Join", "[", "\n", "\t\t\t", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Blue", ",", " ", 
            RowBox[{"Line", "[", 
             RowBox[{"{", 
              RowBox[{"p0", ",", "pH"}], "}"}], "]"}], ",", " ", "\n", 
            "\t\t\t", 
            RowBox[{"Line", "[", 
             RowBox[{"{", 
              RowBox[{"mH", ",", " ", "pH"}], "}"}], "]"}]}], "}"}], ",", " ", 
          RowBox[{"{", "Blue", "}"}], ",", "\n", "\t\t\t", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"Line", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"pEvals", "[", 
                RowBox[{"[", "n", "]"}], "]"}], ",", " ", 
               RowBox[{"pEvals", "[", 
                RowBox[{"[", 
                 RowBox[{"n", "+", "1"}], "]"}], "]"}]}], "}"}], "]"}], ",", 
            " ", 
            RowBox[{"{", 
             RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], 
           "]"}]}], "]"}], ",", "\n", "\t\t\t", "LightGray", ",", " ", 
        "Dashed", ",", " ", "\n", "\t\t\t", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Line", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"10", ",", "0"}], "}"}]}], "}"}], "]"}], ",", " ", 
          RowBox[{"Line", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", "10"}], "}"}]}], "}"}], "]"}]}], "}"}]}], 
       "}"}], ",", " ", "\n", "\t\t", 
      RowBox[{"ImageSize", " ", "->", " ", "Large"}], ",", " ", 
      RowBox[{"PlotRange", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "}"}]}]}], "]"}]}], ",",
    "\n", "\t\t", "\n", "\t    ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"thetaLean", ",", "  ", 
       RowBox[{"Pi", "/", "7"}], ",", " ", "\"\<Leaning Angle\>\""}], "}"}], ",",
      " ", 
     RowBox[{
      RowBox[{"-", "Pi"}], "/", "2"}], ",", "  ", 
     RowBox[{
      RowBox[{"Pi", "/", "2"}], " ", "-", " ", "0.1"}], ",", " ", 
     RowBox[{"ContinuousAction", " ", "->", " ", "False"}]}], "}"}], ",", 
   "\n", "\t    ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"mTailConst", ",", " ", "1", ",", " ", "\"\<Tail Mass\>\""}], 
      "}"}], ",", " ", "0.1", ",", " ", "10", ",", " ", 
     RowBox[{"ContinuousAction", " ", "->", " ", "False"}]}], "}"}], ",", 
   "\n", "\t    ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "numPoints", ",", " ", "6", ",", " ", "\"\<Number of Joints\>\""}], 
      "}"}], ",", " ", "1", ",", " ", "10", ",", " ", "1", ",", " ", 
     RowBox[{"ContinuousAction", " ", "->", " ", "False"}]}], "}"}], ",", 
   "\n", "\t    ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"dTailConst", ",", " ", "1", ",", " ", "\"\<Tail length\>\""}], 
      "}"}], ",", " ", "1", ",", "10", ",", " ", 
     RowBox[{"ContinuousAction", " ", "->", " ", "False"}]}], "}"}], ",", 
   "\n", "\t   ", "\n", "\t     ", 
   RowBox[{"SaveDefinitions", "->", "True"}]}], "\n", "]"}]}], "Input",
 CellChangeTimes->{
  3.992592708733498*^9, 3.992608218626589*^9, {3.9926083928991413`*^9, 
   3.9926083964279137`*^9}, {3.992608478165249*^9, 3.9926084951871777`*^9}, 
   3.9926085519573956`*^9, {3.992610615519204*^9, 3.9926106162833233`*^9}, {
   3.9926252843281403`*^9, 3.992625285440948*^9}, {3.9926254328771152`*^9, 
   3.992625460266253*^9}, {3.992625494745586*^9, 3.9926255466374474`*^9}},
 CellLabel->"In[72]:=",ExpressionUUID->"98cbaa40-a6b4-426b-a332-f9ac14754850"],

