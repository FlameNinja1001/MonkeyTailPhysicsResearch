Cell[TextData[{
 "As a result of recalculating ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "82656c62-f5a6-4b7f-b14d-f974f0f1c2c8"],
 ", the midpoint between ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "61e077ea-997e-4899-9cc7-8964c7f51d18"],
 " and  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "fad38409-6f39-4244-aca0-2a3cf5fe6183"],
