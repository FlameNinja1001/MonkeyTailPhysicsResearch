          RowBox[{
           RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "}"}]}]}], "]"}]}], ",",
    "\n", "\t\t", "\n", "\t    ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"thetaLean", ",", "  ", 
       RowBox[{
        RowBox[{"Pi", "/", "6"}], " ", "-", " ", "0.1"}], ",", 
