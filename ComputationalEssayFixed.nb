         Sqrt[2])}, $CellContext`p4 = {(2 - 2 Sqrt[3] + $CellContext`dTail + 
          Sqrt[3] $CellContext`dTail)/(4 
         Sqrt[2]), (2 (1 + Sqrt[3]) + (-1 + Sqrt[3]) $CellContext`dTail)/(4 
         Sqrt[2])}, $CellContext`p5 = {((-1)/2) ((-1 + Sqrt[3])/Sqrt[
           2]) + ((1 + Sqrt[3]) $CellContext`dTail)/(2 
          Sqrt[2]), (1 + Sqrt[3])/(2 
