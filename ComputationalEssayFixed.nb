           Which[$CellContext`n == 1, $CellContext`firstTheta, True, Sum[
              
              Part[$CellContext`thetaAdjEval, $CellContext`m], \
{$CellContext`m, 
               2, $CellContext`n}] + $CellContext`firstTheta], \
{$CellContext`n, 
            1, $CellContext`numPoints}]], $CellContext`pEvals = \
{{-0.4110438076762634, 0.9116155923255147}, {0.2571258919901456, 
        2.254578455716644}, {0.8078877092814307, 3.6498065448167742`}, {
        1.0911905823096855`, 5.122810102902747}, {0.983250755494866, 
