   3.9925980626124487`*^9}},ExpressionUUID->"83d8cb08-d438-4e34-94e1-\
27280094698b"],

Cell["\<\
Generating the list of the distances and a set number of points:\
\>", "CodeText",
 CellChangeTimes->{{3.9924421697336817`*^9, 
  3.992442201742935*^9}},ExpressionUUID->"ddc43787-9d99-44da-b872-\
451ff3d49af8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"dTailConst", " ", "=", " ", "1.5"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"numPoints", " ", "=", " ", "6"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"listOfDistances", " ", "=", " ", 
  RowBox[{"Table", "[", 
   RowBox[{"dTailConst", ",", " ", "numPoints"}], "]"}]}]}], "Input",
