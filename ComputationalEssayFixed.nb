Cell[TextData[{
 "Defining these constants in Wolfram Language as well as redefining ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "b49ff65b-3791-4f03-96b1-b2c1aa267672"],
 ". A critical thing to note is that because this model begins to get \
computationally expensive, I switched to radians instead of degrees for all \
angles:"
}], "CodeText",
 CellChangeTimes->{
  3.9924421531097116`*^9, {3.992591737082636*^9, 3.992591754913043*^9}, {
