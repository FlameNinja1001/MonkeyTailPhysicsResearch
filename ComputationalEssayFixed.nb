 RowBox[{
  RowBox[{
   RowBox[{"p6", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0"}], "}"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"origin", " ", "point"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"p2", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "hHead"}], "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", 
     RowBox[{"hHead", "*", 
      RowBox[{"Cos", "[", 
       RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"p3", " ", "=", " ", 
