Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"hTail", " ", "=", " ", "1.0"}], ";"}], " "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"mHead", " ", "=", " ", "1.0"}], ";", " ", 
   RowBox[{"hHead", " ", "=", " ", "5.0"}], ";", " ", 
   RowBox[{"dHead", " ", "=", " ", "1.0"}], ";"}], " "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"p0", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0"}], "}"}]}], ";"}], " "}], "\n", 
 RowBox[{
  RowBox[{"thetaLean", " ", "=", " ", 
   RowBox[{"N", "[", 
    RowBox[{
     RowBox[{"Pi", "/", "6"}], " ", "-", " ", "0.1"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"pH", " ", "=", " ", 
   RowBox[{"{", "\n", "\t", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "hHead"}], "*", 
      RowBox[{"Sin", "[", "thetaLean", "]"}]}], ",", "\n", "\t", 
     RowBox[{"hHead", "*", 
      RowBox[{"Cos", "[", "thetaLean", "]"}]}]}], "\n", "}"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"mH", " ", "=", " ", 
   RowBox[{"{", "\n", "\t", 
    RowBox[{
     RowBox[{
      RowBox[{"pH", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "-", 
      RowBox[{"dHead", "*", 
       RowBox[{"Cos", "[", "thetaLean", "]"}]}]}], ",", "\n", "\t", 
     RowBox[{
      RowBox[{"pH", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "-", 
      RowBox[{"dHead", "*", 
       RowBox[{"Sin", "[", "thetaLean", "]"}]}]}]}], "\n", "}"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9924292597898397`*^9, 3.992429286400412*^9}, {
