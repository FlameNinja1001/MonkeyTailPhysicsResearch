 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "0"], TraditionalForm]],ExpressionUUID->
  "314a1ef0-febd-b646-9214-c48a9843e546"],
 " - the origin"
}], "Item",
 CellChangeTimes->{{3.9926016274488163`*^9, 
  3.9926016280443*^9}},ExpressionUUID->"6ca805fc-508a-7141-a2df-4ef240c8cb8b"],

