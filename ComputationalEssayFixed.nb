8512c9c04333"],

Cell[BoxData[
 RowBox[{
  RowBox[{"p2", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "hHead"}], "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", 
     RowBox[{"hHead", "*", 
      RowBox[{"Cos", "[", 
       RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], 
  ";"}]], "Input",
