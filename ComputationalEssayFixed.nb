  3.9926253208898563`*^9, 3.992625391149666*^9, 3.99262560695126*^9, 
  3.9926256629841833`*^9},
 CellLabel->"Out[39]=",ExpressionUUID->"2ae36647-4657-4d85-94fc-fbdb156e867b"]
}, Open  ]],

