Cell[TextData[{
 "As the diagram shows, due to the corresponding angles theorem, this larger \
angle, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "2"], TraditionalForm]],ExpressionUUID->
  "f4927667-637f-434e-948f-059f7a2583c9"],
 ", is actually the sum of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj2"], TraditionalForm]],ExpressionUUID->
  "1a9b83f8-468a-459f-b8af-84624f0aa913"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "1"], TraditionalForm]],ExpressionUUID->
  "9dd3858c-63fb-4a3c-a17f-6ffbd998eaf6"],
 ". Thus, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "2"], TraditionalForm]],ExpressionUUID->
  "592cfe9f-9d72-4c1b-9a55-8fe6aabc04f3"],
 " can be defined as:"
}], "Text",
