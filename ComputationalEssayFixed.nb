      RowBox[{"dHead", "*", 
       RowBox[{"Cos", "[", 
        RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"p2", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "-", 
      RowBox[{"dHead", "*", 
       RowBox[{"Sin", "[", 
        RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}]}], "}"}]}], 
  ";"}]], "Code",
 CellChangeTimes->{{3.99209509573956*^9, 3.992095152566937*^9}},
 CellLabel->
  "In[250]:=",ExpressionUUID->"df14060c-837f-4fef-a312-535c2d9f1635"],

Cell[TextData[{
 "We can apply the same transformation process to derive ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "ede25a78-21b6-4179-8e75-dd8263890cec"],
 " from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "f33438ec-df32-4e66-92d9-3ed317770185"],
 ". If we form a right triangle from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "10b29ef0-461b-4197-a559-18be9f9dafc3"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "2f5e3943-14c9-408a-a999-d893de8f8f49"],
 ", the congruency with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "65bcd936-a02d-4828-ab3d-436274ec0ffa"],
 " stays the same as before:\n",
 Cell[BoxData[
  GraphicsBox[
   TagBox[RasterBox[CompressedData["
