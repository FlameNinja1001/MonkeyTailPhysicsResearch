      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"torqueAtPoint", "[", 
          RowBox[{"mHead", ",", "p1"}], "]"}], "==", 
         RowBox[{"-", 
          RowBox[{"torqueAtPoint", "[", 
           RowBox[{"mTail", ",", "p4"}], "]"}]}]}], "&&", " ", 
        RowBox[{"0", " ", "<=", " ", "thetaAdj", " ", "<=", " ", "180"}]}], ",",
