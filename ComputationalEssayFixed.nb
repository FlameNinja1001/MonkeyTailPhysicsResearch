Cell[TextData[{
 "Using trigonometry, we can compute the coordinates when the monkey is \
leaning. Beginning with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "e3e501ff-ade4-4889-b925-8725dfa03141"],
 ", we can compute its position by drawing a right triangle from the origin \
",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "6"], TraditionalForm]],ExpressionUUID->
  "e097728a-2610-4199-8aa9-38aef2ab3dd7"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "191139fd-c4ae-48fd-b4ed-657f9ec86e51"],
 ". This is visualized below:"
}], "Text",
 CellChangeTimes->{{3.9293546184036617`*^9, 3.9293546199188967`*^9}, {
   3.991843023893482*^9, 3.991843098671399*^9}, {3.991843141651308*^9, 
