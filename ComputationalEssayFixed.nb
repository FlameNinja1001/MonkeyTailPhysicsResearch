Cell[TextData[{
 "The final point to define is ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "4"], TraditionalForm]],ExpressionUUID->
  "6ed7b4c0-6684-49e2-9b17-000e8223ac17"],
 ". Because it is the center of mass for a normal object, it is simply the \
midpoint of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "17b4d04a-a035-4abb-bf4b-7dee88908598"],
