Cell[CellGroupData[{

Cell["Model V2 - Self-Balancing Tail with Variable Rotation", "Subsection",
 CellChangeTimes->{{3.992549151613921*^9, 
  3.9925491578203*^9}},ExpressionUUID->"63246323-9177-4097-af8e-c71cb13b6ca6"],

Cell[TextData[{
 "The model V1 works, however it is inaccurate to any \
animal\[CloseCurlyQuote]s behavior in nature. An animal cannot grow or shrink \
its tail in real-time. The V1 also assumes that the monkey\[CloseCurlyQuote]s \
tail is always perpendicular to its body. In nature, this is also not the \
case. Instead, to counterbalance its mass, a monkey will change the angle of \
its tail, represented in our model with a new variable, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "b1c8929b-5a93-438d-b0d8-a23a41c19a4a"],
 "."
}], "Text",
 CellChangeTimes->{{3.9921006037133503`*^9, 3.992100622324725*^9}, {
   3.992112560594152*^9, 3.992112565902768*^9}, {3.992112666101972*^9, 
   3.992112771642489*^9}, {3.9921128088760357`*^9, 3.992112976802414*^9}, {
   3.992113080218974*^9, 3.9921131016507053`*^9}, {3.9921131343634853`*^9, 
   3.992113141870468*^9}, 3.992114640303331*^9, {3.9924417871062593`*^9, 
   3.992441787471518*^9}, {3.992597555211034*^9, 3.9925975789356203`*^9}, 
   3.992601576811844*^9, {3.9926024901519623`*^9, 3.992602491499401*^9}, {
   3.992616633472019*^9, 3.992616633600563*^9}, {3.992616671961887*^9, 
   3.9926167200094213`*^9}},ExpressionUUID->"3b8a5f72-31a7-4247-a8bf-\
c44c768048fa"],

