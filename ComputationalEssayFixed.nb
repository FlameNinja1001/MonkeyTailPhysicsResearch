Cell[TextData[{
 "Next comes the coordinates for the endpoints of the head and tail. These \
are slightly more complicated, needing more trigonometry as well as being \
transformations from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "936ad301-7727-4049-9ddd-e743a6872439"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "5d403260-13b9-4a30-a28c-15af5ce1ea00"],
 ". Let\[CloseCurlyQuote]s begin with ",
