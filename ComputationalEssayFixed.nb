Cell[TextData[{
 "Notice that the hypotenuse is ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "head"], TraditionalForm]],ExpressionUUID->
  "7f947b20-1ca9-463e-aca4-eef98ad0eaea"],
 " and one of the angles is ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "fb913575-0def-4fb1-a2b7-2e7071676df5"],
 ". This means that since ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "bd4b0860-57e6-4c5e-b9fd-ef3f6eafa671"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "head"], TraditionalForm]],ExpressionUUID->
  "8a268452-8f15-410b-a3f5-2332540f0295"],
 " are known, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "91760ebf-5e75-4c58-b494-750f22e24af8"],
 " can be defined as the following:"
}], "Text",
