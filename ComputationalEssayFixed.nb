  "af2059c6-0412-4359-984d-c6cfe5a42480"],
 "\nNotice that the hypotenuse is ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "head"], TraditionalForm]],ExpressionUUID->
  "cc38c112-e17b-4725-8219-194f42a8165a"],
 ". This means that since we know ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "e28ebfa6-1ef0-40a1-952d-949c766791f9"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "head"], TraditionalForm]],ExpressionUUID->
  "474b1627-992e-497c-8cf2-abfcd4af6c3b"],
 ", we can define ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "38bcc75c-6449-4869-b07e-e3724cb9be0b"],
 " as the following:\n\n(-",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "head"], TraditionalForm]],ExpressionUUID->
  "cfc4d0ba-6582-47fb-a969-ec33a6b8e221"],
 " * sin(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "7599e227-f7f8-41df-a17d-66691af1e8f5"],
 "), ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "head"], TraditionalForm]],ExpressionUUID->
  "0e4207de-6391-4f04-88e6-7f62338d0b79"],
 " * cos(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "4e6ac204-2ce7-4fd6-bed3-8b75a16971d8"],
 "))"
}], "Text",
