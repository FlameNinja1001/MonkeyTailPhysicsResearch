Cell[CellGroupData[{

Cell["Model V2 - Self-Balancing Tail with Variable Rotation", "Section",
 CellChangeTimes->{
  3.992100591446735*^9},ExpressionUUID->"452e9477-e23c-4bb1-bd61-\
b02cdac9c89a"],

Cell[TextData[{
 "Our model now works, however it is inaccurate to any animal\
\[CloseCurlyQuote]s behavior in nature. An animal cannot grow or shrink its \
tail in real-time.\nWe also assume that the monkey\[CloseCurlyQuote]s tail is \
always perpendicular to its body. In nature, this is also not the case.\n\n\
Instead, to counterbalance its mass, a monkey will change the angle of its \
tail. To achieve this, we need to adjust our model, give ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "4bee9a1e-47e4-4818-9f04-0b147cdb1d90"],
 " a value, and define a new constant for the angle of the tail, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "f097059a-02dc-4534-8cec-1e0e60ba383d"],
 ".\n\nFirst, let\[CloseCurlyQuote]s redefine our constants, including ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "68afe768-ca52-4a2e-b83f-90d1f4fbd5b9"],
 " now, named differently due to memory allocation:"
}], "Text",
 CellChangeTimes->{{3.9921006037133503`*^9, 3.992100622324725*^9}, {
   3.992112560594152*^9, 3.992112565902768*^9}, {3.992112666101972*^9, 
   3.992112771642489*^9}, {3.9921128088760357`*^9, 3.992112976802414*^9}, {
   3.992113080218974*^9, 3.9921131016507053`*^9}, {3.9921131343634853`*^9, 
   3.992113141870468*^9}, 
   3.992114640303331*^9},ExpressionUUID->"1cd200dc-b1ec-4bb8-8e77-\
eaaa7a802d07"],

