Cell[TextData[{
 "Defining the origin (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "6"], TraditionalForm]],ExpressionUUID->
  "13d248cc-a50b-4525-b6d1-e71b1e1282d1"],
