AAA4jv4MAAAAOI7+DAAAADiO/gwAAAA4jv4MAAAAOI7+DAAAADjuxIkTw69S
lmXHAQAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAMq+/we15Wu3
     "], {{0, 960.}, {960., 0}}, {0, 255},
     ColorFunction->RGBColor],
    BoxForm`ImageTag["Byte", ColorSpace -> "RGB", Interleaving -> True],
    Selectable->False],
   DefaultBaseStyle->"ImageGraphics",
   ImageSizeRaw->{960., 960.},
   PlotRange->{{0, 960.}, {0, 960.}}]], "Input",ExpressionUUID->
  "5fc31d13-7ba7-49bc-8b18-83c79f46a838"],
 "\nIn the last example, recall we defined ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "54deb7c0-5502-456e-859d-f652aacfdc91"],
 " as the following:\n \n ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "e93ab9b6-bcf3-4244-a730-a93bfc549499"],
 " + (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "fb848fc4-6436-4768-9354-870b7d1458cb"],
 "*cos(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "dd227d79-ae60-48bb-a52e-5bff9f84b46c"],
 "),",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "edd03557-2b3f-4909-9d76-de1eb73a36ea"],
 "*sin(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "c9b29d5a-9787-4494-b49d-a44769ab60b2"],
 "))\n \nHowever, as this diagram shows, because the angle to calculate  isn\
\[CloseCurlyQuote]t a perfect 90 anymore, it\[CloseCurlyQuote]s not ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "ff040bfe-c08a-4aff-b081-d9aa056490f5"],
 " exactly. The angle can still be defined, however, using the new ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "bc52364b-e682-4219-8098-483012bdc346"],
 ". We can see in the image that the angle for the triangle is part of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "144f9ec1-a3d3-4e07-8ad0-f547f2a2f0fc"],
 ". We can also see ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "054fd693-59f4-4841-afac-b560b9bf9f3e"],
 " and a 90 degree angle are part of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "cc4b7624-bc6b-46b9-8489-8b50e1310022"],
 ". Knowing that, we can subtract these specific, exact values from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "65d1d7cf-1d25-4e5c-8e55-d675a861e408"],
 " to get it and then solve for the remaining parts of the model:\n\n ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "192b8875-6e09-4817-b141-90ce3ec65705"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "08109ded-e24f-4d3e-a3b4-bf3fd50b036f"],
 " + (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "e5947fff-48b3-4439-a4d5-bdce235edf16"],
 "*cos(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Theta]", "adj"], " ", "-", " ", 
    RowBox[{"(", 
     RowBox[{"90", "+", 
      SubscriptBox["\[Theta]", "lean"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"af709ff3-0b8c-4288-a1a9-4f16c86ce8d9"],
 "),",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "23332d38-32cb-4721-a8b0-4ce517f28fef"],
 "*sin(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Theta]", "adj"], " ", "-", " ", 
    RowBox[{"(", 
     RowBox[{"90", "+", 
      SubscriptBox["\[Theta]", "lean"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"b3903b08-3b82-4132-a4e4-af4f18e9a5cc"],
 "))"
}], "Text",
 CellChangeTimes->{{3.9921006037133503`*^9, 3.992100622324725*^9}, {
  3.992112560594152*^9, 3.992112565902768*^9}, {3.992112666101972*^9, 
  3.992112771642489*^9}, {3.9921128088760357`*^9, 3.992112976802414*^9}, {
  3.992113080218974*^9, 3.992113106086329*^9}, {3.992426992229374*^9, 
  3.9924269945582542`*^9}, {3.992441851560953*^9, 3.99244185371099*^9}, {
  3.99244196607198*^9, 
  3.992441971152405*^9}},ExpressionUUID->"8ed6460a-9cc6-4565-af29-\
5b497b98bf45"],

Cell[TextData[{
 "Defining ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "70bc589d-3772-4360-ac06-0927254c65e3"],
 " in Wolfram Language using the currently unknown variable ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "d0ed616e-9ceb-4115-bf27-d8b47a0845de"],
 ":"
}], "CodeText",
 CellChangeTimes->{{3.992441910451952*^9, 
  3.992441943097193*^9}},ExpressionUUID->"4fbf6c63-437c-4dc3-9e9c-\
0e3e39bb9df7"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "thetaAdj", "]"}], "\n", 
 RowBox[{
  RowBox[{"p5", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"p3", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "+", 
      RowBox[{"dTailConst", "*", 
       RowBox[{"Cos", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"thetaAdj", "-", 
           RowBox[{"(", 
            RowBox[{"90", "+", "thetaLean"}], ")"}]}], ")"}], " ", "Degree"}],
         "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"p3", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "+", 
      RowBox[{"dTailConst", "*", 
       RowBox[{"Sin", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"thetaAdj", "-", 
           RowBox[{"(", 
            RowBox[{"90", "+", "thetaLean"}], ")"}]}], ")"}], " ", "Degree"}],
         "]"}]}]}]}], "}"}]}], ";"}]}], "Input",
 CellChangeTimes->{
  3.992112681451087*^9, {3.992112901407383*^9, 3.992112950513897*^9}, {
   3.992113151235607*^9, 3.992113153100049*^9}, {3.992114772370968*^9, 
   3.9921147757144947`*^9}, {3.992161791789257*^9, 3.992161792138014*^9}},
 CellLabel->
  "In[321]:=",ExpressionUUID->"76bd79ec-b681-46bc-9086-5dd958e60358"],

Cell[TextData[{
 "As a result of recalculating ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "ccfdf4b7-e47f-4b40-8326-8deed4b190f6"],
 " we also need to recalculate the midpoint between ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "34b0e68f-7e09-453d-bbb1-9e5f90bbd0f8"],
 " and  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "5885dda1-2907-4720-89e2-2f6f40a14a3d"],
 ",  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "4"], TraditionalForm]],ExpressionUUID->
  "f6268502-a05d-42e5-8ce8-b49c2559ef97"],
 ":"
}], "CodeText",
 CellChangeTimes->{{3.992112980302924*^9, 
  3.992113008635346*^9}},ExpressionUUID->"dd9ceb0c-18b5-4f8e-ae32-\
ea9c8003b53e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"p4", " ", "=", " ", 
   RowBox[{"Midpoint", "[", 
    RowBox[{"{", 
     RowBox[{"p3", ",", "p5"}], "}"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9921130178423853`*^9, 3.992113023865211*^9}},
 CellLabel->
  "In[323]:=",ExpressionUUID->"bde448a2-ca51-4632-b6a5-5656d6471b5e"],

Cell[TextData[{
 "Now, given these values, we can once again use NSolve, but instead of for \
",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "77f42a27-68f1-4a24-9ea7-8fe5f68a4394"],
 ", for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "69789875-b519-4f02-8124-fa23c265182c"],
 "."
}], "CodeText",
 CellChangeTimes->{{3.992113031538157*^9, 3.992113037122189*^9}, {
  3.992113169446151*^9, 
  3.992113205577938*^9}},ExpressionUUID->"e6f8ef09-65fb-4763-853e-\
b37b3ba78b56"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NSolve", "[", "\n", "\t", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"torqueAtPoint", "[", 
       RowBox[{"mHead", ",", "p1"}], "]"}], "==", 
      RowBox[{"-", 
       RowBox[{"torqueAtPoint", "[", 
        RowBox[{"mTail", ",", "p4"}], "]"}]}]}], "&&", " ", 
     RowBox[{"0", " ", "<=", " ", "thetaAdj", " ", "<=", " ", "180"}]}], 
    "}"}], ",", "\n", "\t", "thetaAdj"}], "]"}]], "Input",
 CellChangeTimes->{{3.9921132253167562`*^9, 3.992113233084573*^9}, {
   3.992114935899324*^9, 3.992114936929109*^9}, 3.992115260419682*^9, 
   3.992123765791855*^9, {3.9921247463888397`*^9, 3.9921247465552263`*^9}, {
   3.992269602373124*^9, 3.9922696307091*^9}},
 CellLabel->
  "In[324]:=",ExpressionUUID->"8b6e0a7c-bb5f-42c3-8e6c-97c5d30588eb"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"thetaAdj", "\[Rule]", "64.1622980382931`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"thetaAdj", "\[Rule]", "135.8377019617069`"}], "}"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{{3.992113234170627*^9, 3.99211325095544*^9}, 
   3.9921141840898333`*^9, {3.992114265230071*^9, 3.99211427210213*^9}, 
   3.992114459061831*^9, 3.992114628779388*^9, 3.9921147094652443`*^9, 
   3.992114782025187*^9, 3.992114975107647*^9, 3.992115216498659*^9, 
   3.9921152655568*^9, {3.9921153018179827`*^9, 3.992115359172518*^9}, 
   3.992115433316905*^9, 3.992115552750198*^9, {3.992115585235433*^9, 
   3.99211559878507*^9}, {3.9921156822446117`*^9, 3.992115683104652*^9}, 
   3.9921157199519787`*^9, {3.992123344722419*^9, 3.9921233457598963`*^9}, 
   3.992123767642295*^9, {3.992124496991334*^9, 3.992124498420259*^9}, {
   3.9921247309742527`*^9, 3.99212477296778*^9}, 3.992125990027232*^9, {
   3.99215899947921*^9, 3.992159022917454*^9}, 3.992161801758013*^9, {
   3.992162011991941*^9, 3.9921620426172953`*^9}, {3.9922696075715446`*^9, 
   3.9922696078886766`*^9}, 3.992269646782797*^9, {3.992419907813663*^9, 
   3.992419937754984*^9}, 3.992425036867693*^9, {3.992439679674049*^9, 
   3.992439681361885*^9}, 3.992442765418939*^9, 3.99250966807773*^9, 
   3.992513099008574*^9, 3.992545392779889*^9, 3.992545531763134*^9, 
   3.9925456362014723`*^9, 3.9925457572272778`*^9, {3.992547167440352*^9, 
   3.992547184002948*^9}},
 CellLabel->
  "Out[324]=",ExpressionUUID->"f0ede2eb-19dc-4a02-9d35-92ccb1d3807f"]
}, Open  ]],

Cell[TextData[StyleBox["We notice that sometimes, the values give two \
outputs. To get around this, we always take the last one.", "Text"]], \
"CodeText",
 CellChangeTimes->{{3.9921245223704576`*^9, 3.9921245266929607`*^9}, {
  3.992124593087101*^9, 3.9921246012795467`*^9}, {3.992442002876616*^9, 
  3.992442003040289*^9}},ExpressionUUID->"3ca5bd47-140f-4a4e-88fd-\
39fb5cdbe051"],

Cell["\<\
We take the last one by first extracting the pure, raw numerical values from \
the NSolve using Values and Flatten, and then applying the Last function to \
choose a number:\
\>", "CodeText",
 CellChangeTimes->{{3.9924419994909077`*^9, 
  3.9924420344481153`*^9}},ExpressionUUID->"599e478d-ef0a-461b-8e1a-\
29e7ad710074"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"vals", " ", "=", " ", 
  RowBox[{"Last", "@", 
   RowBox[{"Flatten", "@", 
    RowBox[{"Values", "@", 
     RowBox[{"NSolve", "[", "\n", "\t", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"torqueAtPoint", "[", 
          RowBox[{"mHead", ",", "p1"}], "]"}], "==", 
         RowBox[{"-", 
          RowBox[{"torqueAtPoint", "[", 
           RowBox[{"mTail", ",", "p4"}], "]"}]}]}], "&&", " ", 
        RowBox[{"0", " ", "<=", " ", "thetaAdj", " ", "<=", " ", "180"}]}], ",",
        "\n", "thetaAdj"}], "]"}]}]}]}]}]], "Input",
 CellChangeTimes->{{3.9921246044476137`*^9, 3.9921246427993727`*^9}, {
  3.992124755021772*^9, 3.9921247551808147`*^9}},
 CellLabel->
  "In[325]:=",ExpressionUUID->"1766ba52-d865-46cd-847a-bfaf8693b119"],

Cell[BoxData["135.8377019617069`"], "Output",
 CellChangeTimes->{{3.992124618576433*^9, 3.992124644012019*^9}, {
   3.9921247325556593`*^9, 3.992124774457056*^9}, 3.992125990110763*^9, {
   3.9921589995366583`*^9, 3.992159022996674*^9}, 3.992161804073997*^9, {
   3.992162012066957*^9, 3.992162042704859*^9}, 3.99226960763186*^9, {
   3.992419907885726*^9, 3.9924199378452387`*^9}, 3.992425036959584*^9, {
   3.992439679735715*^9, 3.992439681422538*^9}, 3.992442765481468*^9, 
   3.9925096681739473`*^9, 3.992513099076692*^9, 3.992545392851726*^9, 
   3.992545531869166*^9, 3.992545636308659*^9, 3.992545757315811*^9, {
   3.992547167545595*^9, 3.992547184103221*^9}},
 CellLabel->
  "Out[325]=",ExpressionUUID->"773a77d5-b102-4daa-b2f8-45642cb3c2c3"]
}, Open  ]],

Cell["\<\
With this, we can modify the code from V1 to, once again, visualize our \
model. We must note, however, that, because the tail is now rotating, and has \
a limit between 0 and 180 degrees, there are going to be some physically \
impossible combinations of givens. This will result in a red graph and an \
error message. We will get around this later, however.\
\>", "Text",
 CellChangeTimes->{{3.992124649235635*^9, 3.992124680091261*^9}, {
  3.992124878277014*^9, 
  3.9921249492658587`*^9}},ExpressionUUID->"2d719bea-2d8f-43b2-b211-\
b458784f017d"],

Cell["\<\
Defining a function for all the prior computations listed above:\
\>", "CodeText",
 CellChangeTimes->{{3.9924420572247667`*^9, 3.9924420656637697`*^9}, 
   3.992511912021517*^9},ExpressionUUID->"1aa3467f-0f77-49bd-a924-\
811edf404209"],

Cell[BoxData[
 RowBox[{
  RowBox[{"drawMonkey2", "[", "thetaLean_", "]"}], ":=", "\n", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "p1", ",", "p2", ",", "p3", ",", "p4", ",", "p5", ",", "p6", ",", 
      "p5Visual", ",", "p4Visual", ",", "thetaAdjValue", ",", "dTailConst", ",",
       " ", "output"}], "}"}], ",", "\n", "\t", 
    RowBox[{
     RowBox[{"dTailConst", " ", "=", " ", "5"}], ";", "\n", "\t", 
     RowBox[{"p6", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ";", "\n", "\t", 
     RowBox[{"p2", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "hHead"}], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", " ", 
        RowBox[{"hHead", "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], ";", "\n",
      "    ", 
     RowBox[{"p3", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "hTail"}], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", " ", 
        RowBox[{"hTail", "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], ";", "\n",
      "    ", 
     RowBox[{"p1", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"p2", "[", 
          RowBox[{"[", "1", "]"}], "]"}], " ", "-", " ", 
         RowBox[{"dHead", "*", 
          RowBox[{"Cos", "[", 
           RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], ",", " ", 
        RowBox[{
         RowBox[{"p2", "[", 
          RowBox[{"[", "2", "]"}], "]"}], " ", "-", " ", 
         RowBox[{"dHead", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}]}], "}"}]}], ";", 
     "\n", "    \t\t\t", "\n", "    ", 
     RowBox[{"p5", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"p3", "[", 
          RowBox[{"[", "1", "]"}], "]"}], " ", "+", " ", 
         RowBox[{"dTailConst", "*", 
          RowBox[{"Cos", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"90", " ", "+", " ", "thetaLean", "-", "thetaAdj"}], 
             ")"}], " ", "Degree"}], "]"}]}]}], ",", " ", 
        RowBox[{
         RowBox[{"p3", "[", 
          RowBox[{"[", "2", "]"}], "]"}], " ", "+", " ", 
         RowBox[{"dTailConst", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"90", " ", "+", " ", "thetaLean", "-", "thetaAdj"}], 
             ")"}], " ", "Degree"}], "]"}]}]}]}], "}"}]}], ";", "\n", "    ", 
     
     RowBox[{"p4", " ", "=", " ", 
      RowBox[{"Midpoint", "[", 
       RowBox[{"{", 
        RowBox[{"p3", ",", " ", "p5"}], "}"}], "]"}]}], ";", "\n", "   ", 
     "\n", "   ", 
     RowBox[{"objective", " ", "=", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"torqueAtPoint", "[", 
          RowBox[{"mTail", ",", " ", "p4"}], "]"}], " ", "+", " ", 
         RowBox[{"torqueAtPoint", "[", 
          RowBox[{"mHead", ",", "p1"}], "]"}]}], ")"}], "^", "2"}]}], ";", 
     "\n", "   ", 
     RowBox[{"constraints", " ", "=", " ", 
      RowBox[{"0", " ", "<=", " ", "thetaAdj", " ", "<=", " ", "360"}]}], ";",
      "\n", "   ", 
     RowBox[{"output", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"NMinimize", "[", "\n", "   ", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"objective", ",", " ", "constraints"}], "}"}], ",", " ", 
          "thetaAdj"}], "\n", "   ", "]"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", "   ", 
     RowBox[{"thetaAdjValue", " ", "=", " ", 
      RowBox[{"Values", "@", "output"}]}], ";", "\n", "   ", 
     RowBox[{"p5Visual", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"p3", "[", 
          RowBox[{"[", "1", "]"}], "]"}], " ", "+", " ", 
         RowBox[{"dTailConst", "*", 
          RowBox[{"Cos", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"90", " ", "+", " ", "thetaLean", "-", "thetaAdjValue"}],
              ")"}], " ", "Degree"}], "]"}]}]}], ",", " ", 
        RowBox[{
         RowBox[{"p3", "[", 
          RowBox[{"[", "2", "]"}], "]"}], " ", "+", " ", 
         RowBox[{"dTailConst", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"90", " ", "+", " ", "thetaLean", "-", "thetaAdjValue"}],
              ")"}], " ", "Degree"}], "]"}]}]}]}], "}"}]}], ";", "\n", "\t", 
     RowBox[{"Graphics", "[", 
      RowBox[{
       RowBox[{"{", "\n", "\t\t\t", 
        RowBox[{"Blue", ",", 
         RowBox[{"{", "\n", "\t\t\t\t", 
          RowBox[{
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{"p1", ",", "p2"}], "}"}], "]"}], ",", "\n", "\t\t\t\t", 
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{"p6", ",", "p3"}], "}"}], "]"}], ",", "\n", "\t\t\t\t", 
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{"p2", ",", "p3"}], "}"}], "]"}], ",", "\n", "\t\t\t\t", 
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{"p5Visual", ",", "p3"}], "}"}], "]"}]}], "\n", "\t\t\t", 
          "}"}], ",", "\n", "\t\t\t", "LightGray", ",", "Dashed", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "10"}], ",", "0"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"10", ",", "0"}], "}"}]}], "}"}], "]"}], ",", 
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"0", ",", 
                RowBox[{"-", "10"}]}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"0", ",", "10"}], "}"}]}], "}"}], "]"}]}], "}"}]}], 
        "\n", "\t\t", "}"}], ",", " ", 
       RowBox[{"ImageSize", "->", "Medium"}], ",", 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "\n", "\t", "}"}]}]}], 
      "]"}]}]}], "\n", "]"}]}]], "Code",
 CellChangeTimes->{{3.9925113491574793`*^9, 3.992511401608076*^9}, {
   3.992513139800234*^9, 3.9925131572909603`*^9}, {3.9925308068848*^9, 
   3.992530819599038*^9}, {3.992545100289669*^9, 3.99254515190772*^9}, 
   3.992545446301941*^9, {3.992545548443181*^9, 3.992545601039228*^9}, {
   3.992545647218865*^9, 3.9925456618464603`*^9}, {3.992545705361157*^9, 
   3.992545735943681*^9}, {3.992545798446918*^9, 3.992545822305088*^9}, 
   3.9925471560627403`*^9},
 CellLabel->
  "In[326]:=",ExpressionUUID->"e22f2006-c656-4f0d-9eb8-1285a9451b8a"],

