AABAOP0ZAADC6c8AABBOfwYAgHD6MwAAhNOfAbL6P/gfSxs=
     "], {{0, 960.}, {960., 0}}, {0, 255},
     ColorFunction->RGBColor],
    BoxForm`ImageTag["Byte", ColorSpace -> "RGB", Interleaving -> True],
    Selectable->False],
   DefaultBaseStyle->"ImageGraphics",
   ImageSizeRaw->{960., 960.},
   PlotRange->{{0, 960.}, {0, 960.}}]], "Input",ExpressionUUID->
  "54bdee71-9792-4388-bc64-1bddefdba86f"],
 "\nGiven the above equation, the torque on this point would be:\n\n\[Tau] = \
m*g*r*sin(\[Theta])\n\nHowever, there can be a right triangle drawn from the \
point mass to the origin with the x and y coordinates as legs and r as the \
hypotenuse as the above diagram shows. This means that the sine of \[Theta] \
would be ",
 Cell[BoxData[
  FormBox[
   FractionBox["x", "r"], TraditionalForm]],ExpressionUUID->
  "ace9ef6d-21d9-4814-91b2-fbb00025afb4"],
 ". Plugging this into the above torque equation results in the following \
simplification:\n\n\[Tau] = m*g*r*sin(\[Theta])\n\n\[Tau] = m*g*r*",
 Cell[BoxData[
  FormBox[
   FractionBox["x", "r"], TraditionalForm]],ExpressionUUID->
  "2b5cd054-a0a5-49a8-9739-76214b7f240c"],
 "\n\n\[Tau] = m*g*x\n\nLet\[CloseCurlyQuote]s define a wolfram function with \
a coordinate and mass input to calculate the torque of any given point."
}], "Text",
 CellChangeTimes->{{3.992097266395308*^9, 3.9920972777812233`*^9}, {
  3.9920974531310387`*^9, 3.992097472807303*^9}, {3.992097745948107*^9, 
  3.9920981476796417`*^9}, {3.992421033765835*^9, 
  3.992421033879548*^9}},ExpressionUUID->"bbcf056d-f9ba-4fcf-94c5-\
8028af0e7855"],

Cell[BoxData[
 RowBox[{
  RowBox[{"torqueAtPoint", "[", 
   RowBox[{"mass_", ",", "coord_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\n", "\t", 
    RowBox[{"mass", " ", "*", " ", 
     RowBox[{"coord", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}]}], "\n", "]"}]}]], "Code",
 CellChangeTimes->{{3.992098151403298*^9, 3.992098189069479*^9}, {
  3.992114260359228*^9, 3.9921142611536503`*^9}},
 CellLabel->
  "In[253]:=",ExpressionUUID->"39b454a5-62e8-428c-9744-256e15f1ef76"],

Cell[TextData[{
 "We also know that in order for the monkey to stay balanced when rotated to \
an angle of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "2e915e63-af15-4313-bc75-c1336e742a7f"],
 " degrees, the sum of the torques has to equal zero. Recall that in the \
system, we have two point masses, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "h"], TraditionalForm]],ExpressionUUID->
  "0b5fb3a3-1716-4415-867f-2be9906bf0dd"],
 " for the head and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "t"], TraditionalForm]],ExpressionUUID->
  "b06f1340-6c60-46f0-b9bd-0417c8f99d8f"],
 " for the tail. Their positions can be represented by the coordinates ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "7e2add37-9205-461b-b635-23f526fcb65d"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "4"], TraditionalForm]],ExpressionUUID->
  "68cb287b-4c5f-4e70-8c60-b707da0c0477"],
 ". Let\[CloseCurlyQuote]s say that the torque of the head is ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "dadad47a-97f1-4a67-9454-44c02b311ad0"],
 " and the torque of the tail is ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "26da346c-657c-42d2-a07a-3127612359d0"],
 ". With this, we can establish that: ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],ExpressionUUID->
  "388c042e-c0fe-4f1c-937b-e1286009ea9d"],
 " + ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "d5b8c113-4f8d-4abe-bcb0-83eb89c6e793"],
 " = 0 , or that the torques are equal and opposite:\n\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],ExpressionUUID->
  "fdd52f3d-abd0-4098-ae60-8cc087937db2"],
 " = -",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "76e2b1c0-a189-48ce-bb3a-b29444f42e17"],
 "\n\nWith that established, we can create our model with code. It is \
important to recall that in our first set of variables, we did NOT define ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f6441f6f-ab52-40d8-84d5-f8c332e9c4f1"],
 ". Let\[CloseCurlyQuote]s re-examine why below:"
}], "Text",
 CellChangeTimes->{{3.992097266395308*^9, 3.9920972777812233`*^9}, {
  3.9920974531310387`*^9, 3.992097472807303*^9}, {3.992097745948107*^9, 
  3.992098145521916*^9}, {3.992098198772934*^9, 3.9920982084886703`*^9}, {
  3.9920982514498034`*^9, 3.992098335787692*^9}, {3.99209837208337*^9, 
  3.992098422464962*^9}},ExpressionUUID->"90009009-b891-4ed9-82f6-\
3353a6dddce9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "g", ",", "mHead", ",", "dHead", ",", "hHead", ",", "mTail", ",", "hTail", ",",
    "dTail"}], "}"}]], "Code",
 CellChangeTimes->{{3.992098423964962*^9, 3.992098441919664*^9}},
 CellLabel->
  "In[254]:=",ExpressionUUID->"0001b463-beff-4ac8-ba1b-af7e043c6d7d"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "9.81`", ",", "1", ",", "1", ",", "5", ",", "1", ",", "1", ",", "dTail"}], 
  "}"}]], "Output",
 CellChangeTimes->{
  3.992098442293077*^9, 3.992098882142069*^9, 3.992114264860133*^9, {
   3.992115681232635*^9, 3.992115682460018*^9}, {3.992123343806863*^9, 
   3.9921233449405203`*^9}, {3.992124496197686*^9, 3.992124497232633*^9}, 
   3.992125989570477*^9, {3.992158998936428*^9, 3.992159022414731*^9}, {
   3.9921620064181623`*^9, 3.9921620423128242`*^9}, 3.992269607084392*^9, {
   3.992419903273837*^9, 3.9924199374808073`*^9}, 3.992425036556326*^9, {
   3.9924396793759327`*^9, 3.9924396810510893`*^9}},
 CellLabel->
  "Out[254]=",ExpressionUUID->"d470d0e2-97b4-4739-8e5d-49dce16ec44f"]
}, Open  ]],

Cell[TextData[{
 "We did this because for the torques to stay in equilibrium in our model, \
when ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "c191ab82-e9b3-4524-b9ac-fb4df71954d2"],
 ", one or more of the given variables needs to change. If ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bf3b43ec-b0c8-4fad-9435-0105c6a5ee01"],
 " was a fixed length, but ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "dadbb4e4-6ed9-44a2-ace6-3e14964be4fa"],
 " changed, the system would not be in equilibrium. With this established, we \
can now create a model that adjusts ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "352a6ee8-8ff9-4a0f-acd1-9da12d6c2205"],
 " when ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "8b347146-e4c8-4072-8672-2ac959464b34"],
 " changes using Wolfram\[CloseCurlyQuote]s NSolve function:"
}], "Text",
 CellChangeTimes->{{3.99209846209616*^9, 
  3.992098568364648*^9}},ExpressionUUID->"e34e2c4e-6e61-417f-869a-\
922baed75b45"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NSolve", "[", "\n", "\t", 
  RowBox[{
   RowBox[{
    RowBox[{"torqueAtPoint", "[", 
     RowBox[{"mHead", ",", "p1"}], "]"}], "==", 
    RowBox[{"-", 
     RowBox[{"torqueAtPoint", "[", 
      RowBox[{"mTail", ",", "p4"}], "]"}]}]}], ",", "\n", "\t", "dTail"}], 
  "]"}]], "Code",
 CellChangeTimes->{{3.992098574045953*^9, 3.9920986100407753`*^9}, 
   3.992098849528429*^9},
 CellLabel->
  "In[255]:=",ExpressionUUID->"e16f910c-b147-4132-927e-ae02a3495c23"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{"dTail", "\[Rule]", "5.215390309173472`"}], "}"}], "}"}]], "Output",\

 CellChangeTimes->{{3.9920986204777527`*^9, 3.992098624000496*^9}, 
   3.992098849786508*^9, 3.9920988822430677`*^9, {3.9920990136321363`*^9, 
   3.9920990165411777`*^9}, 3.9921142649384193`*^9, {3.992115681416601*^9, 
   3.992115682532655*^9}, {3.992123343882928*^9, 3.992123345019395*^9}, {
   3.9921244963204403`*^9, 3.992124497306608*^9}, 3.992125989665868*^9, {
   3.992158999075091*^9, 3.9921590225238*^9}, {3.992162007938998*^9, 
   3.992162042383925*^9}, 3.9922696071815*^9, {3.992419903383662*^9, 
   3.992419937544939*^9}, 3.992425036630001*^9, {3.99243967942551*^9, 
   3.992439681114352*^9}},
 CellLabel->
  "Out[255]=",ExpressionUUID->"0b788a8d-9b87-46f9-b306-9ba4a46842a4"]
}, Open  ]],

Cell[TextData[{
 "The final part of this simple model is to form the real-time simulation. To \
do this, we must have an input to change ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "ad726840-310d-43c5-a196-2df1f75f8a0f"],
 ". This as a result should change the rotation of the monkey and the tail \
length of the monkey. The DynamicModule function achieves the real-time input \
we desire, and the Graphics function can draw out our monkey out of lines \
defined by the variables. The simulation\[CloseCurlyQuote]s code and output \
are visualized below, with UI allowing you to change each variable and reset \
them. Something of note is that the tail is ALWAYS below the head, and \
otherwise it gives a red error indicator."
}], "Text",
 CellChangeTimes->{{3.9920989413599586`*^9, 3.992098954672945*^9}, {
  3.992101728901793*^9, 3.9921017455229387`*^9}, {3.9921251093393593`*^9, 
  3.992125162972011*^9}},ExpressionUUID->"b1f2ec65-0c58-4e2f-bcac-\
62cd6ce94809"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DynamicModule", "[", 
  RowBox[{
   RowBox[{"{", "\n", "\t\t", 
    RowBox[{
     RowBox[{"p1", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", "\n", "\t\t", 
     RowBox[{"p2", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", "\n", "\t\t", 
     RowBox[{"p3", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", "\n", "\t\t", 
     RowBox[{"p4", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", "\n", "\t\t", 
     RowBox[{"p5", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", "\n", "\t\t", 
     RowBox[{"p6", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", "\n", "\t\t", 
     RowBox[{"dTailValue", "=", "0"}], ",", "\n", "\t\t", 
     RowBox[{"p5Visual", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ",", " ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Due", " ", "to", " ", "memory", " ", "allocation"}], ",", " ", 
       RowBox[{
       "we", " ", "need", " ", "seperate", " ", "variables", " ", "for", " ", 
        "p5", " ", "and", " ", "p4"}], ","}], "*)"}], "\n", "\t\t", 
     RowBox[{"p4Visual", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}]}], "  ", 
    RowBox[{"(*", 
     RowBox[{
     "as", " ", "they", " ", "rely", " ", "on", " ", "the", " ", "unsolved", " ", 
      RowBox[{"dTail", "."}]}], "*)"}], "\n", "\t", "}"}], ",", "\n", "\t", 
   RowBox[{"Column", "[", 
    RowBox[{"{", "\n", "\t\t", 
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{"\"\<\\tTorque Balancing System\>\"", 
        ",", "\"\<Subtitle\>\""}], "]"}], ",", "\n", "\t\t", 
      RowBox[{"Row", "[", 
       RowBox[{"{", "\n", "\t\t\t", 
        RowBox[{
         RowBox[{"Slider", "[", 
          RowBox[{
           RowBox[{"Dynamic", "[", "thetaLean", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "89.9"}], ",", "89.9"}], "}"}]}], "]"}], ",", "\n", 
         "\t\t\t", "\"\<\\t\>\"", ",", "\n", "\t\t\t", 
         RowBox[{"Slider", "[", 
          RowBox[{
           RowBox[{"Dynamic", "[", "dHead", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "]"}]}], "\n", "\t\t",
         "}"}], "]"}], ",", "\n", "\t\t", 
      RowBox[{"Dynamic", "[", "\n", "\t\t\t", 
       RowBox[{"Row", "[", 
        RowBox[{"{", "\n", "\t\t\t\t", 
         RowBox[{
          RowBox[{"Pane", "[", 
           RowBox[{
            RowBox[{"StringJoin", "[", 
             RowBox[{"\"\<\[Theta]_lean = \>\"", ",", " ", 
              RowBox[{"ToString", "[", "thetaLean", "]"}]}], "]"}], ",", " ", 
            
            RowBox[{"ImageSize", " ", "->", " ", "200"}], ",", " ", 
            RowBox[{"Alignment", " ", "->", " ", "Left"}]}], "]"}], ",", " ", 
          "\n", "\t\t\t\t", 
          RowBox[{"StringJoin", "[", 
           RowBox[{"\"\<\\td_head = \>\"", ",", " ", 
            RowBox[{"ToString", "[", "dHead", "]"}]}], "]"}]}], "\n", 
         "\t\t\t", "}"}], "]"}], "\n", "\t\t", "]"}], ",", "\n", "\t\t", 
      RowBox[{"Row", "[", 
       RowBox[{"{", "\n", "\t\t\t", 
        RowBox[{
         RowBox[{"Slider", "[", 
          RowBox[{
           RowBox[{"Dynamic", "[", "hHead", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "]"}], ",", "\n", 
         "\t\t\t", "\"\<\\t\>\"", ",", "\n", "\t\t\t", 
         RowBox[{"Slider", "[", 
          RowBox[{
           RowBox[{"Dynamic", "[", "hTail", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Dynamic", "[", 
              RowBox[{"-", "hHead"}], "]"}], ",", 
             RowBox[{"Dynamic", "[", "hHead", "]"}]}], "}"}]}], "]"}]}], "\n",
         "\t\t", "}"}], "]"}], ",", "\n", "\t\t", 
      RowBox[{"Dynamic", "[", "\n", "\t\t\t", 
       RowBox[{"Row", "[", 
        RowBox[{"{", "\n", "\t\t\t\t", 
         RowBox[{
          RowBox[{"Pane", "[", 
           RowBox[{
            RowBox[{"StringJoin", "[", 
             RowBox[{"\"\<h_head = \>\"", ",", " ", 
              RowBox[{"ToString", "[", "hHead", "]"}]}], "]"}], ",", " ", 
            RowBox[{"ImageSize", " ", "->", " ", "200"}], ",", " ", 
            RowBox[{"Alignment", " ", "->", " ", "Left"}]}], "]"}], ",", " ", 
          "\n", "\t\t\t\t", 
          RowBox[{"StringJoin", "[", 
           RowBox[{"\"\<\\th_tail = \>\"", ",", " ", 
            RowBox[{"ToString", "[", "hTail", "]"}]}], "]"}]}], "\n", 
         "\t\t\t", "}"}], "]"}], "\n", "\t\t", "]"}], ",", "\n", "\t\t", 
      RowBox[{"Row", "[", 
       RowBox[{"{", "\n", "\t\t\t", 
        RowBox[{
         RowBox[{"Slider", "[", 
          RowBox[{
           RowBox[{"Dynamic", "[", "mHead", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "]"}], ",", "\n", 
         "\t\t\t", "\"\<\\t\>\"", ",", "\n", "\t\t\t", 
         RowBox[{"Slider", "[", 
          RowBox[{
           RowBox[{"Dynamic", "[", "mTail", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "]"}]}], "\n", "\t\t",
         "}"}], "]"}], ",", "\n", "\t\t", 
      RowBox[{"Dynamic", "[", "\n", "\t\t\t", 
       RowBox[{"Row", "[", 
        RowBox[{"{", "\n", "\t\t\t\t", 
         RowBox[{
          RowBox[{"Pane", "[", 
           RowBox[{
            RowBox[{"StringJoin", "[", 
             RowBox[{"\"\<m_head = \>\"", ",", " ", 
              RowBox[{"ToString", "[", "mHead", "]"}]}], "]"}], ",", " ", 
            RowBox[{"ImageSize", " ", "->", " ", "200"}], ",", " ", 
            RowBox[{"Alignment", " ", "->", " ", "Left"}]}], "]"}], ",", " ", 
          "\n", "\t\t\t\t", 
          RowBox[{"StringJoin", "[", 
           RowBox[{"\"\<\\tm_tail = \>\"", ",", " ", 
            RowBox[{"ToString", "[", "mTail", "]"}]}], "]"}]}], "\n", 
         "\t\t\t", "}"}], "]"}], "\n", "\t\t", "]"}], ",", "\n", "\t\t", 
      RowBox[{
       RowBox[{"Row", "[", 
        RowBox[{"{", "\n", "\t\t\t", 
         RowBox[{"\"\<\\t\\t\\t\\t\\t\>\"", ",", "\n", "\t\t\t", 
          RowBox[{"Button", "[", 
           RowBox[{"\"\<Reset Values\>\"", ",", "\n", "\t\t\t\t", 
            RowBox[{"Module", "[", 
             RowBox[{
              RowBox[{"{", "}"}], ",", "\n", "\t\t\t\t\t", 
              RowBox[{
               RowBox[{"g", " ", "=", " ", "9.81"}], ";", " ", 
               RowBox[{"(*", 
                RowBox[{"m", "/", "s"}], "*)"}], "\n", "\t\t\t", "\n", 
               "\t\t\t\t\t", 
               RowBox[{"mHead", " ", "=", " ", "1"}], ";", " ", 
               RowBox[{"(*", "kg", "*)"}], "\n", "\t\t\t\t\t", 
               RowBox[{"dHead", " ", "=", " ", "1"}], ";", " ", 
               RowBox[{"(*", "m", "*)"}], "\n", "\t\t\t\t\t", 
               RowBox[{"hHead", " ", "=", " ", "5"}], ";", "\n", "\t\t\t\t\t",
                "\n", "\t\t\t\t\t", 
               RowBox[{"mTail", " ", "=", " ", "1"}], ";", " ", 
               RowBox[{"(*", "kg", "*)"}], "\n", "\t\t\t\t\t", 
               RowBox[{"hTail", " ", "=", " ", "1"}], ";", " ", 
               RowBox[{"(*", "m", "*)"}], "\n", "\t\t\t\t\t", 
               RowBox[{"thetaLean", " ", "=", " ", "15"}], ";"}]}], " ", 
             RowBox[{"(*", "degrees", "*)"}], "\n", "\t\t\t\t", "]"}]}], "\n",
            "\t\t\t", "]"}]}], "\n", "\t\t", "}"}], "]"}], "\n", "\t\t", "\n",
        "\t\t", 
       RowBox[{"Dynamic", "[", "\n", "\t\t\t", 
        RowBox[{
         RowBox[{"p2", " ", "=", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "hHead"}], "*", 
             RowBox[{"Sin", "[", 
              RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", 
            RowBox[{"hHead", "*", 
             RowBox[{"Cos", "[", 
              RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], ";", 
         "\n", "\t\t\t", 
         RowBox[{"p3", " ", "=", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "hTail"}], "*", 
             RowBox[{"Sin", "[", 
              RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", 
            RowBox[{"hTail", "*", 
             RowBox[{"Cos", "[", 
              RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], ";", 
         "\n", "\t\t\t", 
         RowBox[{"p1", " ", "=", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"p2", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "-", 
             RowBox[{"dHead", "*", 
              RowBox[{"Cos", "[", 
               RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], ",", 
            RowBox[{
             RowBox[{"p2", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "-", 
             RowBox[{"dHead", "*", 
              RowBox[{"Sin", "[", 
               RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}]}], "}"}]}], ";",
          "\n", "\t\t\t", 
         RowBox[{"p5", " ", "=", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"p3", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "+", 
             RowBox[{"dTail", "*", 
              RowBox[{"Cos", "[", 
               RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], ",", 
            RowBox[{
             RowBox[{"p3", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "+", 
             RowBox[{"dTail", "*", 
              RowBox[{"Sin", "[", 
               RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}]}], "}"}]}], ";",
          "\n", "\t\t\t", 
         RowBox[{"p4", " ", "=", " ", 
          RowBox[{"Midpoint", "[", 
           RowBox[{"{", 
            RowBox[{"p3", ",", "p5"}], "}"}], "]"}]}], ";", "\n", "\t\t\t", 
         RowBox[{"dTailValue", " ", "=", " ", 
          RowBox[{"Values", "@", 
           RowBox[{
            RowBox[{"Flatten", "[", "\n", "\t\t\t\t", 
             RowBox[{"NSolve", "[", "\n", "\t\t\t\t\t", 
              RowBox[{
               RowBox[{
                RowBox[{"torqueAtPoint", "[", 
                 RowBox[{"mHead", ",", "p1"}], "]"}], "==", 
                RowBox[{"-", 
                 RowBox[{"torqueAtPoint", "[", 
                  RowBox[{"mTail", ",", "p4"}], "]"}]}]}], ",", "\n", 
               "\t\t\t\t\t", "dTail"}], "\n", "\t\t\t\t", "]"}], "\n", 
             "\t\t\t", "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\n", "\t\t\t", 
         RowBox[{"p5Visual", " ", "=", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"p3", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "+", 
             RowBox[{"dTailValue", "*", 
              RowBox[{"Cos", "[", 
               RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], ",", 
            RowBox[{
             RowBox[{"p3", "[", 
              RowBox[{"[", "2", "]"}], "]"}], "+", 
             RowBox[{"dTailValue", "*", 
              RowBox[{"Sin", "[", 
               RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}]}], "}"}]}], ";",
          "\n", "\t\t\t", 
         RowBox[{"p4Visual", " ", "=", " ", 
          RowBox[{"Midpoint", "[", 
