   3.992467732351017*^9},ExpressionUUID->"c9313fa5-24a3-4e0e-828b-\
67dd94bfa06b"],

Cell[TextData[{
 "Implementation of these thee formulas for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "1"], TraditionalForm]],ExpressionUUID->
  "f6b8d7fe-1ad6-4b06-b597-65b3b984a7dc"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "2"], TraditionalForm]],ExpressionUUID->
  "267ef9c0-96dd-4130-8e03-d91164adb889"],
 ", and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "n"], TraditionalForm]],ExpressionUUID->
  "b4ce8995-9d5e-4197-9092-d7a5d694196a"],
 " using recursion, temporary \[OpenCurlyDoubleQuote]doubleprev\
\[CloseCurlyDoubleQuote] and \[OpenCurlyDoubleQuote]prev\
\[CloseCurlyDoubleQuote] variables due to memory allocation, and a loop based \
on the numPoints variable defined earlier:"
}], "CodeText",
 CellChangeTimes->{{3.9924422581544724`*^9, 3.992442284343647*^9}, {
  3.992467746121683*^9, 3.992467746836852*^9}, {3.992467812534623*^9, 
  3.99246784321319*^9}},ExpressionUUID->"e8302ee3-7328-4915-91b1-\
708ae96bf171"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "thetaVars", "]"}], "\n", 
 RowBox[{
  RowBox[{"doubleprev", " ", "=", " ", 
   RowBox[{
    RowBox[{"thetaAdjVars", "[", 
     RowBox[{"[", "1", "]"}], "]"}], "-", 
    RowBox[{"(", 
     RowBox[{"90", "+", "thetaLean"}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"prev", "=", 
   RowBox[{"180", "-", 
    RowBox[{"thetaAdjVars", "[", 
     RowBox[{"[", "2", "]"}], "]"}], "-", "doubleprev"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"thetaVars", "=", 
   RowBox[{"Table", "[", "\n", "\t", 
    RowBox[{
     RowBox[{"Which", "[", "\n", "\t", 
      RowBox[{
       RowBox[{"n", "==", "1"}], ",", " ", 
       RowBox[{
        RowBox[{"thetaAdjVars", "[", 
         RowBox[{"[", "n", "]"}], "]"}], "-", 
        RowBox[{"(", 
         RowBox[{"90", "+", "thetaLean"}], ")"}]}], ",", "\n", "\t", 
       RowBox[{"n", "==", "2"}], ",", " ", 
       RowBox[{
        RowBox[{"prev", "=", " ", 
         RowBox[{"180", "-", 
          RowBox[{"thetaAdjVars", "[", 
           RowBox[{"[", "n", "]"}], "]"}], "-", "doubleprev"}]}], ";", 
        RowBox[{"180", "-", 
         RowBox[{"thetaAdjVars", "[", 
          RowBox[{"[", "n", "]"}], "]"}], "-", "doubleprev"}]}], ",", "\n", 
       "\t", 
       RowBox[{"n", ">=", "3"}], ",", " ", 
       RowBox[{
        RowBox[{"360", " ", "-", " ", 
         RowBox[{"thetaAdjVars", "[", 
          RowBox[{"[", "n", "]"}], "]"}], "-", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"thetaAdjVars", "[", 
            RowBox[{"[", 
             RowBox[{"n", "-", "1"}], "]"}], "]"}], "-", "doubleprev"}], 
          ")"}]}], ";", " ", 
        RowBox[{"prev", "=", 
         RowBox[{"360", " ", "-", " ", 
          RowBox[{"thetaAdjVars", "[", 
           RowBox[{"[", "n", "]"}], "]"}], "-", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"thetaAdjVars", "[", 
             RowBox[{"[", 
              RowBox[{"n", "-", "1"}], "]"}], "]"}], "-", "doubleprev"}], 
           ")"}]}]}], ";", " ", 
        RowBox[{"doubleprev", "=", "prev"}]}]}], "\n", "\t", "]"}], ",", "\n", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "numPoints"}], "}"}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.992426805286147*^9, 3.99242681081077*^9}, {
  3.992513022168312*^9, 3.992513029447467*^9}},
 CellLabel->
  "In[338]:=",ExpressionUUID->"8da86b89-6f96-4ad0-aafb-f5088e541da8"],

Cell[TextData[{
 "With all of our ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "n"], TraditionalForm]],ExpressionUUID->
  "461bb785-e67e-4ee8-9d9e-62739495a199"],
 " variables defined, we can now get all remaining ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "n"], TraditionalForm]],ExpressionUUID->
  "2a8e91d1-e155-4cde-9981-b141df08206c"],
 " point variables via simple trigonometry, and setting up the right \
triangles as we did earlier. Each coordinate, or ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "n"], TraditionalForm]],ExpressionUUID->
  "f2cccd5d-d622-45a0-98bb-b9fb5f51a8e9"],
 ", will be a transformation from the last coordinate in the sequence. To do \
this, however, we must define ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "d28336c8-5c6b-493b-938c-4def28b33065"],
 ". We will simply use the same formula we used above in the Model V2 that \
relates ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "3f6fe2aa-cfcc-4f00-88da-b9e87c1ac976"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "c22452ab-632c-4c4b-b836-1641fe54c989"],
 ", and  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "tail"], TraditionalForm]],ExpressionUUID->
  "75b80260-1acb-4f75-99bc-fbe3b328d2a9"],
 ":\n",
 Cell[BoxData[
  GraphicsBox[
   TagBox[RasterBox[CompressedData["
