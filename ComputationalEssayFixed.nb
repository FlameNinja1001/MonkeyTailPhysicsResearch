Cell["Defining the origin and the leaning angle:", "CodeText",
 CellChangeTimes->{{3.992441054939665*^9, 3.992441061779421*^9}, {
  3.99244111238437*^9, 
  3.992441117361927*^9}},ExpressionUUID->"dc5a30f9-bfa3-4ae6-a250-\
c8958669df76"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"thetaLean", " ", "=", " ", "15"}], ";"}], " "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"p6", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "0"}], "}"}]}], ";"}], " "}]}], "Input",
 CellChangeTimes->{
  3.9920924754622097`*^9, {3.992097130184827*^9, 3.992097134714262*^9}, {
   3.9920982264622602`*^9, 3.992098229396916*^9}, {3.992441063435473*^9, 
   3.9924410650978737`*^9}, {3.992594641224121*^9, 3.9925946425390797`*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"4eeb5805-8f2e-4cd2-ac95-174d6d93cfa4"],

Cell[TextData[{
 "Now, instead of simply defining the coordinates with the variables from \
earlier, I used trigonometry to define them. Beginning with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "8a4dc0f8-7577-48a5-8597-fa2aa902819c"],
 ", which can be defined by drawing a right triangle from the origin ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "6"], TraditionalForm]],ExpressionUUID->
  "608c0622-eefa-4f81-aa57-5a1ac2994410"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "ba228962-3a23-4c95-aca7-c9add3d98c43"],
 ", it uses ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "1f29acb4-e186-47a2-bc66-08c8c05929a3"],
 " as one of its angles. This is visualized below:"
}], "Text",
 CellChangeTimes->{{3.9293546184036617`*^9, 3.9293546199188967`*^9}, {
   3.991843023893482*^9, 3.991843098671399*^9}, {3.991843141651308*^9, 
   3.991843153204752*^9}, {3.9918432145448112`*^9, 3.991843314639442*^9}, {
   3.991843367531785*^9, 3.991843482849601*^9}, {3.991843529523225*^9, 
   3.991843563288316*^9}, {3.99184359410602*^9, 3.9918436278691387`*^9}, {
   3.9918436914439497`*^9, 3.991843723147058*^9}, {3.991843789397196*^9, 
   3.9918438381344337`*^9}, {3.99184392692651*^9, 3.991844022786091*^9}, {
   3.991844093496125*^9, 3.9918441019339437`*^9}, {3.991844140124487*^9, 
   3.991844288216073*^9}, {3.991844434010304*^9, 3.991844463089705*^9}, 
