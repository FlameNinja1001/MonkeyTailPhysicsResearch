Cell[BoxData[{
 RowBox[{"ClearAll", "[", "thetaAdj", "]"}], "\n", 
 RowBox[{
  RowBox[{"p5", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"p3", "[", 
       RowBox[{"[", "1", "]"}], "]"}], " ", "+", " ", 
      RowBox[{"dTailConst", "*", 
       RowBox[{"Cos", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"90", " ", "+", " ", "thetaLean", "-", "thetaAdj"}], ")"}], 
         " ", "Degree"}], "]"}]}]}], ",", " ", 
     RowBox[{
      RowBox[{"p3", "[", 
       RowBox[{"[", "2", "]"}], "]"}], " ", "+", " ", 
      RowBox[{"dTailConst", "*", 
       RowBox[{"Sin", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"90", " ", "+", " ", "thetaLean", "-", "thetaAdj"}], ")"}], 
         " ", "Degree"}], "]"}]}]}]}], "}"}]}], ";"}]}], "Input",
 CellChangeTimes->{
  3.992112681451087*^9, {3.992112901407383*^9, 3.992112950513897*^9}, {
   3.992113151235607*^9, 3.992113153100049*^9}, {3.992114772370968*^9, 
