   3.992445410578506*^9, 3.992445427136434*^9}, {3.992445721840701*^9, 
   3.992445732279418*^9}, {3.9924464068410673`*^9, 3.992446409819991*^9}, {
   3.992446451774686*^9, 3.9924464616771593`*^9}, {3.992446528112933*^9, 
   3.992446530092387*^9}, {3.992464703243794*^9, 3.992464979147122*^9}, {
   3.9924652524149637`*^9, 3.9924652652733088`*^9}, {3.9924653164823437`*^9, 
   3.992465321734583*^9}, {3.992465779391829*^9, 3.992465819315625*^9}, {
