  3.992441336915831*^9},ExpressionUUID->"dc175f09-b7e1-4650-bb24-\
ff758118e4da"],

Cell[BoxData[
 RowBox[{
  RowBox[{"p5", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"p3", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "+", 
      RowBox[{"dTail", "*", 
       RowBox[{"Cos", "[", 
        RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"p3", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "+", 
      RowBox[{"dTail", "*", 
       RowBox[{"Sin", "[", 
        RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}]}], "}"}]}], 
  ";"}]], "Input",
