     RowBox[{"hTail", "*", 
      RowBox[{"Cos", "[", 
       RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"p1", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"p2", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "-", 
      RowBox[{"dHead", "*", 
       RowBox[{"Cos", "[", 
        RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"p2", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "-", 
      RowBox[{"dHead", "*", 
       RowBox[{"Sin", "[", 
        RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}]}], "}"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9921131222179747`*^9, 3.9921131316411867`*^9}, {
   3.9921132429315147`*^9, 3.992113246915884*^9}, {3.9921141772692413`*^9, 
