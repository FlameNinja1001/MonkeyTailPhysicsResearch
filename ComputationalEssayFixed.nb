Cell[TextData[{
 "This means that the sine of \[Phi] would be ",
 Cell[BoxData[
  FormBox[
   FractionBox["x", "r"], TraditionalForm]],ExpressionUUID->
  "3d92860f-7d22-4502-b78c-bc3bd77f3409"],
 ". Plugging this into the above torque equation results in the following \
simplification:"
}], "Text",
 CellChangeTimes->{{3.992097266395308*^9, 3.9920972777812233`*^9}, {
  3.9920974531310387`*^9, 3.992097472807303*^9}, {3.992097745948107*^9, 
  3.9920981476796417`*^9}, {3.992421033765835*^9, 3.992421033879548*^9}, {
  3.992441390140338*^9, 3.9924413916989183`*^9}, {3.9925974258569527`*^9, 
  3.99259747202188*^9}, {3.992598757839549*^9, 3.99259875926333*^9}, {
  3.992601545006607*^9, 3.9926015634098988`*^9}, {3.9926159582095947`*^9, 
  3.992615958392747*^9}, {3.992616042345127*^9, 
  3.992616049978857*^9}},ExpressionUUID->"285a9ad5-deb3-4b38-91b4-\
f14584f7c83a"],

Cell[TextData[{
 "\[Tau] = m \:22c5 g \:22c5 r \:22c5 sin(\[Phi])\n\[Tau] = m \:22c5 g \:22c5 \
r \:22c5 ",
 Cell[BoxData[
  FormBox[
   FractionBox["x", "r"], TraditionalForm]],ExpressionUUID->
  "087d5131-74e6-454a-a7c4-20b1dfb8cc64"],
 "\n\[Tau] = m \:22c5 g \:22c5 x"
}], "Text",
 CellChangeTimes->{{3.992097266395308*^9, 3.9920972777812233`*^9}, {
  3.9920974531310387`*^9, 3.992097472807303*^9}, {3.992097745948107*^9, 
  3.9920981476796417`*^9}, {3.992421033765835*^9, 3.992421033879548*^9}, {
  3.992441390140338*^9, 3.9924413916989183`*^9}, {3.9925974258569527`*^9, 
  3.99259747202188*^9}, {3.992598757839549*^9, 3.99259875926333*^9}, {
  3.992601545006607*^9, 3.992601561510029*^9}, {3.99261486676152*^9, 
  3.992614887299932*^9}, {3.992615442721272*^9, 
  3.992615442835601*^9}},ExpressionUUID->"0abe5a3d-55f4-46ee-8054-\
e36bbcf50440"],

Cell[TextData[{
 "It\[CloseCurlyQuote]s also known that in order for the monkey to stay \
balanced when rotated to an angle of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "668922ca-656e-4982-b669-6595d189e588"],
 " degrees, the sum of the torques has to equal zero. Recall that in the \
system, I had two point masses, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "h"], TraditionalForm]],ExpressionUUID->
  "e24dae18-9dd1-4ded-9676-c2d67598d972"],
 " for the head and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "t"], TraditionalForm]],ExpressionUUID->
  "9c4c78fa-b167-458e-9648-416da7b42d90"],
 " for the tail. Their positions can be represented by the coordinates ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "ed7703d2-785f-4cce-b399-241c5cecb15d"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "4"], TraditionalForm]],ExpressionUUID->
  "5733b019-efaa-4cec-a0ea-532daa16749d"],
 ". It can also be expressed that the torque of the head is ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],ExpressionUUID->
  "5aabbf4d-612a-49b5-809d-767d1f3032c6"],
 " and the torque of the tail is ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "c0812dd9-5f64-4e35-b895-03c57be5cc0f"],
 ". With this, I established that: ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],ExpressionUUID->
  "0cf10421-dbe0-40cc-be90-2d35906b66b0"],
 " + ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "6a16c887-794c-41b3-a706-b7bdcff2ce8b"],
 " = 0 , or that the torques are equal and opposite:"
}], "Text",
 CellChangeTimes->{{3.992097266395308*^9, 3.9920972777812233`*^9}, {
   3.9920974531310387`*^9, 3.992097472807303*^9}, {3.992097745948107*^9, 
   3.992098145521916*^9}, {3.992098198772934*^9, 3.9920982084886703`*^9}, {
   3.9920982514498034`*^9, 3.992098335787692*^9}, {3.99209837208337*^9, 
   3.992098422464962*^9}, {3.992441427395996*^9, 3.99244142826186*^9}, {
   3.9925974785471573`*^9, 3.9925975064576387`*^9}, {3.99259869563301*^9, 
   3.9925987001896276`*^9}, 3.992601568413561*^9, {3.9926022987465973`*^9, 
   3.992602323794695*^9}},ExpressionUUID->"0c2db30c-4e5f-4d3f-8fb3-\
d6ad03aecb43"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],ExpressionUUID->
  "df627fd8-e2df-4e1f-bdfb-9278ff4ed0c1"],
 " = -",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "65193c8b-7203-4993-a649-e0e52d4d598d"]
}], "Text",
 CellChangeTimes->{{3.992097266395308*^9, 3.9920972777812233`*^9}, {
   3.9920974531310387`*^9, 3.992097472807303*^9}, {3.992097745948107*^9, 
   3.992098145521916*^9}, {3.992098198772934*^9, 3.9920982084886703`*^9}, {
   3.9920982514498034`*^9, 3.992098335787692*^9}, {3.99209837208337*^9, 
   3.992098422464962*^9}, {3.992441427395996*^9, 3.99244142826186*^9}, {
   3.9925974785471573`*^9, 3.9925975064576387`*^9}, {3.99259869563301*^9, 
   3.9925987001896276`*^9}, 
   3.9926015694758167`*^9},ExpressionUUID->"30b1f3fe-8bf0-4a52-94b5-\
9f15852ee05c"],

Cell["\<\
Because the gravitational constant g is present on both sides, we can \
simplify the torque to the following helper function in Wolfram Language:\
\>", "CodeText",
 CellChangeTimes->{{3.992097266395308*^9, 3.9920972777812233`*^9}, {
  3.9920974531310387`*^9, 3.992097472807303*^9}, {3.992097745948107*^9, 
  3.992098145521916*^9}, {3.992098198772934*^9, 3.9920982084886703`*^9}, {
  3.9920982514498034`*^9, 3.992098335787692*^9}, {3.99209837208337*^9, 
  3.992098422464962*^9}, {3.992441427395996*^9, 3.99244142826186*^9}, {
  3.9925974785471573`*^9, 3.9925975064576387`*^9}, {3.99259869563301*^9, 
  3.9925987001896276`*^9}, {3.9926023443927574`*^9, 3.992602355148279*^9}, {
  3.992616175248864*^9, 3.992616207515441*^9}, {3.992616255870351*^9, 
  3.992616261729281*^9}},ExpressionUUID->"6a1bbb8f-cb85-4a9a-9978-\
6f9dab2819db"],

Cell[BoxData[
 RowBox[{
  RowBox[{"torqueAtPoint", "[", 
   RowBox[{"mass_", ",", "coord_"}], "]"}], ":=", 
  RowBox[{"mass", " ", "*", " ", 
   RowBox[{"coord", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.992097266395308*^9, 3.9920972777812233`*^9}, {
  3.9920974531310387`*^9, 3.992097472807303*^9}, {3.992097745948107*^9, 
  3.992098145521916*^9}, {3.992098198772934*^9, 3.9920982084886703`*^9}, {
  3.9920982514498034`*^9, 3.992098335787692*^9}, {3.99209837208337*^9, 
  3.992098422464962*^9}, {3.992441427395996*^9, 3.99244142826186*^9}, {
  3.9925974785471573`*^9, 3.9925975064576387`*^9}, {3.99259869563301*^9, 
  3.9925987001896276`*^9}, {3.9926023443927574`*^9, 3.992602355148279*^9}, {
  3.992616175248864*^9, 3.992616228418995*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"5aa72a0d-edf7-484b-aaad-f2f5c4bcf6a7"],

Cell[TextData[{
 "With that established, I created this simple model. It is important to \
recall that in the first set of variables, I did not define ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "7e4e8598-f1f0-4e16-94e4-5d112c0dc5a8"],
 "."
}], "Text",
 CellChangeTimes->{{3.992097266395308*^9, 3.9920972777812233`*^9}, {
  3.9920974531310387`*^9, 3.992097472807303*^9}, {3.992097745948107*^9, 
  3.992098145521916*^9}, {3.992098198772934*^9, 3.9920982084886703`*^9}, {
  3.9920982514498034`*^9, 3.992098335787692*^9}, {3.99209837208337*^9, 
  3.992098422464962*^9}, {3.992441427395996*^9, 3.99244142826186*^9}, {
  3.9925974785471573`*^9, 3.9925975064576387`*^9}, {3.99259869563301*^9, 
  3.9925987001896276`*^9}, {3.9926023443927574`*^9, 3.992602355148279*^9}, {
  3.992616175248864*^9, 
  3.992616212010803*^9}},ExpressionUUID->"8f317e11-6709-48c6-8681-\
864846f926f9"],

Cell[TextData[{
 "List of all known constants. Note that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "672b0f76-637c-4058-8612-5609ea3ab9cf"],
 " is undefined:"
}], "CodeText",
 CellChangeTimes->{{3.992441433444645*^9, 
  3.9924414505758963`*^9}},ExpressionUUID->"d33a50eb-8573-480a-a4a6-\
99af7f3d6df9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "mHead", ",", "dHead", ",", "hHead", ",", "mTail", ",", "hTail", ",", 
   "dTail"}], "}"}]], "Input",
 CellChangeTimes->{{3.992098423964962*^9, 3.992098441919664*^9}, {
  3.992616292181282*^9, 3.992616292338677*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"08a17a3e-2196-48d0-a8f7-d40ffcfa4c31"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "1", ",", "5", ",", "1", ",", "1", ",", "dTail"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.992624502576935*^9, 3.99262514903771*^9, 
  3.992625319927712*^9, 3.99262539006179*^9, 3.992625605283596*^9, 
  3.9926256618140507`*^9},
 CellLabel->"Out[19]=",ExpressionUUID->"b0be4bfa-41ec-4bf9-be0e-bf05957e812c"]
}, Open  ]],

Cell[TextData[{
 "I did this because for the torques to stay in equilibrium in the model, \
when ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "8d291870-28dd-4068-851b-1fcffd7f587b"],
 " changes, one or more of the given variables also needs to change. If ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "5134ef91-8567-4414-9d23-7303d94197b7"],
 " was a fixed length, but ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "c1a8b293-4f6e-4b96-b02d-8e0e7a4c9eac"],
 " changed, the system would not be in equilibrium. With this established, I  \
created a model that adjusts ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "e5556693-06c5-4a50-9a08-b7a2f84f680f"],
 " when ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "fe6e895f-e890-42c1-818a-8de743cdcf7d"],
 " changes."
}], "Text",
 CellChangeTimes->{{3.99209846209616*^9, 3.992098568364648*^9}, {
  3.9924414856306267`*^9, 3.992441487478155*^9}, {3.9925975084583597`*^9, 
  3.992597518503393*^9}, {3.9925987623918333`*^9, 
  3.99259877264497*^9}},ExpressionUUID->"209c0b2a-e012-47fe-92fe-\
d497ce93613e"],

Cell[TextData[{
 "Wolfram\[CloseCurlyQuote]s built in NSolve function allows us to solve for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "39d7555c-6541-449a-b38b-32509be1f928"],
 " using the model\[CloseCurlyQuote]s symbolic equations which include ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "a8141b46-c15c-443e-a241-b00c4c6dbc8a"],
 ":"
}], "CodeText",
 CellChangeTimes->{{3.992441492033078*^9, 3.992441512691023*^9}, {
  3.992598775996005*^9, 
  3.9925987762105227`*^9}},ExpressionUUID->"82d6ea66-90fe-4a22-be46-\
5a2fae165609"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NSolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"torqueAtPoint", "[", 
     RowBox[{"mHead", ",", "p1"}], "]"}], "==", 
    RowBox[{"-", 
     RowBox[{"torqueAtPoint", "[", 
      RowBox[{"mTail", ",", "p4"}], "]"}]}]}], ",", "dTail"}], "]"}]], "Input",\

 CellChangeTimes->{{3.992098574045953*^9, 3.9920986100407753`*^9}, 
   3.992098849528429*^9, {3.9926084298870697`*^9, 3.992608432809826*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"977afce1-00a1-4d03-ab3d-dcc19111055a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{"dTail", "\[Rule]", "5.215390309173472`"}], "}"}], "}"}]], "Output",\

 CellChangeTimes->{3.992624502593762*^9, 3.992625149245595*^9, 
  3.992625320021078*^9, 3.992625390270833*^9, 3.992625605389176*^9, 
  3.992625661970105*^9},
