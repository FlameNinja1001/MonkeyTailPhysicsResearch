Cell[BoxData[
 RowBox[{
  RowBox[{"p3", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "hTail"}], "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", 
     RowBox[{"hTail", "*", 
      RowBox[{"Cos", "[", 
       RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], 
  ";"}]], "Input",
