Cell["Defining the origin and the leaning angle:", "CodeText",
 CellChangeTimes->{{3.992441054939665*^9, 3.992441061779421*^9}, {
  3.99244111238437*^9, 
  3.992441117361927*^9}},ExpressionUUID->"e6769b4d-f9f9-4b14-905b-\
ad2be95e234e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"thetaLean", " ", "=", " ", "15"}], ";"}], " ", 
  RowBox[{"(*", "degrees", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"p6", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "0"}], "}"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"origin", " ", "point"}], "*)"}]}]}], "Input",
 CellChangeTimes->{
  3.9920924754622097`*^9, {3.992097130184827*^9, 3.992097134714262*^9}, {
   3.9920982264622602`*^9, 3.992098229396916*^9}, {3.992441063435473*^9, 
   3.9924410650978737`*^9}},
 CellLabel->
  "In[297]:=",ExpressionUUID->"094db03c-f74d-4619-9385-7d05e57c364e"],

Cell[TextData[{
 "Now, instead of simply defining our coordinates with the variables from \
earlier, we must use trigonometry to define them. Let\[CloseCurlyQuote]s \
begin with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "b0b7a307-55ff-4e08-8b56-bf853dc9fc69"],
 ". We can draw a right triangle from the origin ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "6"], TraditionalForm]],ExpressionUUID->
  "8f47d679-1225-48f8-8bae-8fa2a6187e1e"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "4024dac0-feb2-4076-80d5-53fe9e182546"],
 " which uses ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "b2abdd14-b8a1-4281-bb2d-9b432e440b0b"],
 " as one of its angles. This is visualized below:\n",
 Cell[BoxData[
  GraphicsBox[
   TagBox[RasterBox[CompressedData["
