AAAAAAAAAAAAAAAAwFnExMSEh4eLW9WFAACgDN0QgOU44xgAALohAMsxYgAA
QDcEYDlGDAAA6IYALMeIAQAA3RCA5RgxAACgGwKw3Llz58LCwsSt6kIAAFCG
bggAAAAAAAAAAAAAAAAAAAAANvT/AVZwtBI=
     "], {{0, 960.}, {960., 0}}, {0, 255},
     ColorFunction->RGBColor],
    BoxForm`ImageTag["Byte", ColorSpace -> "RGB", Interleaving -> True],
    Selectable->False],
   DefaultBaseStyle->"ImageGraphics",
   ImageSizeRaw->{960., 960.},
   PlotRange->{{0, 960.}, {0, 960.}}]], "Input",ExpressionUUID->
  "0c95125d-7ea5-4c08-981c-b61e2867f804"],
 "\nIn this case, we know the the hypotenuse, always being the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "c1aa72df-97b5-40b7-92bd-afe821b84e05"],
 " constant, and we know the angle, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "70a1c70d-85a3-4eb7-a114-32548340d739"],
 ". Thus, because right triangles are always made, we can define any given \
coordinate as the following:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "n"], " "}], TraditionalForm]],ExpressionUUID->
  "a4d56087-dcf2-4166-a2b6-90d3782d6d91"],
 "= ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", 
     RowBox[{"n", "-", "1"}]], " "}], TraditionalForm]],ExpressionUUID->
  "e047d7ac-dc26-4bc4-96fb-b368c0d3755f"],
 " + (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "tail"], " "}], TraditionalForm]],ExpressionUUID->
  "75927b7b-9882-48dd-ba86-8eeb07ffb01c"],
 " * cos(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "76f767e4-d854-43a0-a1ee-abd8e76c50f4"],
 "), ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "tail"], " "}], TraditionalForm]],ExpressionUUID->
  "2ab3ff41-e0a8-4c3d-8a3c-c497592dfcb9"],
 " * sin(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "0f09f418-3cc8-42ea-901f-aa1f16b0d655"],
 ")); n \[GreaterEqual] 1\n\nThis formula can be implemented in the Wolfram \
Language using Table and an empty variable \[OpenCurlyDoubleQuote]p\
\[CloseCurlyDoubleQuote] to keep track of the last known point. Note that we \
must add numPoints by 1 for the total number of points, as each joint has a \
start and endpoint, thus meaning that for example for 4 joints, there are 5 \
points:"
}], "Text",
 CellChangeTimes->{{3.99242681595566*^9, 3.9924268316542253`*^9}, {
  3.9924269672537317`*^9, 3.992426985349269*^9}, {3.992427058181831*^9, 
  3.992427196925643*^9}, {3.992427243838944*^9, 3.992427256946658*^9}, {
  3.9924283426062813`*^9, 3.9924283632840357`*^9}, {3.992428440914689*^9, 
  3.992428508029765*^9}, {3.9924285875910263`*^9, 3.992428592161234*^9}, {
  3.992428694607253*^9, 3.9924288026147327`*^9}, {3.992429547736376*^9, 
  3.992429584315475*^9}, {3.9924471782497063`*^9, 3.99244718720131*^9}, {
  3.992447226014073*^9, 3.992447231642888*^9}, {3.992447267338966*^9, 
  3.9924473075442677`*^9}, {3.992447848477474*^9, 
  3.992447906482706*^9}},ExpressionUUID->"8a08613d-d5ee-4e6f-ae79-\
27aef7f0d3fa"],

Cell[TextData[{
 "Implementation of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "n"], TraditionalForm]],ExpressionUUID->
  "f9084463-cd7b-410d-881c-c563aab2dd88"],
 " formula recursively in the Wolfram Language:"
}], "CodeText",
 CellChangeTimes->{{3.992442303839573*^9, 
  3.992442319230948*^9}},ExpressionUUID->"18d1cde7-000f-41ec-8f68-\
96865db04330"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "pVars", "]"}], "\n", 
 RowBox[{"p", ";"}], "\n", 
 RowBox[{
  RowBox[{"pVars", "=", 
   RowBox[{"Table", "[", "\n", 
    RowBox[{
     RowBox[{"Which", "[", "\n", "\t", 
      RowBox[{
       RowBox[{"n", "==", "1"}], ",", " ", 
       RowBox[{"p", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "hTail"}], "*", 
           RowBox[{"Sin", "[", 
            RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", 
          RowBox[{"hTail", "*", 
           RowBox[{"Cos", "[", 
            RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], ",", 
       "\n", "\t", 
       RowBox[{"n", ">=", "2"}], ",", " ", 
       RowBox[{"p", "=", 
        RowBox[{"p", "+", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"listOfDistances", "[", 
             RowBox[{"[", 
              RowBox[{"n", "-", "1"}], "]"}], "]"}], "*", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{"thetaVars", "[", 
               RowBox[{"[", 
                RowBox[{"n", "-", "1"}], "]"}], "]"}], " ", "Degree"}], 
             "]"}]}], ",", 
           RowBox[{
            RowBox[{"listOfDistances", "[", 
             RowBox[{"[", 
              RowBox[{"n", "-", "1"}], "]"}], "]"}], "*", 
            RowBox[{"Sin", "[", 
             RowBox[{
              RowBox[{"thetaVars", "[", 
               RowBox[{"[", 
                RowBox[{"n", "-", "1"}], "]"}], "]"}], " ", "Degree"}], 
             "]"}]}]}], "}"}]}]}]}], "]"}], ",", "\n", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", 
       RowBox[{"numPoints", "+", "1"}]}], "}"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.99242881265384*^9, 3.992428815441949*^9}},
 CellLabel->
  "In[342]:=",ExpressionUUID->"6dd53025-e81a-4c78-8ae3-eff3d1a651c5"],

Cell[TextData[{
 "We now must move on to calculating the center of masses, which are actually \
very simple. Each center of mass is simply the midpoint between the endpoints \
of a joint. Thus, we can use the following formula knowing that there is n+1 \
total number of points:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "n"], " "}], TraditionalForm]],ExpressionUUID->
  "4dbcfe04-ba45-461f-a7c6-75c8da1861d0"],
 "=  midpoint(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "n"], TraditionalForm]],ExpressionUUID->
  "39cf403e-78b0-43c4-826c-583af187c2ea"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", 
    RowBox[{"n", "+", "1"}]], TraditionalForm]],ExpressionUUID->
  "6dee2370-b7c4-496e-82a0-b5216c5451d4"],
 ")"
}], "Text",
 CellChangeTimes->{{3.99242681595566*^9, 3.9924268316542253`*^9}, {
  3.9924269672537317`*^9, 3.992426985349269*^9}, {3.992427058181831*^9, 
  3.992427196925643*^9}, {3.992427243838944*^9, 3.992427256946658*^9}, {
  3.9924283426062813`*^9, 3.9924283632840357`*^9}, {3.992428440914689*^9, 
  3.992428508029765*^9}, {3.9924285875910263`*^9, 3.992428592161234*^9}, {
  3.992428694607253*^9, 3.992428800596725*^9}, {3.992429431698173*^9, 
  3.992429448344366*^9}, {3.992429538396015*^9, 3.992429545007667*^9}, {
  3.9924295889379663`*^9, 3.99242969743328*^9}, {3.9924423262708597`*^9, 
  3.992442349004857*^9}},ExpressionUUID->"92faa809-f46d-42e8-bff2-\
1125d17b6bd6"],

Cell["\<\
Using Wolfram\[CloseCurlyQuote]s a built-in Midpoint function to compute the \
center of masses:\
\>", "CodeText",
 CellChangeTimes->{
  3.99244235691253*^9},ExpressionUUID->"07fcc7f7-7ebd-4814-8290-a022bd5c9a6d"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "mVars", "]"}], "\n", 
 RowBox[{
  RowBox[{"mVars", "=", 
   RowBox[{"Table", "[", "\n", "\t", 
    RowBox[{
     RowBox[{"Midpoint", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"pVars", "[", 
         RowBox[{"[", "n", "]"}], "]"}], ",", 
        RowBox[{"pVars", "[", 
         RowBox[{"[", 
          RowBox[{"n", "+", "1"}], "]"}], "]"}]}], "}"}], "]"}], ",", "\n", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "numPoints"}], "}"}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.992429706480315*^9, 3.992429708289136*^9}},
 CellLabel->
  "In[345]:=",ExpressionUUID->"ced8c208-6af5-42ef-833b-582d4c994126"],

Cell["\<\
With all of our center of masses defined, we can now set up the torque \
equilibrium equation from our past two models. Before doing that, however, we \
must define our mass. Mass is a similar constant to distance, in that in real \
tails, it changes between joints, but for simplicity\[CloseCurlyQuote]s sake, \
we will define it as a single constant:\
\>", "Text",
 CellChangeTimes->{{3.9924297840613823`*^9, 3.992429835642281*^9}, {
  3.992429979252898*^9, 3.992429986050687*^9}, {3.9924300328885393`*^9, 
  3.992430126788211*^9}, {3.992430162063816*^9, 3.9924301819042253`*^9}, {
  3.992442435188746*^9, 
  3.99244244334699*^9}},ExpressionUUID->"b10560b0-50db-4891-8d60-\
91eed27ac7c4"],

Cell["\<\
Using the ConstantArray function to create an n-sized list of masses:\
\>", "CodeText",
 CellChangeTimes->{{3.9924424474598503`*^9, 
  3.9924424667295837`*^9}},ExpressionUUID->"961bbc6f-c143-4489-b2a3-\
47570fcf8f50"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "listOfMasses", "]"}], "\n", 
 RowBox[{
  RowBox[{"mTailConst", " ", "=", " ", "1"}], ";"}], "\n", 
 RowBox[{"listOfMasses", " ", "=", " ", 
  RowBox[{"Table", "[", 
   RowBox[{"mTailConst", ",", "numPoints"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.992430201586566*^9, 3.992430203436946*^9}, 
   3.9924390585182323`*^9},
 CellLabel->
  "In[347]:=",ExpressionUUID->"9b32c561-b702-4069-909b-3d19e35bc2d9"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "1", ",", "1", ",", "1"}], "}"}]], "Output",
 CellChangeTimes->{
  3.992439058785111*^9, {3.99243968046132*^9, 3.992439682144813*^9}, 
   3.99244276627492*^9, 3.992509669066792*^9, 3.992513099980969*^9, 
   3.992545393908687*^9, 3.99254553276812*^9, 3.9925456372889843`*^9, 
   3.992545758278524*^9, {3.992547168522155*^9, 3.9925471850554667`*^9}},
 CellLabel->
  "Out[349]=",ExpressionUUID->"e49a56a3-e735-4469-8f6b-a0f6158d5061"]
}, Open  ]],

Cell[TextData[{
 "We need to slightly tweak it from the previous two models, however, because \
our tail now has multiple joints. The torque on the tail now is a summation \
of the torque of every individual joint of the tail. This can be represented \
by the following:\n\n",
 Cell[BoxData[
  FormBox["\[Sum]", TraditionalForm]],ExpressionUUID->
  "3ac03102-42f6-4cf8-b993-eb804d318a33"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "d1dc23f5-3a7b-49d2-9fbb-279a5e347733"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "1"], TraditionalForm]],ExpressionUUID->
  "191fed6e-52d2-4adf-9b05-1858828d13ce"],
 ".x * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "26a6a5b7-5cc3-4908-bb98-501b89b8cb29"],
 " + ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "2"], TraditionalForm]],ExpressionUUID->
  "a1bbd2fb-1cc4-4e06-8349-401ebde0e654"],
 ".x * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "65864962-9b98-4281-9908-0b2fb2a42e6c"],
 " + ... +  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "n"], TraditionalForm]],ExpressionUUID->
  "d5d7a636-ea7c-43fc-9ad9-414aa401b6a5"],
 ".x * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "003be000-b07e-403c-8dd1-5251cf8214ee"]
}], "Text",
 CellChangeTimes->{{3.9924297840613823`*^9, 3.992429835642281*^9}, {
  3.992429979252898*^9, 3.992429986050687*^9}, {3.9924300328885393`*^9, 
  3.992430126788211*^9}, {3.992430162063816*^9, 3.992430178918331*^9}, {
  3.992430333248941*^9, 3.9924303736643457`*^9}, {3.992430412941063*^9, 
  3.992430481540447*^9}, {3.992430522211628*^9, 3.992430532630219*^9}, {
  3.9924424767413387`*^9, 
  3.9924424862241917`*^9}},ExpressionUUID->"4908bd9d-ded6-468a-a7f5-\
1e87853dc679"],

Cell["\<\
Implementing the summation in Wolfram Language by creating a list for each \
torque, and then summing them up using the Total function:\
\>", "CodeText",
 CellChangeTimes->{
  3.9924424909473658`*^9},ExpressionUUID->"89c9217d-c44f-46bc-96fc-\
7d93eeebe1f3"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "torqueVars", "]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"torqueVars", "=", 
    RowBox[{"Table", "[", "\n", "\t", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"mVars", "[", 
         RowBox[{"[", "n", "]"}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}], " ", "*", " ", 
       RowBox[{"listOfMasses", "[", 
        RowBox[{"[", "n", "]"}], "]"}]}], ",", "\n", 
      RowBox[{"{", 
       RowBox[{"n", ",", "1", ",", "numPoints"}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"Total", "[", "torqueVars", "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.992430537815002*^9, 3.992430544191409*^9}},
 CellLabel->
  "In[350]:=",ExpressionUUID->"0675cfe7-9a33-447e-b4e0-9963397580da"],

Cell[TextData[{
 "Now, to create the equilibrium, we can add this total torque to the torque \
on the head, and set it equal to zero:\n\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],ExpressionUUID->
  "fe94666c-be91-4268-bd7e-5277bb8c3eef"],
 " + ",
 Cell[BoxData[
  FormBox["\[Sum]", TraditionalForm]],ExpressionUUID->
  "5ee25c68-5e31-4e80-873d-f56b57fb4afa"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "c5b90822-b7ff-4b70-b451-2ef9c790b2a5"],
 " = 0\n\nNow, just like the previous NSolve functions in Wolfram for the \
previous two models, we need to compute each of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "1012da48-030e-4230-8dc9-e76ba367fd63"],
 " values. Before computing the values, we must define constraints such that \
all of the joints do not fold on each other. In the previous V2, we only \
defined the constraints as 0\[Degree] to 180\[Degree], however, here, we must \
be stricter and stick closer to 180\[Degree] so the joints form a gradual and \
natural curve."
}], "Text",
 CellChangeTimes->{{3.992430546160564*^9, 3.992430574793579*^9}, {
  3.992430647446924*^9, 3.992430686038555*^9}, {3.9924307408162403`*^9, 
  3.992430754278891*^9}, {3.9924385025856943`*^9, 3.992438584663288*^9}, {
  3.992438640573579*^9, 3.992438675778263*^9}, {3.9924389067790003`*^9, 
  3.9924389453976717`*^9}, {3.9924425400360193`*^9, 
  3.9924425947238703`*^9}},ExpressionUUID->"70070d21-4f0e-4f68-aa3d-\
a1e3cad045f7"],

Cell[TextData[{
 "Implementing constraints by once again using the symbolic ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "d781335c-65c4-45df-94ec-bb1a38cf1ace"],
 ". 160\[Degree] - 200\[Degree] was found to produce the most \
\[OpenCurlyDoubleQuote]natural\[CloseCurlyDoubleQuote] results:"
}], "CodeText",
 CellChangeTimes->{
  3.992442588732627*^9},ExpressionUUID->"de479b21-94eb-40c1-9383-\
90fb850a4758"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"lowerBound", "=", "160"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"upperBound", " ", "=", " ", "200"}], ";"}], "\n", 
 RowBox[{"constraints", " ", "=", " ", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"lowerBound", " ", "<=", " ", 
     RowBox[{"thetaAdj", "[", "n", "]"}], " ", "<=", " ", "upperBound"}], ",",
     " ", 
    RowBox[{"{", 
     RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{
  3.992439038272984*^9, {3.992439138154262*^9, 3.9924391412218847`*^9}},
 CellLabel->
  "In[353]:=",ExpressionUUID->"6220499a-0952-4ec5-a040-0faf47e57c3e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"160", "\[LessEqual]", 
    RowBox[{"thetaAdj", "[", "1", "]"}], "\[LessEqual]", "200"}], ",", 
   RowBox[{"160", "\[LessEqual]", 
    RowBox[{"thetaAdj", "[", "2", "]"}], "\[LessEqual]", "200"}], ",", 
   RowBox[{"160", "\[LessEqual]", 
    RowBox[{"thetaAdj", "[", "3", "]"}], "\[LessEqual]", "200"}], ",", 
   RowBox[{"160", "\[LessEqual]", 
    RowBox[{"thetaAdj", "[", "4", "]"}], "\[LessEqual]", "200"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{
  3.992439141512145*^9, {3.9924396805567617`*^9, 3.9924396822340107`*^9}, 
   3.992442766335054*^9, 3.992509669183929*^9, 3.99251310009793*^9, 
   3.992545393988899*^9, 3.992545532879627*^9, 3.992545637398641*^9, 
   3.9925457583595324`*^9, {3.9925471686246634`*^9, 3.9925471851531763`*^9}},
 CellLabel->
  "Out[355]=",ExpressionUUID->"5d8adcf5-eec1-4980-8047-f851e44536d4"]
}, Open  ]],

Cell[TextData[{
 "Another change is that because there is n given solutions at any time, \
however, NSolve will not work due to its syntax requiring a system of \
equations with n amount of equations and n variables being solved for. As a \
result, we will use NMinimize and try to minimize the sum of the torques. \n\n\
NMinimize does this by finding the values which make the objective, the sum \
of the torques in this case, closest to zero. This will output an error value \
and each of the magnitudes for the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "b01071b5-f5dc-4111-8abc-f8ac232e2ed6"],
 " values. When the error is anything above a near-zero value, we can assume \
that it is unsolvable anymore. "
}], "Text",
 CellChangeTimes->{{3.992438950260206*^9, 3.992439027179831*^9}, {
  3.992439695229824*^9, 3.992439748434547*^9}, {3.992442602857543*^9, 
  3.9924426071338167`*^9}},ExpressionUUID->"4bdee60c-7996-47b0-b175-\
3a04a1427c22"],

Cell["\<\
Defining the objective as the sum of the torques, and then minimizing the \
squared error:\
\>", "CodeText",
 CellChangeTimes->{{3.9924426128251333`*^9, 
  3.992442634112012*^9}},ExpressionUUID->"368a09c6-59bf-4448-817c-\
6ae1d0ea3bdc"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"objective", " ", "=", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"torqueAtPoint", "[", 
        RowBox[{"mHead", ",", " ", "mH"}], "]"}], " ", "+", " ", 
       RowBox[{"Total", "[", "torqueVars", "]"}]}], ")"}], "^", "2"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{"output", " ", "=", " ", 
  RowBox[{"NMinimize", "[", "\n", "  \t", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"objective", ",", " ", "constraints"}], "}"}], ",", " ", 
    "thetaAdjVars"}], "\n", "  ", "]"}]}]}], "Input",
 CellChangeTimes->{{3.992439015782524*^9, 3.992439028276684*^9}, {
  3.992439149208548*^9, 3.992439152034925*^9}, {3.992440359426385*^9, 
  3.992440360679812*^9}},
 CellLabel->
  "In[356]:=",ExpressionUUID->"320d8e75-1d53-431a-97a4-cff83cc2e732"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"3.8820022639629666`*^-25", ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"thetaAdj", "[", "1", "]"}], "\[Rule]", "189.2916136663998`"}], 
     ",", 
     RowBox[{
      RowBox[{"thetaAdj", "[", "2", "]"}], "\[Rule]", "166.2526791890495`"}], 
     ",", 
     RowBox[{
      RowBox[{"thetaAdj", "[", "3", "]"}], "\[Rule]", "166.0983485132925`"}], 
     ",", 
     RowBox[{
      RowBox[{"thetaAdj", "[", "4", "]"}], "\[Rule]", 
      "168.27015443995515`"}]}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{
  3.9924391528688593`*^9, {3.992439680667101*^9, 3.9924396823241568`*^9}, 
   3.992442766440092*^9, 3.992509669277961*^9, 3.9925131006929493`*^9, 
   3.992545394899148*^9, 3.992545533019326*^9, 3.992545637509633*^9, 
   3.992545758480755*^9, {3.992547168725726*^9, 3.992547185258629*^9}},
 CellLabel->
  "Out[357]=",ExpressionUUID->"26a6db1e-abb0-4698-956a-fa339309a0a4"]
}, Open  ]],

Cell[TextData[{
 "With each of our ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "79e71213-1db9-4cf5-a476-80f0279d83de"],
 " values defined, we can plug it back into our symbolic expressions and view \
the outputs by reassigning the physical values from output into the symbolic \
values of thetaAdjVars, and recompute our ",
 Cell[BoxData[
  FormBox["\[Theta]", TraditionalForm]],ExpressionUUID->
  "52eb6a72-23fb-48e0-b2c5-bd6a071c727d"],
 " and p values which relied on our ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "840306b2-9f8b-4073-807a-449a655c62de"],
 " values:"
}], "Text",
 CellChangeTimes->{{3.992439229258428*^9, 3.992439298651322*^9}, {
  3.9924393352078667`*^9, 
  3.992439353840773*^9}},ExpressionUUID->"c6cfdd2e-55a4-4c7d-a565-\
e4d4935db797"],

Cell["\<\
Reassigning thetaAdjVars to be actual values instead of symbolic ones:\
\>", "CodeText",
 CellChangeTimes->{{3.992442647272934*^9, 
  3.992442659142373*^9}},ExpressionUUID->"fb553a56-714b-451a-a5d6-\
dbaa36d3f3f9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"thetaAdjVars", " ", "=", " ", 
  RowBox[{"Values", "[", 
   RowBox[{"output", "[", 
    RowBox[{"[", "2", "]"}], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{3.99243930001608*^9},
 CellLabel->
  "In[358]:=",ExpressionUUID->"67a4abe2-7fc4-4219-834d-0f5f19c2e99d"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "189.2916136663998`", ",", "166.2526791890495`", ",", "166.0983485132925`", 
   ",", "168.27015443995515`"}], "}"}]], "Output",
 CellChangeTimes->{
  3.992439300903157*^9, {3.992439680727985*^9, 3.992439682383119*^9}, 
   3.992442766511117*^9, 3.992509669346396*^9, 3.9925131008986397`*^9, 
   3.9925453951541862`*^9, 3.992545533093936*^9, 3.99254563758401*^9, 
   3.992545758554591*^9, {3.992547168795679*^9, 3.992547185352531*^9}},
 CellLabel->
  "Out[358]=",ExpressionUUID->"e0d9fb48-6728-46f7-9155-ca77a3040fb0"]
}, Open  ]],

Cell[TextData[{
 "Using the newly assigned ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "d4df7a03-30c8-4d8a-9d28-4aae56b88745"],
 " list to reassign the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "n"], TraditionalForm]],ExpressionUUID->
  "dc664c77-85d9-45a8-ab9c-96ee9a22291d"],
 " values:"
}], "CodeText",
 CellChangeTimes->{{3.9924427118122787`*^9, 
  3.9924427517380037`*^9}},ExpressionUUID->"9b4bff3b-d769-4996-b337-\
e0b880ea9f79"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "thetaVars", "]"}], "\n", 
 RowBox[{
  RowBox[{"doubleprev", " ", "=", " ", 
   RowBox[{
    RowBox[{"thetaAdjVars", "[", 
     RowBox[{"[", "1", "]"}], "]"}], "-", 
    RowBox[{"(", 
     RowBox[{"90", "+", "thetaLean"}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"prev", "=", 
   RowBox[{"180", "-", 
    RowBox[{"thetaAdjVars", "[", 
     RowBox[{"[", "2", "]"}], "]"}], "-", "doubleprev"}]}], ";"}], "\n", 
 RowBox[{"thetaVars", "=", 
  RowBox[{"Table", "[", "\n", "\t", 
   RowBox[{
    RowBox[{"Which", "[", "\n", "\t", 
     RowBox[{
      RowBox[{"n", "==", "1"}], ",", " ", 
      RowBox[{
       RowBox[{"thetaAdjVars", "[", 
        RowBox[{"[", "n", "]"}], "]"}], "-", 
       RowBox[{"(", 
        RowBox[{"90", "+", "thetaLean"}], ")"}]}], ",", "\n", "\t", 
      RowBox[{"n", "==", "2"}], ",", " ", 
      RowBox[{
       RowBox[{"prev", "=", " ", 
        RowBox[{"180", "-", 
         RowBox[{"thetaAdjVars", "[", 
          RowBox[{"[", "n", "]"}], "]"}], "-", "doubleprev"}]}], ";", 
       RowBox[{"180", "-", 
        RowBox[{"thetaAdjVars", "[", 
         RowBox[{"[", "n", "]"}], "]"}], "-", "doubleprev"}]}], ",", "\n", 
      "\t", 
      RowBox[{"n", ">=", "3"}], ",", " ", 
      RowBox[{
       RowBox[{"360", " ", "-", " ", 
        RowBox[{"thetaAdjVars", "[", 
         RowBox[{"[", "n", "]"}], "]"}], "-", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"thetaAdjVars", "[", 
           RowBox[{"[", 
            RowBox[{"n", "-", "1"}], "]"}], "]"}], "-", "doubleprev"}], 
         ")"}]}], ";", " ", 
       RowBox[{"prev", "=", 
        RowBox[{"360", " ", "-", " ", 
         RowBox[{"thetaAdjVars", "[", 
          RowBox[{"[", "n", "]"}], "]"}], "-", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"thetaAdjVars", "[", 
            RowBox[{"[", 
             RowBox[{"n", "-", "1"}], "]"}], "]"}], "-", "doubleprev"}], 
          ")"}]}]}], ";", " ", 
       RowBox[{"doubleprev", "=", "prev"}]}]}], "\n", "\t", "]"}], ",", "\n", 
    
    RowBox[{"{", 
     RowBox[{"n", ",", "1", ",", "numPoints"}], "}"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{
  3.9924393186122637`*^9, {3.99251307054809*^9, 3.992513081000947*^9}},
 CellLabel->
  "In[359]:=",ExpressionUUID->"6e221671-4d8b-4ae4-b4fb-c8d72ff461a8"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"39.2916136663998`", ",", 
   RowBox[{"-", "25.5442928554493`"}], ",", "66.94058596405779`", ",", 
   "92.57208301081013`"}], "}"}]], "Output",
 CellChangeTimes->{
  3.992439319367722*^9, {3.992439680805831*^9, 3.992439682488559*^9}, 
   3.992442766573634*^9, 3.9925096694369373`*^9, 3.992513100983645*^9, 
   3.992545395257992*^9, 3.992545533220196*^9, 3.992545637707027*^9, 
   3.9925457586548233`*^9, {3.9925471689200573`*^9, 3.992547185418479*^9}},
 CellLabel->
  "Out[362]=",ExpressionUUID->"dc98ac02-3a7a-48db-9fb4-4b8ea280d1d2"]
}, Open  ]],

Cell[TextData[{
 "Using the newly assigned ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "n"], TraditionalForm]],ExpressionUUID->
  "9eaac808-80e0-4da2-9b5a-3d3d5c9acfaa"],
 " list to reassign the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "n"], TraditionalForm]],ExpressionUUID->
  "6fe47cbb-f513-4075-8ec6-bdbacc039a6a"],
 " values:"
}], "CodeText",
 CellChangeTimes->{{3.992442739899919*^9, 
  3.992442753706554*^9}},ExpressionUUID->"1df061d5-abb7-4012-bd3f-\
96c2338e56b5"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "pVars", "]"}], "\n", 
 RowBox[{"p", ";"}], "\n", 
 RowBox[{"pVars", "=", 
  RowBox[{"Table", "[", "\n", 
   RowBox[{
    RowBox[{"Which", "[", "\n", "\t", 
     RowBox[{
      RowBox[{"n", "==", "1"}], ",", " ", 
      RowBox[{"p", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "hTail"}], "*", 
          RowBox[{"Sin", "[", 
           RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", 
         RowBox[{"hTail", "*", 
          RowBox[{"Cos", "[", 
           RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], ",", 
      "\n", "\t", 
      RowBox[{"n", ">=", "2"}], ",", " ", 
      RowBox[{"p", "=", 
       RowBox[{"p", "+", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"listOfDistances", "[", 
            RowBox[{"[", 
             RowBox[{"n", "-", "1"}], "]"}], "]"}], "*", 
           RowBox[{"Cos", "[", 
            RowBox[{
             RowBox[{"thetaVars", "[", 
              RowBox[{"[", 
               RowBox[{"n", "-", "1"}], "]"}], "]"}], " ", "Degree"}], 
            "]"}]}], ",", 
          RowBox[{
           RowBox[{"listOfDistances", "[", 
            RowBox[{"[", 
             RowBox[{"n", "-", "1"}], "]"}], "]"}], "*", 
           RowBox[{"Sin", "[", 
            RowBox[{
             RowBox[{"thetaVars", "[", 
              RowBox[{"[", 
               RowBox[{"n", "-", "1"}], "]"}], "]"}], " ", "Degree"}], 
            "]"}]}]}], "}"}]}]}]}], "]"}], ",", "\n", 
    RowBox[{"{", 
     RowBox[{"n", ",", "1", ",", 
      RowBox[{"numPoints", "+", "1"}]}], "}"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9924393252571917`*^9, 3.992439326321536*^9}},
 CellLabel->
  "In[363]:=",ExpressionUUID->"382ba3ec-2406-4a80-9b19-d5f226bcc510"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       SqrtBox["3"], "2"]}], ",", 
     FractionBox["1", "2"]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"0.2948739594850516`", ",", "1.4499013992833636`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1.648252267625397`", ",", "0.8030883234606991`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"2.23578044962051`", ",", "2.183237096369445`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"2.1684660881681586`", ",", "3.6817259274063208`"}], "}"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{
  3.9924393266842318`*^9, {3.992439680865774*^9, 3.9924396825332003`*^9}, 
   3.9924427666489363`*^9, 3.992509669532926*^9, 3.9925131010480833`*^9, 
   3.99254539533353*^9, 3.9925455333472557`*^9, 3.9925456377776318`*^9, 
   3.99254575872585*^9, {3.992547168995027*^9, 3.992547185512266*^9}},
 CellLabel->
  "Out[365]=",ExpressionUUID->"95cb0920-1b0b-4eae-a5b3-346e9810feeb"]
}, Open  ]],

Cell["\<\
With these formulas and the NMinimize established for our multi-joint model, \
we can now create a final DynamicModule which calculates the visuals for it. \
We also include interactive sliders for the constants. The simulation of the \
model is shown below: \
\>", "Text",
 CellChangeTimes->{{3.992439825989151*^9, 
  3.992439891308881*^9}},ExpressionUUID->"f7f3e97f-def8-41e4-b696-\
95e83db9566a"]
}, Open  ]]
}, Open  ]]
