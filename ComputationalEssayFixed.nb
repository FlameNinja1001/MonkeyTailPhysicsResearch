     "], {{0, 960.}, {960., 0}}, {0, 255},
     ColorFunction->RGBColor],
    BoxForm`ImageTag["Byte", ColorSpace -> "RGB", Interleaving -> True],
    Selectable->False],
   DefaultBaseStyle->"ImageGraphics",
   ImageSizeRaw->{960., 960.},
   PlotRange->{{0, 960.}, {0, 960.}}]], "Input",ExpressionUUID->
  "5a168ecf-1c8a-4aa5-8958-4205daaca296"],
 "\nImmediately, we notice that we can represent the angle between the \
imaginary horizontal line and the second segment as the following:\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj2"], TraditionalForm]],ExpressionUUID->
  "b003da90-b65d-4f81-b9fe-a3fcba1e4864"],
 " + ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "1"], TraditionalForm]],ExpressionUUID->
  "d2687439-143a-4505-ace7-ce1db7dcb36b"],
 " \nHowever, notice that the triangle with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "1"], TraditionalForm]],ExpressionUUID->
  "94d4607b-317b-4419-8c50-5672be1648c5"],
 " goes right and DOWN from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "515ae519-48cc-455c-bfc5-36942ccd8dde"],
 ", meaning it is actually NEGATIVE angle. To factor in for this (and later \
POSITIVE angles when we create a general purpose algorithm), we subtract \
instead, resulting in the following:\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj2"], TraditionalForm]],ExpressionUUID->
  "855da093-59db-4809-a539-34fcd2180977"],
 " + (-",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "1"], TraditionalForm]],ExpressionUUID->
  "ab703303-de29-45ba-bfe4-dc36483d262f"],
 ")\nOR\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj2"], TraditionalForm]],ExpressionUUID->
  "2020c578-02f3-4ab6-9d75-920add3af96f"],
 " - ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "1"], TraditionalForm]],ExpressionUUID->
  "a9b47e9b-ad99-4827-8038-91dc1bbd1e2d"],
 " \n",
