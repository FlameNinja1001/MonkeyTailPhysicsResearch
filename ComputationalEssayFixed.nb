Cell[TextData[{
 "This time, the angle from the horizontal to the new reference frame is ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "2"], TraditionalForm]],ExpressionUUID->
  "27e9d35b-03ad-4738-8001-9de680166009"],
 ". This means that the total angle, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "3"], TraditionalForm]],ExpressionUUID->
  "67d87e68-3745-4847-8ec1-c93454c177ee"],
 ", is the sum of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj3"], TraditionalForm]],ExpressionUUID->
  "5b79c715-d625-43f3-9957-b6f111712693"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "2"], TraditionalForm]],ExpressionUUID->
  "3776f4f6-5d7e-4a3b-9839-cedacebe7ee1"],
 ":"
}], "Text",
