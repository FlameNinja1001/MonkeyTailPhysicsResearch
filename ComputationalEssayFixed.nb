Cell[TextData[{
 "The final part of this simple model is to form a visual simulation by \
parameterizing our model with respect to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "c1457c7d-b203-4e72-a012-e622895f20dd"],
 ". This as a result changes the rotation of the monkey and the tail length \
of the monkey."
}], "Text",
 CellChangeTimes->{{3.9920989413599586`*^9, 3.992098954672945*^9}, {
   3.992101728901793*^9, 3.9921017455229387`*^9}, {3.9921251093393593`*^9, 
   3.992125162972011*^9}, 3.992441619125505*^9, {3.992597522932423*^9, 
   3.992597549308612*^9}, {3.9926023894061623`*^9, 3.9926024110020695`*^9}, {
   3.9926164481081553`*^9, 3.9926164566749573`*^9}, {3.9926165198214607`*^9, 
   3.992616569074873*^9}},ExpressionUUID->"af4756d3-a025-46e1-b824-\
918d6c575ba8"],

Cell["\<\
Defining a function for all the prior computations listed above:\
\>", "CodeText",
 CellChangeTimes->{{3.992511895512957*^9, 
  3.9925119028171997`*^9}},ExpressionUUID->"ce8a8a97-5476-4cc4-b812-\
aa32a96da205"],

Cell[BoxData[
 RowBox[{
  RowBox[{"drawMonkey1", "[", "thetaLean_", "]"}], ":=", "\n", "\t", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "p1", ",", "p2", ",", "p3", ",", "p4", ",", "p5", ",", "p6", ",", 
      "p5Visual", ",", "p4Visual", ",", "dTailValue"}], "}"}], ",", "\n", 
    "\t", "\n", "\t\t", 
    RowBox[{
     RowBox[{"p6", "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}]}], ";", "\n", "\t\t", 
     RowBox[{"p2", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "hHead"}], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", 
        RowBox[{"hHead", "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], ";", "\n",
      "\t\t", 
     RowBox[{"p3", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "hTail"}], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", 
        RowBox[{"hTail", "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], ";", "\n",
      "\t\t", 
     RowBox[{"p1", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"p2", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "-", 
         RowBox[{"dHead", "*", 
          RowBox[{"Cos", "[", 
           RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"p2", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "-", 
         RowBox[{"dHead", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}]}], "}"}]}], ";", 
     "\n", "\t\t", 
     RowBox[{"p5", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"p3", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "+", 
         RowBox[{"dTail", "*", 
          RowBox[{"Cos", "[", 
           RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"p3", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "+", 
         RowBox[{"dTail", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}]}], "}"}]}], ";", 
     "\n", "\t\t", 
     RowBox[{"p4", " ", "=", " ", 
      RowBox[{"Midpoint", "[", 
       RowBox[{"{", 
        RowBox[{"p3", ",", "p5"}], "}"}], "]"}]}], ";", "\n", "\t\t", "\n", 
     "\t\t", 
     RowBox[{"dTailValue", " ", "=", " ", 
      RowBox[{"Values", "@", 
       RowBox[{
        RowBox[{"Flatten", "[", "\n", "\t\t\t", 
         RowBox[{"NSolve", "[", "\n", "\t\t\t\t", 
          RowBox[{
           RowBox[{
            RowBox[{"torqueAtPoint", "[", 
             RowBox[{"mHead", ",", "p1"}], "]"}], "==", 
            RowBox[{"-", 
             RowBox[{"torqueAtPoint", "[", 
              RowBox[{"mTail", ",", "p4"}], "]"}]}]}], ",", "\n", "\t\t\t\t", 
           "dTail"}], "\n", "\t\t\t", "]"}], "\n", "\t\t", "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\n", "\t\t", "\n", "\t\t", 
     RowBox[{"p5Visual", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"p3", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "+", 
         RowBox[{"dTailValue", "*", 
          RowBox[{"Cos", "[", 
           RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"p3", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "+", 
         RowBox[{"dTailValue", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}]}], "}"}]}], ";", 
     "\n", "\t\t", 
     RowBox[{"p4Visual", " ", "=", " ", 
      RowBox[{"Midpoint", "[", 
       RowBox[{"{", 
        RowBox[{"p3", ",", "p5Visual"}], "}"}], "]"}]}], ";", "\n", "\t\t", 
     RowBox[{"Graphics", "[", 
      RowBox[{
       RowBox[{"{", "\n", "\t\t\t", 
        RowBox[{"Blue", ",", 
         RowBox[{"{", "\n", "\t\t\t\t", 
          RowBox[{
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{"p1", ",", "p2"}], "}"}], "]"}], ",", "\n", "\t\t\t\t", 
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{"p6", ",", "p3"}], "}"}], "]"}], ",", "\n", "\t\t\t\t", 
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{"p2", ",", "p3"}], "}"}], "]"}], ",", "\n", "\t\t\t\t", 
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{"p5Visual", ",", "p3"}], "}"}], "]"}]}], "}"}], ",", 
         "\n", "\t\t\t", "LightGray", ",", "Dashed", ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "10"}], ",", "0"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"10", ",", "0"}], "}"}]}], "}"}], "]"}], ",", 
           RowBox[{"Line", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"0", ",", 
                RowBox[{"-", "10"}]}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"0", ",", "10"}], "}"}]}], "}"}], "]"}]}], "}"}]}], 
        "}"}], ",", " ", "\n", "\t\t\t", 
       RowBox[{"ImageSize", "->", "Medium"}], ",", 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "}"}]}]}], "\n", 
      "\t\t", "]"}]}]}], "\n", "]"}]}]], "Code",
 CellChangeTimes->{
  3.9925110380856113`*^9, {3.9925112567263193`*^9, 3.992511260331654*^9}, {
   3.992602417159851*^9, 3.992602472801508*^9}, {3.992615018660692*^9, 
