Cell[TextData[{
 "As the diagram shows, due to the corresponding angles theorem, this larger \
angle, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "2"], TraditionalForm]],ExpressionUUID->
  "d4dc7e5a-097d-2c42-ac2f-5a32d6f60900"],
 ", is actually the sum of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj2"], TraditionalForm]],ExpressionUUID->
  "90c445ca-2d8d-4044-86d9-e65d882f94fe"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "1"], TraditionalForm]],ExpressionUUID->
  "43832371-67e5-a247-851c-41bdbffb6171"],
 ". Thus, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "2"], TraditionalForm]],ExpressionUUID->
  "4fd3fdae-edc6-3b4a-b00d-1a52d38be77f"],
 " can be defined as:"
}], "Text",
