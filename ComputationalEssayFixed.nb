   3.9921260773657084`*^9, 3.992126130943181*^9, {3.992126167805657*^9, 
   3.9921262138455963`*^9}, 3.992126265626384*^9, {3.992126331649048*^9, 
   3.992126403638442*^9}, {3.992158999633719*^9, 3.992159023103298*^9}, 
