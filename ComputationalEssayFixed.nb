Cell[TextData[{
 "In the above diagram, the monkey is standing perfectly upright. However, \
this will not always be the case. Thus, I added a 7th variable, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "7b41f61d-0086-491e-8908-73778cf9814a"],
 ", which looks like this:"
}], "Text",
