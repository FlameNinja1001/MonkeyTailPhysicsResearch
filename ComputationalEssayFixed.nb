Cell[TextData[{
 "Implementation of these thee formulas for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "1"], TraditionalForm]],ExpressionUUID->
  "83750fa4-953e-4525-97a5-9329fa538ece"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "n"], TraditionalForm]],ExpressionUUID->
  "3977bf6f-f837-4535-bbe5-4aeba9c21345"],
 " using the sum of all past angles to represent ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "e91c1b8d-343d-4180-bb05-69aee779917e"],
 ":"
}], "CodeText",
 CellChangeTimes->{{3.9924422581544724`*^9, 3.992442284343647*^9}, {
  3.992467746121683*^9, 3.992467746836852*^9}, {3.992467812534623*^9, 
  3.99246784321319*^9}, {3.9925922893420877`*^9, 
  3.992592314802619*^9}},ExpressionUUID->"0e6960ec-dc1a-4371-9949-\
0dbe63d7da4b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"thetaVarsFunc", "[", 
    RowBox[{"numPoints_Integer", ",", " ", "thetaLean_Real"}], "]"}], " ", ":=",
    " ", "\n", "\t", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"thetaAdjVars", " ", "=", " ", 
        RowBox[{"Unique", "[", "\"\<thetaAdjV\>\"", "]"}]}], ",", " ", 
       "firstTheta"}], "}"}], ",", "\n", "\t", "\n", "\t", 
     RowBox[{
      RowBox[{"If", "[", "\n", "\t\t", 
       RowBox[{
        RowBox[{"thetaLean", " ", ">=", " ", "0"}], ",", " ", "\n", "\t\t", 
        RowBox[{"firstTheta", " ", "=", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Pi", "/", "2"}], " ", "+", " ", "thetaLean"}], ")"}], 
          " ", "-", " ", 
          RowBox[{"thetaAdjVars", "[", "1", "]"}]}]}], ",", " ", "\n", "\t\t", 
        RowBox[{"firstTheta", " ", "=", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"thetaLean", " ", "+", " ", 
            RowBox[{"thetaAdjVars", "[", "1", "]"}]}], ")"}], " ", "-", " ", 
          RowBox[{"Pi", "/", "2"}]}]}]}], "]"}], ";", "\n", "\t\t", "\n", 
      "\t", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Table", "[", "\n", "\t\t", 
         RowBox[{
          RowBox[{"Which", "[", "\n", "\t\t\t", 
           RowBox[{
            RowBox[{"n", "==", "1"}], ",", " ", "\n", "\t\t\t", "firstTheta", 
            ",", "\n", "\t\t\t", "True", ",", "\n", "\t\t\t", 
            RowBox[{
             RowBox[{"Sum", "[", 
              RowBox[{
               RowBox[{"thetaAdjVars", "[", "m", "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"m", ",", " ", "2", ",", " ", "n"}], "}"}]}], "]"}], "+",
              " ", "firstTheta"}]}], "]"}], ",", " ", "\n", "\t\t", 
          RowBox[{"{", 
           RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], 
         "]"}], ",", " ", "\n", "\t", "thetaAdjVars"}], "}"}]}]}], "\n", 
    "]"}]}], ";"}]], "Code",
 CellChangeTimes->{{3.992426805286147*^9, 3.99242681081077*^9}, {
   3.992513022168312*^9, 3.992513029447467*^9}, {3.992592282933468*^9, 
   3.992592284682097*^9}, {3.992602875935396*^9, 3.992602922220356*^9}, 
   3.992620141320607*^9, 3.992623616842235*^9},
 CellLabel->"In[54]:=",ExpressionUUID->"8a1e601c-1c5f-4f92-8869-41449539dc5c"],

Cell[TextData[{
 "With all of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "n"], TraditionalForm]],ExpressionUUID->
  "4ab66ee3-f68c-4d34-944c-f7c06df04537"],
 " variables defined, I could calculate the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "n"], TraditionalForm]],ExpressionUUID->
  "08c1983e-65b4-4ad1-8849-dd4f43055cdc"],
 " point variables via simple trigonometry. Each coordinate ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "n"], TraditionalForm]],ExpressionUUID->
  "f39be9c0-9a87-4369-800a-48f7dfbda7a4"],
 " will be a translation from the last coordinate in the sequence ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "03b3c8f0-cb7f-4612-9558-c872e2f4c876"],
 ". The first term in the sequence, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "db7e99c3-2e1f-4e73-bb0d-28f48ccae865"],
 ", is defined using the same formula in Model V2 that relates ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "1559581d-3397-4c3a-b19c-c361ec2a1eab"],
 ", and  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "tail"], TraditionalForm]],ExpressionUUID->
  "cda0d4bc-bbb1-42b8-8445-db3e463f2861"],
 ":"
}], "Text",
 CellChangeTimes->{{3.99242681595566*^9, 3.9924268316542253`*^9}, {
