Cell[TextData[{
 "Implementing trigonometric functions to solve for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "9c6c6e59-e408-4ac4-a830-bb81a7651479"],
 " in the Wolfram Language:"
}], "CodeText",
 CellChangeTimes->{{3.992441188923299*^9, 
  3.992441204753735*^9}},ExpressionUUID->"fc266ad1-6326-4371-8db0-\
0f8c7cfbdff9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"p1", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"p2", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "-", 
      RowBox[{"dHead", "*", 
       RowBox[{"Cos", "[", 
        RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"p2", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "-", 
      RowBox[{"dHead", "*", 
       RowBox[{"Sin", "[", 
        RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}]}], "}"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.99209509573956*^9, 3.992095152566937*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"38b20474-1f14-4049-86ba-7895d341511a"],

Cell[TextData[{
 "Similarly, to derive ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "1d0c027b-d93a-4b5c-866f-b4fa68f23e83"],
 " from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "2b5cc893-afe0-4f9d-ba21-7d496fa16efb"],
 ", I formed a right triangle from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "b3976f8e-c62d-45fb-8fb3-04db8f19d89d"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "11fea433-86d5-417f-8dd9-82e20d7c6083"],
 ", as shown below:"
}], "Text",
