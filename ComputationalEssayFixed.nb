   3.992547600846415*^9},
 CellLabel->"In[50]:=",ExpressionUUID->"f9faf343-a37f-48f3-a205-72b7753ab0e1"],

Cell[BoxData[
 RowBox[{"thetaAdj", "\[Rule]", "135.83770196374246`"}]], "Output",
