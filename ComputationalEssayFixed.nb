Cell[TextData[{
 "Drawing a vertical line from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "9ef4f47c-9695-4239-8a18-8d3816903d57"],
 ", it becomes evident that it\[CloseCurlyQuote]s parallel to the line which \
defines ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "8b5250f1-6baa-4b82-9798-8d779ed74b93"],
 ". By the alternate interior angles theorem, this means that it\
\[CloseCurlyQuote]s congruent to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "7297073e-b590-4daf-9829-27c95cb997c8"],
 ". Since the line between ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "6853431a-5783-4b06-9bb9-433d3dd62276"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "69636dc4-29db-4188-a7d8-c59b535630d4"],
 " is 90 degrees, I defined the complementary angle as 90-",
 Cell[BoxData[
  FormBox[
   FormBox[
    SubscriptBox["\[Theta]", "lean"],
    TraditionalForm], TraditionalForm]],ExpressionUUID->
  "c1b72a51-0ca8-4f00-825b-4b107321f0c3"],
 ". However, since this new angle of 90-",
 Cell[BoxData[
  FormBox[
   FormBox[
    SubscriptBox["\[Theta]", "lean"],
    TraditionalForm], TraditionalForm]],ExpressionUUID->
  "57e54179-f99b-4aed-b3df-bda52119a886"],
 " is also complementary to the missing angle of the right triangle (marked \
in red), the missing angle is ",
 Cell[BoxData[
  FormBox[
   FormBox[
    SubscriptBox["\[Theta]", "lean"],
    TraditionalForm], TraditionalForm]],ExpressionUUID->
  "c4e26d3b-9209-4147-b9fc-8166b78619c2"],
 ", as shown below:"
}], "Text",
 CellChangeTimes->{{3.9293546184036617`*^9, 3.9293546199188967`*^9}, {
