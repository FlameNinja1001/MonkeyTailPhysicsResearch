Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "pVars", "]"}], "\n", 
 RowBox[{"p", ";"}], "\n", 
 RowBox[{"pVars", "=", 
  RowBox[{"Table", "[", "\n", 
   RowBox[{
    RowBox[{"Which", "[", "\n", "\t", 
     RowBox[{
      RowBox[{"n", "==", "1"}], ",", " ", 
      RowBox[{"p", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "hTail"}], "*", 
          RowBox[{"Sin", "[", 
           RowBox[{"thetaLean", " ", "Degree"}], "]"}]}], ",", 
         RowBox[{"hTail", "*", 
          RowBox[{"Cos", "[", 
           RowBox[{"thetaLean", " ", "Degree"}], "]"}]}]}], "}"}]}], ",", 
      "\n", "\t", 
      RowBox[{"n", ">=", "2"}], ",", " ", 
      RowBox[{"p", "=", 
       RowBox[{"p", "+", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"listOfDistances", "[", 
            RowBox[{"[", 
             RowBox[{"n", "-", "1"}], "]"}], "]"}], "*", 
           RowBox[{"Cos", "[", 
            RowBox[{
             RowBox[{"thetaVars", "[", 
              RowBox[{"[", 
               RowBox[{"n", "-", "1"}], "]"}], "]"}], " ", "Degree"}], 
            "]"}]}], ",", 
          RowBox[{
           RowBox[{"listOfDistances", "[", 
            RowBox[{"[", 
             RowBox[{"n", "-", "1"}], "]"}], "]"}], "*", 
           RowBox[{"Sin", "[", 
            RowBox[{
             RowBox[{"thetaVars", "[", 
              RowBox[{"[", 
               RowBox[{"n", "-", "1"}], "]"}], "]"}], " ", "Degree"}], 
            "]"}]}]}], "}"}]}]}]}], "]"}], ",", "\n", 
    RowBox[{"{", 
     RowBox[{"n", ",", "1", ",", 
      RowBox[{"numPoints", "+", "1"}]}], "}"}]}], "]"}]}]}], "Code",
