   3.992426122816869*^9}, {3.992426295421831*^9, 3.992426364079625*^9}, {
   3.9924264734863567`*^9, 3.9924265491572943`*^9}, {3.992426673894291*^9, 
   3.992426744439538*^9}, {3.992426837513113*^9, 3.992426855318568*^9}, {
   3.992442263552492*^9, 3.9924422723505163`*^9}, {3.992444401984993*^9, 
   3.992444404463888*^9}, {3.9924444695823507`*^9, 3.992444477862547*^9}, {
   3.992445166462389*^9, 3.992445189506733*^9}, {3.992445224404346*^9, 
