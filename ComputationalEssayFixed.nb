Cell["Given the above equation, the torque on this point would be:", "Text",
 CellChangeTimes->{{3.992097266395308*^9, 3.9920972777812233`*^9}, {
  3.9920974531310387`*^9, 3.992097472807303*^9}, {3.992097745948107*^9, 
  3.9920981476796417`*^9}, {3.992421033765835*^9, 3.992421033879548*^9}, {
  3.992441390140338*^9, 3.9924413916989183`*^9}, {3.9925974258569527`*^9, 
  3.99259747202188*^9}, {3.992598757839549*^9, 3.99259875926333*^9}, {
  3.992601545006607*^9, 
  3.992601556366892*^9}},ExpressionUUID->"d56db766-fb12-db4c-b555-\
bb43619adfdd"],

Cell["\[Tau] = m*g*r*sin(\[Theta])", "Text",
 CellChangeTimes->{{3.992097266395308*^9, 3.9920972777812233`*^9}, {
  3.9920974531310387`*^9, 3.992097472807303*^9}, {3.992097745948107*^9, 
  3.9920981476796417`*^9}, {3.992421033765835*^9, 3.992421033879548*^9}, {
  3.992441390140338*^9, 3.9924413916989183`*^9}, {3.9925974258569527`*^9, 
  3.99259747202188*^9}, {3.992598757839549*^9, 3.99259875926333*^9}, {
  3.992601545006607*^9, 
  3.9926015577716312`*^9}},ExpressionUUID->"46312698-4ec2-254a-a9a0-\
f3cd6a6f0ebb"],

Cell[TextData[{
 "However, there can be a right triangle drawn from the point mass to the \
origin with the x and y coordinates as legs and r as the hypotenuse as the \
above diagram shows. This means that the sine of \[Theta] would be ",
 Cell[BoxData[
  FormBox[
   FractionBox["x", "r"], TraditionalForm]],ExpressionUUID->
  "26d6a054-48d8-fd4d-a066-8d6dd4d40b2b"],
 ". Plugging this into the above torque equation results in the following \
simplification:"
}], "Text",
 CellChangeTimes->{{3.992097266395308*^9, 3.9920972777812233`*^9}, {
  3.9920974531310387`*^9, 3.992097472807303*^9}, {3.992097745948107*^9, 
  3.9920981476796417`*^9}, {3.992421033765835*^9, 3.992421033879548*^9}, {
  3.992441390140338*^9, 3.9924413916989183`*^9}, {3.9925974258569527`*^9, 
  3.99259747202188*^9}, {3.992598757839549*^9, 3.99259875926333*^9}, {
  3.992601545006607*^9, 
  3.9926015634098988`*^9}},ExpressionUUID->"fa939282-e97b-f14e-9ff2-\
085f83755ffd"],

Cell[TextData[{
 "\[Tau] = m*g*r*sin(\[Theta])\n\[Tau] = m*g*r*",
 Cell[BoxData[
  FormBox[
   FractionBox["x", "r"], TraditionalForm]],ExpressionUUID->
  "a1ba5500-2d70-ec49-a3f9-d193428fa33a"],
 "\n\[Tau] = m*g*x"
}], "Text",
 CellChangeTimes->{{3.992097266395308*^9, 3.9920972777812233`*^9}, {
  3.9920974531310387`*^9, 3.992097472807303*^9}, {3.992097745948107*^9, 
  3.9920981476796417`*^9}, {3.992421033765835*^9, 3.992421033879548*^9}, {
  3.992441390140338*^9, 3.9924413916989183`*^9}, {3.9925974258569527`*^9, 
  3.99259747202188*^9}, {3.992598757839549*^9, 3.99259875926333*^9}, {
