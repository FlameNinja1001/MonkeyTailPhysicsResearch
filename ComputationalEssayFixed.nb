Cell[TextData[{
 "These ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "eecd2d6b-2c25-4cae-9b84-5832747a1989"],
