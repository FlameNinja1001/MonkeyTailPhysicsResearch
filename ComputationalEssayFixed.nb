 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "4"], TraditionalForm]],ExpressionUUID->
  "df14b460-9614-4663-a522-5cb566a0d011"],
 " also needed to be recalculated:"
}], "CodeText",
 CellChangeTimes->{{3.992112980302924*^9, 3.992113008635346*^9}, {
  3.992597634012143*^9, 
  3.992597645343742*^9}},ExpressionUUID->"80de1fa9-db8a-4e39-9b7c-\
662a7d45d3b1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"p4", " ", "=", " ", 
   RowBox[{"Midpoint", "[", 
    RowBox[{"{", 
     RowBox[{"p3", ",", "p5"}], "}"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9921130178423853`*^9, 3.992113023865211*^9}},
 CellLabel->"In[36]:=",ExpressionUUID->"79871fb7-7a08-4d36-a8dd-0b7a9cebb18d"],

Cell[TextData[{
 "I then solved for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "81a802e2-687b-4e68-9e76-987e0a416392"],
 ", but instead of using NSolve, I used Wolfram\[CloseCurlyQuote]s NMinimize \
function because there is multiple solutions.  NMinimize works by finding the \
values which make the objective, the square of the sum of the torques in this \
case, closest to zero. This will output an error value and each of the \
magnitudes for the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "852c0429-24c0-4af3-b195-878d52392eb8"],
 " values. As a minor note, when the error is nonzero value, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "66e35b1e-e25e-491a-b72d-d6f7a6a598ca"],
 " has no solutions. "
}], "Text",
 CellChangeTimes->{{3.992547379122067*^9, 3.9925474204969883`*^9}, {
   3.992597649024189*^9, 3.9925976631022453`*^9}, {3.992598445274379*^9, 
   3.992598492774729*^9}, {3.9925987033638906`*^9, 3.992598714361136*^9}, 
   3.9926025720055714`*^9, {3.992617131623021*^9, 3.992617137741784*^9}, {
   3.9926172904785213`*^9, 
   3.992617339643663*^9}},ExpressionUUID->"677c9297-04f6-41c6-81a4-\
d8910e53f5a0"],

Cell["\<\
NMinimize first begins with defining the squared sum of the torques to \
minimize:\
\>", "CodeText",
 CellChangeTimes->{{3.9925474252777452`*^9, 3.992547441425571*^9}, {
  3.992617168489149*^9, 
  3.9926171761198387`*^9}},ExpressionUUID->"e9eba98d-b7f7-4859-92f3-\
c25e2c3edde3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"objective", " ", "=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"torqueAtPoint", "[", 
       RowBox[{"mTail", ",", " ", "p4"}], "]"}], " ", "+", " ", 
      RowBox[{"torqueAtPoint", "[", 
       RowBox[{"mHead", ",", "p1"}], "]"}]}], ")"}], "^", "2"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{
  3.992547370180601*^9, {3.992547594535014*^9, 3.99254759534606*^9}},
 CellLabel->"In[37]:=",ExpressionUUID->"6a11525d-1049-4f67-854b-6c55baba48cd"],

Cell["I then defined constraints to prevent multiple solutions:", "CodeText",
 CellChangeTimes->{{3.992547449379689*^9, 3.992547468932815*^9}, {
  3.9925976653861933`*^9, 
  3.992597666984438*^9}},ExpressionUUID->"0aadf520-593b-4217-aeaa-\
b2d194a78a48"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"constraints", "=", 
  RowBox[{"0", "<=", "thetaAdj", "<=", "360"}]}]], "Input",
 CellChangeTimes->{{3.992547470492115*^9, 3.992547476581016*^9}, 
   3.992547598714168*^9},
 CellLabel->"In[38]:=",ExpressionUUID->"051daa58-e962-48bc-bfc2-a54d676528f7"],

Cell[BoxData[
 RowBox[{"0", "\[LessEqual]", "thetaAdj", "\[LessEqual]", "360"}]], "Output",
 CellChangeTimes->{3.9926245027077*^9, 3.992625150376067*^9, 
  3.9926253207824373`*^9, 3.992625391023344*^9, 3.992625606483548*^9, 
  3.992625662849145*^9},
 CellLabel->"Out[38]=",ExpressionUUID->"f618b1be-f8b3-45cd-9dc0-b87ea66baacf"]
}, Open  ]],

Cell[TextData[{
 "Now, given these values, I used NMinimize to find the solution that makes \
the squared error closest to zero, and instead of solving for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "f5a124cc-3633-4304-bbc8-382d8a0b9aaf"],
 ", I solved for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "90ee3413-0ab0-49f1-af43-bdb3ed44be2f"],
 ":"
}], "CodeText",
 CellChangeTimes->{{3.992113031538157*^9, 3.992113037122189*^9}, {
  3.992113169446151*^9, 3.992113205577938*^9}, {3.9925472824739857`*^9, 
  3.992547311785128*^9}, {3.992597668977108*^9, 3.992597672648374*^9}, {
  3.992602608044876*^9, 
  3.992602614409357*^9}},ExpressionUUID->"5ff8784c-8e31-408c-a32c-\
1f47c28a9b56"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"output", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"NMinimize", "[", "\n", "   ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"objective", ",", " ", "constraints"}], "}"}], ",", " ", 
      "thetaAdj"}], "\n", "   ", "]"}], "[", 
    RowBox[{"[", "2", "]"}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9921132253167562`*^9, 3.992113233084573*^9}, {
   3.992114935899324*^9, 3.992114936929109*^9}, 3.992115260419682*^9, 
   3.992123765791855*^9, {3.9921247463888397`*^9, 3.9921247465552263`*^9}, {
   3.992269602373124*^9, 3.9922696307091*^9}, 3.992547484289052*^9, 
   3.992547600846415*^9, {3.9926174373794394`*^9, 3.9926174537365437`*^9}},
 CellLabel->"In[39]:=",ExpressionUUID->"1b42b753-0c3d-4173-8045-89ba6a807bed"],

Cell[BoxData[
 RowBox[{"thetaAdj", "\[Rule]", "100.00000000026924`"}]], "Output",
