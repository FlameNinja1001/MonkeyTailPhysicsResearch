    Initialization:>({$CellContext`drawMonkey1[
         Pattern[$CellContext`thetaLean, 
          Blank[]]] := 
       Module[{$CellContext`p1, $CellContext`p2, $CellContext`p3, \
$CellContext`p4, $CellContext`p5, $CellContext`p6, $CellContext`p5Visual, \
$CellContext`p4Visual, $CellContext`dTailValue}, $CellContext`p6 = {0, 
           0}; $CellContext`p2 = {(-$CellContext`hHead) 
            Sin[$CellContext`thetaLean Degree], $CellContext`hHead 
            Cos[$CellContext`thetaLean 
              Degree]}; $CellContext`p3 = {(-$CellContext`hTail) 
            Sin[$CellContext`thetaLean Degree], $CellContext`hTail 
            Cos[$CellContext`thetaLean Degree]}; $CellContext`p1 = {
           Part[$CellContext`p2, 1] - $CellContext`dHead 
            Cos[$CellContext`thetaLean Degree], 
            Part[$CellContext`p2, 2] - $CellContext`dHead 
            Sin[$CellContext`thetaLean Degree]}; $CellContext`p5 = {
           Part[$CellContext`p3, 1] + $CellContext`dTail 
