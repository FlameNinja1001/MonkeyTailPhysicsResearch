   PlotRange->{{0, 960.}, {0, 960.}}]], "Input",ExpressionUUID->
  "e5826780-5450-488e-b354-708cd1c05d53"],
 "\nWe can define each as the following using the variables from earlier:\n\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "d0d30e95-7f11-4616-8125-f1bb93604596"],
 ": (-",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "head"], TraditionalForm]],ExpressionUUID->
  "fddbc233-a0ed-49a8-84d7-7f0381d89f43"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "head"], TraditionalForm]],ExpressionUUID->
  "2fe3be0c-43e1-4221-98e9-8477df44a455"],
 ")\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "930ba0b4-5e3a-4714-9df4-f341da1a2d1c"],
 ": (0,",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "head"], TraditionalForm]],ExpressionUUID->
  "afb4aa72-5ea7-4d5c-888a-57e18ab2abb3"],
 ")\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "ca49c433-ffb0-427e-9885-4dde604238f7"],
 ": (0,",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "tail"], TraditionalForm]],ExpressionUUID->
  "c1a089ac-812a-4e18-ad30-e570e5dba0bb"],
 ")\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "4"], TraditionalForm]],ExpressionUUID->
  "f0061bfa-cd62-4354-a74b-3b1b2fdc1a9a"],
 ": (",
 Cell[BoxData[
  FormBox[
   FractionBox[
    SubscriptBox["d", "tail"], "2"], TraditionalForm]],ExpressionUUID->
  "268bf7f8-b7b1-42d6-a08f-866bb6ff3772"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "tail"], TraditionalForm]],ExpressionUUID->
  "a53e1bbe-fb64-4818-8980-2ac50b355a9c"],
 ")\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "d3da099f-edd0-4721-932a-49302da72a22"],
 ": (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "1bf2e77e-36b4-4fce-ba17-ad163572da16"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["h", "tail"], TraditionalForm]],ExpressionUUID->
  "62d84c6d-517e-4759-817c-7ad19bfb6638"],
 ")\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "6"], TraditionalForm]],ExpressionUUID->
  "573196ad-1f40-461d-8649-16f596cc6302"],
 ": (0,0)\n\nThis is when our monkey is standing perfectly upright. However, \
our monkey will not always be standing perfectly upright. Thus, we need to \
factor in a 7th variable, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "ac5dd3f9-fee9-4a9b-9a26-da169fa411d1"],
 ". In our diagram and in Wolfram Language, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "cd8f5d41-b116-44a9-b44d-008fad1f1a8c"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "6"], TraditionalForm]],ExpressionUUID->
  "b6759a9d-7b4c-4927-9ae8-a51ef5ae2f90"],
