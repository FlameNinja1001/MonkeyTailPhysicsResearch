9ce7768b7891"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"thetaVarsFuncEval", "[", 
    RowBox[{
    "numPoints_Integer", ",", " ", "thetaLean_Real", ",", " ", 
     "thetaAdjEval_List"}], "]"}], " ", ":=", " ", "\n", "\t", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "firstTheta", "}"}], ",", "\n", "\t    ", 
     RowBox[{
      RowBox[{"If", "[", "\n", "\t\t    ", 
       RowBox[{
        RowBox[{"thetaLean", " ", ">=", " ", "0"}], ",", " ", "\n", 
        "\t\t    ", 
        RowBox[{"firstTheta", " ", "=", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Pi", "/", "2"}], " ", "+", " ", "thetaLean"}], ")"}], 
          " ", "-", " ", 
          RowBox[{"thetaAdjEval", "[", 
           RowBox[{"[", "1", "]"}], "]"}]}]}], ",", " ", "\n", "\t\t    ", 
        RowBox[{"firstTheta", " ", "=", " ", 
         RowBox[{"thetaLean", " ", "+", " ", 
          RowBox[{"thetaAdjEval", "[", 
           RowBox[{"[", "1", "]"}], "]"}], " ", "-", " ", 
          RowBox[{"Pi", "/", "2"}]}]}]}], "\n", "\t\t", "]"}], ";", " ", "\n",
       "\t\t", 
      RowBox[{"Table", "[", "\n", "\t\t\t", 
       RowBox[{
        RowBox[{"Which", "[", "\n", "\t\t\t\t", 
         RowBox[{
          RowBox[{"n", "==", "1"}], ",", " ", "\n", "\t\t\t\t", "firstTheta", 
          ",", "\n", "\t\t\t\t", "True", ",", "\n", "\t\t\t\t", 
          RowBox[{
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{"thetaAdjEval", "[", 
              RowBox[{"[", "m", "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"m", ",", " ", "2", ",", " ", "n"}], "}"}]}], "]"}], "+",
            " ", "firstTheta"}]}], "]"}], ",", " ", "\n", "\t\t\t", 
        RowBox[{"{", 
         RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], "\n", 
       "\t\t", "]"}]}]}], "\n", "\t", "]"}]}], ";"}]], "Code",
 CellChangeTimes->{
  3.9924393186122637`*^9, {3.99251307054809*^9, 3.992513081000947*^9}, {
   3.992592562594407*^9, 3.992592564415525*^9}, {3.9926033699373207`*^9, 
   3.992603405717531*^9}, {3.992623571880064*^9, 3.992623596794859*^9}},
 CellLabel->"In[69]:=",ExpressionUUID->"32595228-7bc8-4c1b-9cdc-fba365b2aa9b"],

