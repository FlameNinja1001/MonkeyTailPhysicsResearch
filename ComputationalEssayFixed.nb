         0 < $CellContext`thetaAdjV59[4] < 2 Pi, 
         0 < $CellContext`thetaAdjV59[5] < 2 Pi, 
         0 < $CellContext`thetaAdjV59[6] < 
         2 Pi}, $CellContext`objective = (-5.433097476764412 + 
         8.25 Cos[1.9943951023931954` - $CellContext`thetaAdjV59[1]] + 
         6.75 Cos[
           1.9943951023931954` - $CellContext`thetaAdjV59[
            1] + $CellContext`thetaAdjV59[2]] + 
         5.25 Cos[
           1.9943951023931954` - $CellContext`thetaAdjV59[
            1] + $CellContext`thetaAdjV59[2] + $CellContext`thetaAdjV59[3]] + 
         3.75 Cos[
           1.9943951023931954` - $CellContext`thetaAdjV59[
            1] + $CellContext`thetaAdjV59[2] + $CellContext`thetaAdjV59[
             3] + $CellContext`thetaAdjV59[4]] + 
         2.25 Cos[
           1.9943951023931954` - $CellContext`thetaAdjV59[
            1] + $CellContext`thetaAdjV59[2] + $CellContext`thetaAdjV59[
             3] + $CellContext`thetaAdjV59[4] + $CellContext`thetaAdjV59[5]] + 
         0.75 Cos[
           1.9943951023931954` - $CellContext`thetaAdjV59[
            1] + $CellContext`thetaAdjV59[2] + $CellContext`thetaAdjV59[
             3] + $CellContext`thetaAdjV59[4] + $CellContext`thetaAdjV59[
             5] + $CellContext`thetaAdjV59[6]])^2, $CellContext`output = {
        8.945390984904199*^-19, {$CellContext`thetaAdjV59[1] -> 
          0.8852716478648747, $CellContext`thetaAdjV59[2] -> 
          0.08570330678052127, $CellContext`thetaAdjV59[3] -> 
          0.18595970091401054`, $CellContext`thetaAdjV59[4] -> 
          0.2620319983565462, $CellContext`thetaAdjV59[5] -> 
          0.33097501752475766`, $CellContext`thetaAdjV59[6] -> 
          0.43919014040365584`}}, $CellContext`error = 
       8.945365783726923*^-19, $CellContext`thetaAdjs = {0.8852716478648747, 
        0.08570330678052127, 0.18595970091401054`, 0.2620319983565462, 
        0.33097501752475766`, 0.43919014040365584`}, $CellContext`thetas = {
        1.1091234545283206`, 1.194826761308842, 1.3807864622228525`, 
        1.6428184605793987`, 1.9737934781041564`, 
        2.412983618507812}, $CellContext`thetaVarsFuncEval[
         Pattern[$CellContext`numPoints, 
