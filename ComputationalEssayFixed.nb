    Selectable->False],
   DefaultBaseStyle->"ImageGraphics",
   ImageSizeRaw->{960., 960.},
   PlotRange->{{0, 960.}, {0, 960.}}]], "Input",ExpressionUUID->
  "8a03aed0-28d4-4445-aa4c-0e7477946d4a"],
 "\nIf we draw a vertical line from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "8bf25ce1-643b-4814-9e41-b3441492a560"],
 ", we can see that it\[CloseCurlyQuote]s parallel to the line which defines ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "d96c9d3b-29dd-42e8-b5e6-6979314c0aca"],
 ". By alternate interior angles, this means that it\[CloseCurlyQuote]s \
congruent to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "1dd39891-b115-44d7-aa4a-bfbb666adaf2"],
 " . Since the line between ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "c3bbb9bb-abed-4897-bf63-c892b7c0e10e"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "61060f54-2a82-4a23-9168-3d7cbfcf5ad3"],
 " is 90 degrees, we can define the complementary angle as 90-",
 Cell[BoxData[
  FormBox[
   FormBox[
    SubscriptBox["\[Theta]", "lean"],
    TraditionalForm], TraditionalForm]],ExpressionUUID->
  "0bd0dbd7-b677-4cd8-9254-c7434cb7ceb3"],
 ". However, since this new angle of 90-",
 Cell[BoxData[
  FormBox[
   FormBox[
    SubscriptBox["\[Theta]", "lean"],
    TraditionalForm], TraditionalForm]],ExpressionUUID->
  "1f40bede-0d3b-4cec-a5d3-2b3c111e5f6c"],
 " is ALSO complementary to the missing angle of our right triangle (marked \
in red), we can simply define the triangle\[CloseCurlyQuote]s angle as ",
 Cell[BoxData[
  FormBox[
   FormBox[
    SubscriptBox["\[Theta]", "lean"],
    TraditionalForm], TraditionalForm]],ExpressionUUID->
  "20081b1c-346e-4b42-b333-793c4359198f"],
