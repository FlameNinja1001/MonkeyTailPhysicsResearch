Cell[TextData[{
 "Next comes the coordinates for the endpoints of the head and tail, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "bcb37617-007b-4b1f-a7fc-ad82b3a19c98"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "170ec899-2e57-4b1c-988b-6d0911bfb754"],
 " respectively. These are slightly more complicated, needing more \
trigonometry as well as being translations from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "27e8b4bb-9d78-48a7-b5ee-9d9b3e76321d"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "150efbcb-29da-4c2d-a588-c098e791b305"],
 ". I began with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "1"], TraditionalForm]],ExpressionUUID->
  "d31ea96a-904d-4f35-9e2b-f4f93f5e5e20"],
 "."
}], "Text",
