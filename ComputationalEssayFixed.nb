Cell["\<\
With the center of masses defined, I set up the torque equilibrium equation \
from the past two models. Before doing that, however, I redefined the masses. \
Mass is a similar constant to distance, in that in real tails, it changes \
between joints. For simplicity\[CloseCurlyQuote]s sake, however, I defined it \
as a single constant:\
\>", "Text",
 CellChangeTimes->{{3.9924297840613823`*^9, 3.992429835642281*^9}, {
  3.992429979252898*^9, 3.992429986050687*^9}, {3.9924300328885393`*^9, 
  3.992430126788211*^9}, {3.992430162063816*^9, 3.9924301819042253`*^9}, {
  3.992442435188746*^9, 3.99244244334699*^9}, {3.992598326203429*^9, 
  3.992598346075508*^9}, {3.992598733855364*^9, 3.992598736831396*^9}, {
  3.9926032546824703`*^9, 
  3.9926032602035103`*^9}},ExpressionUUID->"e2378fb8-b6f6-4f47-a41e-\
ec8967497bda"],

Cell["\<\
Using the ConstantArray function to create an n-sized list of masses:\
\>", "CodeText",
 CellChangeTimes->{{3.9924424474598503`*^9, 
  3.9924424667295837`*^9}},ExpressionUUID->"216e8ca5-57b9-4141-9130-\
e1f869d0f251"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mTailConst", " ", "=", " ", "8"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"listOfMasses", " ", "=", " ", 
  RowBox[{"Table", "[", 
   RowBox[{"mTailConst", ",", " ", "numPoints"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.992430201586566*^9, 3.992430203436946*^9}, 
   3.9924390585182323`*^9, {3.992592470770549*^9, 3.992592481818815*^9}},
 CellLabel->"In[78]:=",ExpressionUUID->"53812b31-833a-4f83-b811-91d1eeb7fd80"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"8", ",", "8", ",", "8", ",", "8", ",", "8", ",", "8"}], 
  "}"}]], "Output",
 CellChangeTimes->{
  3.992439058785111*^9, {3.99243968046132*^9, 3.992439682144813*^9}, 
   3.99244276627492*^9, 3.992509669066792*^9, 3.992513099980969*^9, 
   3.992545393908687*^9, 3.99254553276812*^9, 3.9925456372889843`*^9, 
   3.992545758278524*^9, {3.992547168522155*^9, 3.9925471850554667`*^9}, 
   3.992547586763054*^9, 3.992554350851391*^9, 3.992591781259225*^9, {
   3.992592472272389*^9, 3.992592482526174*^9}, 3.992592733857678*^9, 
   3.992593902580001*^9, 3.9925963144336023`*^9, 3.992608764299651*^9},
 CellLabel->"Out[79]=",ExpressionUUID->"c6e737d5-4fb4-4e4b-96c3-79a72f1540de"]
}, Open  ]],

Cell["\<\
I needed to slightly tweak it from the previous two models because the tail \
now has multiple joints. The torque on the tail now is a summation of the \
torque of every individual joint of the tail. This can be represented by the \
following:\
\>", "Text",
 CellChangeTimes->{{3.9924297840613823`*^9, 3.992429835642281*^9}, {
  3.992429979252898*^9, 3.992429986050687*^9}, {3.9924300328885393`*^9, 
  3.992430126788211*^9}, {3.992430162063816*^9, 3.992430178918331*^9}, {
  3.992430333248941*^9, 3.9924303736643457`*^9}, {3.992430412941063*^9, 
  3.992430481540447*^9}, {3.992430522211628*^9, 3.992430532630219*^9}, {
  3.9924424767413387`*^9, 3.9924424862241917`*^9}, {3.9925983497675037`*^9, 
  3.9925983531209393`*^9}, {3.9926032743732166`*^9, 
  3.9926033010374184`*^9}},ExpressionUUID->"2ecec401-c4ef-4aa7-8d41-\
de92a3e4bac7"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["\[Sum]", TraditionalForm]],ExpressionUUID->
  "c7f848e1-3b2f-814a-98ea-c58538596548"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "04a12140-8841-9449-8a6e-836369085388"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "1"], TraditionalForm]],ExpressionUUID->
  "9d589aaa-383f-ec4e-b202-904e2de0146d"],
 ".x * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "837eb154-c072-1e41-9a4e-4af772e5225a"],
 " + ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "2"], TraditionalForm]],ExpressionUUID->
  "67cbf15f-60a3-a34a-a73c-72086b955323"],
 ".x * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "10d52fa0-0d4b-7644-b31e-44b849a2e14b"],
 " + ... +  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "n"], TraditionalForm]],ExpressionUUID->
  "846b31b4-4698-9b4d-8a79-540ef17f7706"],
 ".x * ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "f7af3c7b-3910-dc47-bb3e-c078fc8bdf01"]
}], "Text",
 CellChangeTimes->{{3.9924297840613823`*^9, 3.992429835642281*^9}, {
  3.992429979252898*^9, 3.992429986050687*^9}, {3.9924300328885393`*^9, 
  3.992430126788211*^9}, {3.992430162063816*^9, 3.992430178918331*^9}, {
  3.992430333248941*^9, 3.9924303736643457`*^9}, {3.992430412941063*^9, 
  3.992430481540447*^9}, {3.992430522211628*^9, 3.992430532630219*^9}, {
  3.9924424767413387`*^9, 3.9924424862241917`*^9}, {3.9925983497675037`*^9, 
  3.9925983531209393`*^9}, {3.9926032743732166`*^9, 
  3.992603282665472*^9}},ExpressionUUID->"4a9672eb-41b2-b548-9b2d-\
41a64c51d5dd"],

Cell["\<\
Implementing the summation in Wolfram Language by creating a list for each \
torque, and then summing them up using the Total function:\
\>", "CodeText",
 CellChangeTimes->{
  3.9924424909473658`*^9},ExpressionUUID->"0fe02ea9-809e-4a33-961f-\
8faa2d03ff50"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"torqueVars", " ", "=", " ", 
    RowBox[{"Table", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"torqueAtPoint", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"listOfMasses", "[", 
         RowBox[{"[", "n", "]"}], "]"}], ",", " ", 
        RowBox[{"mVars", "[", 
         RowBox[{"[", "n", "]"}], "]"}]}], "]"}], ",", " ", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Total", "[", "torqueVars", "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.992430537815002*^9, 3.992430544191409*^9}, {
  3.992592504839736*^9, 3.992592513579604*^9}, {3.992603307311762*^9, 
  3.9926033178954334`*^9}},
 CellLabel->"In[80]:=",ExpressionUUID->"e4e4e279-13a3-4a91-babb-b5aa386f0844"],

Cell["\<\
Now, to create the equilibrium, I added this total torque to the torque on \
the head, and set it equal to zero:\
\>", "Text",
 CellChangeTimes->{{3.992430546160564*^9, 3.992430574793579*^9}, {
   3.992430647446924*^9, 3.992430686038555*^9}, {3.9924307408162403`*^9, 
   3.992430754278891*^9}, {3.9924385025856943`*^9, 3.992438584663288*^9}, {
   3.992438640573579*^9, 3.992438675778263*^9}, {3.9924389067790003`*^9, 
   3.9924389453976717`*^9}, {3.9924425400360193`*^9, 
   3.9924425947238703`*^9}, {3.9925983574591312`*^9, 3.992598382559623*^9}, 
   3.9926033217682343`*^9},ExpressionUUID->"74f9e66d-0215-461c-b450-\
4f6937391077"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],ExpressionUUID->
  "b0ba972b-538d-fa43-aac8-ef0dec9c1add"],
 " + ",
 Cell[BoxData[
  FormBox["\[Sum]", TraditionalForm]],ExpressionUUID->
  "6da82aa2-901c-df47-b2f5-71b8c7d8804c"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "c93f2b3d-0cdb-d74b-b926-793aad78a9bc"],
 " = 0"
}], "Text",
 CellChangeTimes->{{3.992430546160564*^9, 3.992430574793579*^9}, {
   3.992430647446924*^9, 3.992430686038555*^9}, {3.9924307408162403`*^9, 
