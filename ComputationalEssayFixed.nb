   3.9925500643330593`*^9, 3.992550070122388*^9}, {3.992550108511402*^9, 
   3.9925501573482647`*^9}, {3.992550206670268*^9, 3.992550209377697*^9}, {
   3.992550251081251*^9, 3.992550252903345*^9}, {3.992550301060635*^9, 
   3.992550354970546*^9}, {3.992550388331648*^9, 3.992550468260149*^9}, {
   3.992550715785241*^9, 3.992550721554553*^9}, {3.992550879200548*^9, 
