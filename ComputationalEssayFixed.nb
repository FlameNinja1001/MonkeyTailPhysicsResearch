e9e8b823ae65"],

Cell[TextData[{
 "Creating symbolic values for the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "73979d23-9493-455c-99ae-c70d605607bb"],
 " values to be solved later:"
}], "CodeText",
 CellChangeTimes->{{3.99244218764997*^9, 
  3.9924422131880302`*^9}},ExpressionUUID->"5c1c7f39-efaa-40c4-b752-\
6c402482b431"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "thetaAdjVars", "]"}], "\n", 
 RowBox[{"thetaAdjVars", "=", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"thetaAdj", "[", "n", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "1", ",", "numPoints"}], "}"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9924250319804783`*^9, 3.992425065090556*^9}, 
   3.992439049294832*^9, {3.992442194412589*^9, 3.992442194841529*^9}},
 CellLabel->
  "In[336]:=",ExpressionUUID->"42701554-20b5-466c-8e9c-acb71409dade"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"thetaAdj", "[", "1", "]"}], ",", 
   RowBox[{"thetaAdj", "[", "2", "]"}], ",", 
   RowBox[{"thetaAdj", "[", "3", "]"}], ",", 
   RowBox[{"thetaAdj", "[", "4", "]"}]}], "}"}]], "Output",
 CellChangeTimes->{
  3.9924390496155443`*^9, {3.992439680014943*^9, 3.992439681695715*^9}, 
   3.9924427657548428`*^9, 3.9925096686521482`*^9, 3.992513099408698*^9, 
   3.992545393335696*^9, 3.992545532267812*^9, 3.992545636799457*^9, 
   3.992545757689742*^9, {3.992547167987108*^9, 3.992547184537386*^9}},
 CellLabel->
  "Out[337]=",ExpressionUUID->"4560d28e-519a-46da-9841-12169e074aeb"]
}, Open  ]],

Cell[TextData[{
 "We need to now establish a formula for getting the coordinates of the next \
point in the tail using ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "0fcff175-351d-4b3b-9647-f9f781485ea4"],
 ". To do this for the single jointed tail prior we used trigonometry and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "aaec2160-bd18-4cea-99c6-8a52bf8b1480"],
 ". This works for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj1"], TraditionalForm]],ExpressionUUID->
  "963a749d-52ab-4b2c-9d2c-7275f269fcec"],
 " but no other subsequent angles. Thus, due to this discrepancy, we will \
establish a new variable type, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "n"], TraditionalForm]],ExpressionUUID->
  "b7744f05-b430-42c0-96bc-8453a727c7f7"],
 ". ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "n"], TraditionalForm]],ExpressionUUID->
  "0f301eea-bf64-4a6e-8dcb-8282013fb9de"],
 " is the angle of the triangle used to compute the next point of the line. \
In our single jointed tail, what is now called ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "1"], TraditionalForm]],ExpressionUUID->
  "861a19d5-684c-44eb-bef5-82f19e4f223e"],
 " had previously been computed as the following:\n\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "1"], TraditionalForm]],ExpressionUUID->
  "205e1e57-ae49-4087-a426-471859bbdba2"],
 "  = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Theta]", "adj1"], " ", "-", " ", 
    RowBox[{"(", 
     RowBox[{"90", "+", 
      SubscriptBox["\[Theta]", "lean"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"edb90b1f-1d2d-4fcb-a658-47d441a16f17"],
 "\n\nWe can see this again in the following diagram with the same setup as \
V2:\n",
 Cell[BoxData[
  GraphicsBox[
