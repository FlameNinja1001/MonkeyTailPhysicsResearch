Cell["\<\
We notice that sometimes, the values give two outputs. To get around this, we \
always take the last one:\
\>", "Text",
 CellChangeTimes->{{3.9921245223704576`*^9, 3.9921245266929607`*^9}, {
  3.992124593087101*^9, 
  3.9921246012795467`*^9}},ExpressionUUID->"3ca5bd47-140f-4a4e-88fd-\
39fb5cdbe051"],

