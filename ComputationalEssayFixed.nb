            1] + $CellContext`thetaAdjV59[2] + $CellContext`thetaAdjV59[3]] + 
         1.5 Cos[1.9943951023931954` - $CellContext`thetaAdjV59[
            1] + $CellContext`thetaAdjV59[2] + $CellContext`thetaAdjV59[
             3] + $CellContext`thetaAdjV59[4]] + 
         1.5 Cos[1.9943951023931954` - $CellContext`thetaAdjV59[
            1] + $CellContext`thetaAdjV59[2] + $CellContext`thetaAdjV59[
             3] + $CellContext`thetaAdjV59[4] + $CellContext`thetaAdjV59[5]] + 
         0.75 Cos[
           1.9943951023931954` - $CellContext`thetaAdjV59[
            1] + $CellContext`thetaAdjV59[2] + $CellContext`thetaAdjV59[
             3] + $CellContext`thetaAdjV59[4] + $CellContext`thetaAdjV59[
             5] + $CellContext`thetaAdjV59[6]]}, $CellContext`torqueAtPoint[
         Pattern[$CellContext`mass, 
          Blank[]], 
         Pattern[$CellContext`coord, 
          Blank[]]] := $CellContext`mass 
        Part[$CellContext`coord, 1], $CellContext`pH = {-2.055219038381317, 
        4.558077961627573}, $CellContext`mH = {-2.9668346307068316`, 
