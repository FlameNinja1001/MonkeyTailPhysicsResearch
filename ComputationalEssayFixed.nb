Cell[TextData[{
 "In model V1, recall ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "d5159bfd-5199-4ece-824b-616d1c0d200b"],
 " was defined as the following:"
}], "Text",
 CellChangeTimes->{{3.9921006037133503`*^9, 3.992100622324725*^9}, {
  3.992112560594152*^9, 3.992112565902768*^9}, {3.992112666101972*^9, 
  3.992112771642489*^9}, {3.9921128088760357`*^9, 3.992112976802414*^9}, {
  3.992113080218974*^9, 3.992113106086329*^9}, {3.992426992229374*^9, 
  3.9924269945582542`*^9}, {3.992441851560953*^9, 3.99244185371099*^9}, {
  3.99244196607198*^9, 3.992441971152405*^9}, {3.992547219500305*^9, 
  3.99254727054673*^9}, {3.99255454013698*^9, 3.992554551305415*^9}, {
  3.992591199570836*^9, 3.992591335034568*^9}, {3.992591417807701*^9, 
  3.992591507651742*^9}, {3.9925976066891727`*^9, 3.9925976296804457`*^9}, {
  3.992601591631201*^9, 3.992601606145481*^9}, {3.992616906365859*^9, 
  3.9926169071139097`*^9}},ExpressionUUID->"e44cd494-9b67-4efd-9edb-\
9d2c98f7e2e5"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "5"], TraditionalForm]],ExpressionUUID->
  "aaf48f4b-27d7-4d3b-8cce-3ccbd8e6f8fc"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "3"], TraditionalForm]],ExpressionUUID->
  "42ec01c0-dccc-4804-bbde-b5dc0004f7ec"],
 " + (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "08595733-5c90-437d-8a6d-b2c555e4ab90"],
 " \:22c5 cos(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "d5c16e1a-c6b4-4af6-9b72-bf55b7741ba8"],
 "), ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "tail"], TraditionalForm]],ExpressionUUID->
  "72c7da4b-58b9-42a1-ad60-d50e5da1fa57"],
 " \:22c5 sin(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "eee28e23-d3ac-4d1c-8d78-def7bd434c3e"],
 "))"
}], "Text",
 CellChangeTimes->{{3.9921006037133503`*^9, 3.992100622324725*^9}, {
  3.992112560594152*^9, 3.992112565902768*^9}, {3.992112666101972*^9, 
  3.992112771642489*^9}, {3.9921128088760357`*^9, 3.992112976802414*^9}, {
  3.992113080218974*^9, 3.992113106086329*^9}, {3.992426992229374*^9, 
  3.9924269945582542`*^9}, {3.992441851560953*^9, 3.99244185371099*^9}, {
  3.99244196607198*^9, 3.992441971152405*^9}, {3.992547219500305*^9, 
  3.99254727054673*^9}, {3.99255454013698*^9, 3.992554551305415*^9}, {
  3.992591199570836*^9, 3.992591335034568*^9}, {3.992591417807701*^9, 
  3.992591507651742*^9}, {3.9925976066891727`*^9, 3.9925976296804457`*^9}, {
  3.992601591631201*^9, 3.992601609552702*^9}, {3.992614910178458*^9, 
  3.9926149152233353`*^9}},ExpressionUUID->"bd45b2dd-82bd-41a1-9232-\
aa238cd8e0c2"],

Cell[TextData[{
 "However, as this diagram shows, because the angle to calculate isn\
\[CloseCurlyQuote]t a right angle anymore, it\[CloseCurlyQuote]s not ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "fd1d3539-b43e-4e35-a38b-42e1ff3fb9aa"],
 " exactly. The angle can still be defined, however, using the newly \
introduced adjustment angle, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "79872241-6a74-4190-b59c-2edd05717bf0"],
 ". It\[CloseCurlyQuote]s shown in the image that the angle for the triangle, \
as well as ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "ff1f0b5b-703f-40a3-a7c6-ac3d19b5c062"],
 ", are part of a larger angle defined by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "lean"], TraditionalForm]],ExpressionUUID->
  "6f289236-dbb4-477d-83be-ae84bbb92db1"],
 " and a right angle. Knowing that, I subtracted  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "3d42bbc2-bd1b-46c7-b236-2f9492103d58"],
 " from the larger angle to get it and then solve for the remaining parts of \
the model:"
}], "Text",
 CellChangeTimes->{{3.9921006037133503`*^9, 3.992100622324725*^9}, {
