Cell[TextData[{
 "Using the above formula to calculate for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "2"], TraditionalForm]],ExpressionUUID->
  "9b7b498a-487a-4ff1-8190-0170d4973ef8"],
 " based on the constants:"
}], "CodeText",
