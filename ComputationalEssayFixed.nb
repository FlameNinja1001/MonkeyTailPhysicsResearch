$CellContext`p1$$] == -$CellContext`torqueAtPoint[$CellContext`mTail, \
$CellContext`p4$$], 0 <= $CellContext`thetaAdj <= 
               180], $CellContext`thetaAdj]]]]; $CellContext`p5Visual$$ = {
