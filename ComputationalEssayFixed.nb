Cell["\<\
This formula can be implemented in the Wolfram Language using Table:\
\>", "CodeText",
 CellChangeTimes->{{3.992442303839573*^9, 3.992442319230948*^9}, {
  3.9926191287807627`*^9, 
  3.9926191795128727`*^9}},ExpressionUUID->"905660d8-22c8-476b-b44c-\
22157cc4ae1b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"pVarsFunc", "[", 
    RowBox[{
    "numPoints_Integer", ",", " ", "hTail_Real", ",", " ", "thetaLean_Real", ",",
      " ", "distances_List", ",", " ", "theta_List"}], "]"}], " ", ":=", " ", 
   "\n", "\t", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "p", "}"}], ",", "\n", "\t\t", 
     RowBox[{"Table", "[", "\n", "\t\t\t", 
      RowBox[{
       RowBox[{"Which", "[", "\n", "\t\t\t\t", 
        RowBox[{
         RowBox[{"n", "==", "1"}], ",", " ", "\n", "\t\t\t\t", 
         RowBox[{"p", " ", "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "hTail"}], "*", 
             RowBox[{"Sin", "[", "thetaLean", "]"}]}], ",", " ", 
            RowBox[{"hTail", "*", 
             RowBox[{"Cos", "[", "thetaLean", "]"}]}]}], "}"}]}], ",", "\n", 
         "\t\t\t\t", 
         RowBox[{"n", ">=", "2"}], ",", " ", "\n", "\t\t\t\t", 
         RowBox[{"p", " ", "+=", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"distances", "[", 
              RowBox[{"[", 
               RowBox[{"n", "-", "1"}], "]"}], "]"}], "*", 
             RowBox[{"Cos", "[", 
              RowBox[{"theta", "[", 
               RowBox[{"[", 
                RowBox[{"n", "-", "1"}], "]"}], "]"}], "]"}]}], ",", " ", 
            "\n", "\t\t\t\t\t", 
            RowBox[{
             RowBox[{"distances", "[", 
              RowBox[{"[", 
               RowBox[{"n", "-", "1"}], "]"}], "]"}], "*", 
             RowBox[{"Sin", "[", 
              RowBox[{"theta", "[", 
               RowBox[{"[", 
                RowBox[{"n", "-", "1"}], "]"}], "]"}], "]"}]}]}], "}"}]}]}], 
        "]"}], ",", "\n", "\t\t\t\t", 
       RowBox[{"{", 
        RowBox[{"n", ",", " ", "1", ",", " ", 
         RowBox[{"numPoints", "+", "1"}]}], "}"}]}], "\n", "\t\t\t", "]"}]}], 
    "\n", "\t", "]"}]}], ";"}]], "Code",
 CellChangeTimes->{{3.99242881265384*^9, 3.992428815441949*^9}, 
   3.9925924132613077`*^9, {3.9926031096604404`*^9, 3.9926031556550617`*^9}, {
   3.992619037756507*^9, 3.992619045872539*^9}},
 CellLabel->"In[55]:=",ExpressionUUID->"c9d7a021-2c97-43c3-aa8d-527410e71b55"],

Cell["\<\
With the points solved for, I algorithmically calculated the center of \
masses. Each center of mass is simply the midpoint between the endpoints of a \
joint. Thus, I used the following formula knowing that there is n+1 total \
number of points:\
\>", "Text",
 CellChangeTimes->{{3.99242681595566*^9, 3.9924268316542253`*^9}, {
   3.9924269672537317`*^9, 3.992426985349269*^9}, {3.992427058181831*^9, 
   3.992427196925643*^9}, {3.992427243838944*^9, 3.992427256946658*^9}, {
   3.9924283426062813`*^9, 3.9924283632840357`*^9}, {3.992428440914689*^9, 
   3.992428508029765*^9}, {3.9924285875910263`*^9, 3.992428592161234*^9}, {
   3.992428694607253*^9, 3.992428800596725*^9}, {3.992429431698173*^9, 
   3.992429448344366*^9}, {3.992429538396015*^9, 3.992429545007667*^9}, {
   3.9924295889379663`*^9, 3.99242969743328*^9}, {3.9924423262708597`*^9, 
   3.992442349004857*^9}, {3.9925983032479362`*^9, 3.992598320809457*^9}, 
   3.9926031646151886`*^9},ExpressionUUID->"80e5a7f3-5fb0-41ba-9d56-\
96c4a4d28ea6"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "n"], " "}], TraditionalForm]],ExpressionUUID->
  "7d416fe8-0e33-4eac-bd99-92c3919ebf8b"],
 "=  midpoint(",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "n"], TraditionalForm]],ExpressionUUID->
  "9b8d2eb5-c164-43bd-93ea-c94fe6fa1e94"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", 
    RowBox[{"n", "+", "1"}]], TraditionalForm]],ExpressionUUID->
  "1b016c0c-f954-42f8-9c85-7dd935d0d3de"],
 ")"
}], "Text",
 CellChangeTimes->{{3.99242681595566*^9, 3.9924268316542253`*^9}, {
  3.9924269672537317`*^9, 3.992426985349269*^9}, {3.992427058181831*^9, 
  3.992427196925643*^9}, {3.992427243838944*^9, 3.992427256946658*^9}, {
  3.9924283426062813`*^9, 3.9924283632840357`*^9}, {3.992428440914689*^9, 
  3.992428508029765*^9}, {3.9924285875910263`*^9, 3.992428592161234*^9}, {
  3.992428694607253*^9, 3.992428800596725*^9}, {3.992429431698173*^9, 
  3.992429448344366*^9}, {3.992429538396015*^9, 3.992429545007667*^9}, {
  3.9924295889379663`*^9, 3.99242969743328*^9}, {3.9924423262708597`*^9, 
  3.992442349004857*^9}, {3.9925983032479362`*^9, 
  3.992598320809457*^9}},ExpressionUUID->"dd4cb5be-70ba-4a0c-a489-\
6c9e85d4247d"],

Cell["\<\
Using Wolfram\[CloseCurlyQuote]s built-in Midpoint function to compute the \
center of masses, which depend on thetaVars and pVars:\
\>", "CodeText",
 CellChangeTimes->{
  3.99244235691253*^9, {3.992592435614058*^9, 3.992592435732904*^9}, {
   3.992619236323208*^9, 
   3.9926192506400347`*^9}},ExpressionUUID->"d0ce0740-a7fa-4a41-ac00-\
9da6ab0a28bc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"thetaVars", ",", " ", "thetaAdjVars"}], "}"}], " ", "=", " ", 
   RowBox[{"thetaVarsFunc", "[", 
    RowBox[{"numPoints", ",", " ", "thetaLean"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pVars", " ", "=", " ", 
   RowBox[{"pVarsFunc", "[", 
    RowBox[{
    "numPoints", ",", " ", "hTail", ",", " ", "thetaLean", ",", " ", 
     "listOfDistances", ",", " ", "thetaVars"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"mVars", " ", "=", " ", 
   RowBox[{"Table", "[", "\n", "\t", 
    RowBox[{
     RowBox[{"Midpoint", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"pVars", "[", 
         RowBox[{"[", "n", "]"}], "]"}], ",", " ", 
        RowBox[{"pVars", "[", 
         RowBox[{"[", 
          RowBox[{"n", "+", "1"}], "]"}], "]"}]}], "}"}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], "\n", 
    "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.992429706480315*^9, 3.992429708289136*^9}, {
  3.9925924374874973`*^9, 3.992592439013946*^9}, {3.992593257462973*^9, 
  3.992593261931279*^9}, {3.992618908722103*^9, 3.992618930626692*^9}, {
  3.992618998434943*^9, 3.992618998635353*^9}, {3.9926244265017357`*^9, 
  3.992624441942831*^9}},
 CellLabel->"In[56]:=",ExpressionUUID->"f18bbd31-5909-438f-9438-9cef0417318b"],

Cell["\<\
With the center of masses defined, I set up the torque equilibrium equation \
from the past two models. In contrast to real tails, where mass varies per \
joint, in this model, for simplicity\[CloseCurlyQuote]s sake, mass is \
constant between joints:\
\>", "Text",
 CellChangeTimes->{{3.9924297840613823`*^9, 3.992429835642281*^9}, {
   3.992429979252898*^9, 3.992429986050687*^9}, {3.9924300328885393`*^9, 
   3.992430126788211*^9}, {3.992430162063816*^9, 3.9924301819042253`*^9}, {
   3.992442435188746*^9, 3.99244244334699*^9}, {3.992598326203429*^9, 
   3.992598346075508*^9}, {3.992598733855364*^9, 3.992598736831396*^9}, {
   3.9926032546824703`*^9, 3.9926032602035103`*^9}, 3.992619319345961*^9, {
   3.992619352505362*^9, 
   3.99261939595233*^9}},ExpressionUUID->"1a5b1a7f-8c4c-4fa3-b9d9-\
482be0d2776e"],

Cell[TextData[{
 "Using the Table function to create an ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "cb179920-4bea-4c48-a5b5-8e577a0982f4"],
 "-sized list of masses:"
}], "CodeText",
 CellChangeTimes->{{3.9924424474598503`*^9, 3.9924424667295837`*^9}, {
  3.992619263370557*^9, 
  3.992619285828122*^9}},ExpressionUUID->"9f9a61ed-02d8-43ef-abd9-\
607c239af5bd"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mTailConst", " ", "=", " ", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"listOfMasses", " ", "=", " ", 
  RowBox[{"Table", "[", 
   RowBox[{"mTailConst", ",", " ", "numPoints"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.992430201586566*^9, 3.992430203436946*^9}, 
   3.9924390585182323`*^9, {3.992592470770549*^9, 3.992592481818815*^9}, {
   3.9926255689243803`*^9, 3.992625569967749*^9}},
 CellLabel->"In[59]:=",ExpressionUUID->"9430138a-4a44-45a0-b47b-acbf50814b91"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "1", ",", "1", ",", "1", ",", "1", ",", "1"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.992624502959594*^9, 3.9926251519135733`*^9, 
  3.9926253219651403`*^9, 3.992625392185534*^9, 3.992625608010675*^9, 
  3.992625664059944*^9},
 CellLabel->"Out[60]=",ExpressionUUID->"06305290-4389-4601-aa1c-0103ac88b100"]
}, Open  ]],

Cell["\<\
I needed to slightly tweak my torque equation from the previous two models \
because the tail now has multiple joints. The torque on the tail now is a \
summation of the torque of every individual joint of the tail. This can be \
represented by the following:\
\>", "Text",
 CellChangeTimes->{{3.9924297840613823`*^9, 3.992429835642281*^9}, {
  3.992429979252898*^9, 3.992429986050687*^9}, {3.9924300328885393`*^9, 
  3.992430126788211*^9}, {3.992430162063816*^9, 3.992430178918331*^9}, {
  3.992430333248941*^9, 3.9924303736643457`*^9}, {3.992430412941063*^9, 
  3.992430481540447*^9}, {3.992430522211628*^9, 3.992430532630219*^9}, {
  3.9924424767413387`*^9, 3.9924424862241917`*^9}, {3.9925983497675037`*^9, 
  3.9925983531209393`*^9}, {3.9926032743732166`*^9, 3.9926033010374184`*^9}, {
  3.9926194097086897`*^9, 
  3.992619414944572*^9}},ExpressionUUID->"bded1b15-af10-4b41-836e-\
da9ce1d35239"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["\[Sum]", TraditionalForm]],ExpressionUUID->
  "bd06e690-e930-4343-8ac9-00c6232f8a73"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "5d606b05-de13-49ff-aa9e-3af8baad03fe"],
 " = ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "1"], TraditionalForm]],ExpressionUUID->
  "40df33fc-de70-44bd-9299-70753daa0caa"],
 ".x \:22c5 ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "89018ff8-2e81-417a-8c34-6a6d3869805c"],
 " + ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "2"], TraditionalForm]],ExpressionUUID->
  "6598a9a8-f275-4407-b3b4-b766c678dee0"],
 ".x \:22c5 ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "b4c7c7ca-e090-4bad-b6d5-ef8ad00e7316"],
 " + ... +  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "n"], TraditionalForm]],ExpressionUUID->
  "a9c0f8ca-d3a6-4fab-8999-2a2417611f5c"],
 ".x \:22c5 ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "tail"], TraditionalForm]],ExpressionUUID->
  "4c6f79a6-0e22-4527-bd5a-cb3582e427d7"]
}], "Text",
 CellChangeTimes->{{3.9924297840613823`*^9, 3.992429835642281*^9}, {
  3.992429979252898*^9, 3.992429986050687*^9}, {3.9924300328885393`*^9, 
  3.992430126788211*^9}, {3.992430162063816*^9, 3.992430178918331*^9}, {
  3.992430333248941*^9, 3.9924303736643457`*^9}, {3.992430412941063*^9, 
  3.992430481540447*^9}, {3.992430522211628*^9, 3.992430532630219*^9}, {
  3.9924424767413387`*^9, 3.9924424862241917`*^9}, {3.9925983497675037`*^9, 
  3.9925983531209393`*^9}, {3.9926032743732166`*^9, 3.992603282665472*^9}, {
  3.992614964764619*^9, 
  3.992614967459711*^9}},ExpressionUUID->"4fae1252-da38-4bd1-abde-\
8e2142fb31db"],

Cell["\<\
Implementing the summation in Wolfram Language by creating a list for each \
torque, and then summing them up using the Total function:\
\>", "CodeText",
 CellChangeTimes->{
  3.9924424909473658`*^9},ExpressionUUID->"1c31b9fb-8951-4c14-ac54-\
a869c76a2952"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"torqueVars", " ", "=", " ", 
    RowBox[{"Table", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"torqueAtPoint", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"listOfMasses", "[", 
         RowBox[{"[", "n", "]"}], "]"}], ",", " ", 
        RowBox[{"mVars", "[", 
         RowBox[{"[", "n", "]"}], "]"}]}], "]"}], ",", " ", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"n", ",", " ", "1", ",", " ", "numPoints"}], "}"}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Total", "[", "torqueVars", "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.992430537815002*^9, 3.992430544191409*^9}, {
  3.992592504839736*^9, 3.992592513579604*^9}, {3.992603307311762*^9, 
  3.9926033178954334`*^9}},
 CellLabel->"In[61]:=",ExpressionUUID->"56c445ee-b9a6-47fc-b9c9-ba111eaf41d6"],

Cell[TextData[{
 "Now, to create the equilibrium, I added ",
 Cell[BoxData[
  FormBox["\[Sum]", TraditionalForm]],ExpressionUUID->
  "75ba7881-7778-4d41-b2db-628935365ff4"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "78a793de-a033-4bd7-86eb-b339482220e2"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],ExpressionUUID->
  "44b7ec06-f23c-496e-a323-d7060f9e196a"],
 ", and set it equal to zero:"
}], "Text",
 CellChangeTimes->{{3.992430546160564*^9, 3.992430574793579*^9}, {
   3.992430647446924*^9, 3.992430686038555*^9}, {3.9924307408162403`*^9, 
   3.992430754278891*^9}, {3.9924385025856943`*^9, 3.992438584663288*^9}, {
   3.992438640573579*^9, 3.992438675778263*^9}, {3.9924389067790003`*^9, 
   3.9924389453976717`*^9}, {3.9924425400360193`*^9, 
   3.9924425947238703`*^9}, {3.9925983574591312`*^9, 3.992598382559623*^9}, 
   3.9926033217682343`*^9, {3.992619556788782*^9, 3.99261956214443*^9}, {
   3.99261970219724*^9, 
   3.992619704663866*^9}},ExpressionUUID->"657aa072-8fdf-4aa4-ba87-\
0dc10c1d8090"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "head"], TraditionalForm]],ExpressionUUID->
  "c7e735b9-76ce-471c-9c99-c0798b51aff0"],
 " + ",
 Cell[BoxData[
  FormBox["\[Sum]", TraditionalForm]],ExpressionUUID->
  "2d60a4d0-cd97-4f6f-9237-216f8a599ff9"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "tail"], TraditionalForm]],ExpressionUUID->
  "4a39efba-e91a-4342-84a1-98ba9767acca"],
 " = 0"
}], "Text",
 CellChangeTimes->{{3.992430546160564*^9, 3.992430574793579*^9}, {
   3.992430647446924*^9, 3.992430686038555*^9}, {3.9924307408162403`*^9, 
   3.992430754278891*^9}, {3.9924385025856943`*^9, 3.992438584663288*^9}, {
   3.992438640573579*^9, 3.992438675778263*^9}, {3.9924389067790003`*^9, 
   3.9924389453976717`*^9}, {3.9924425400360193`*^9, 
   3.9924425947238703`*^9}, {3.9925983574591312`*^9, 3.992598382559623*^9}, 
   3.9926033226463814`*^9},ExpressionUUID->"96fb99ec-d613-436f-825e-\
f45cc358ba64"],

Cell["\<\
This leads to another minimization problem similar to the one studied in the \
model V2:\
\>", "Text",
 CellChangeTimes->{{3.9926197178783073`*^9, 
  3.992619762430687*^9}},ExpressionUUID->"e311d49e-8300-4c13-b781-\
00939ff043fc"],

Cell[TextData[{
 "Before minimizing, I defined constraints for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", 
    RowBox[{"adj", " ", "n"}]], TraditionalForm]],ExpressionUUID->
  "94e8b172-16ea-4661-8733-2537cc364b07"],
 ":"
}], "CodeText",
 CellChangeTimes->{
  3.992442588732627*^9, {3.992598390880487*^9, 3.992598393113414*^9}, {
   3.992619203273819*^9, 3.992619210026739*^9}, {3.992619595186153*^9, 
   3.992619645347746*^9}, {3.992619770588867*^9, 
   3.992619775275998*^9}},ExpressionUUID->"11fbd3de-4e42-4595-85ab-\
c619dda0e3bd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"lowerBound", " ", "=", " ", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"upperBound", " ", "=", " ", 
   RowBox[{"2", "Pi"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"constraints", " ", "=", " ", 
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", " ", "<", " ", 
       RowBox[{"thetaAdjVars", "[", "1", "]"}], " ", "<", " ", "Pi"}], "}"}], 
     ",", "\n", "\t", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"lowerBound", " ", "<", " ", 
        RowBox[{"thetaAdjVars", "[", "n", "]"}], " ", "<", " ", 
        "upperBound"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"n", ",", " ", "2", ",", " ", "numPoints"}], "}"}]}], "]"}]}],
     "\n", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{
  3.992439038272984*^9, {3.992439138154262*^9, 3.9924391412218847`*^9}, {
   3.992592521011835*^9, 3.992592529515367*^9}, {3.992592806391341*^9, 
   3.9925928133969707`*^9}, {3.9926033282635098`*^9, 3.992603342243557*^9}, {
   3.9926084607081547`*^9, 3.9926084636081657`*^9}, {3.992619991175713*^9, 
   3.9926199922801523`*^9}},
 CellLabel->"In[63]:=",ExpressionUUID->"df0a9eab-e278-443f-bb60-75fb245d71e5"],

Cell["\<\
Defining the objective as the sum of the torques, and then minimizing the \
squared error:\
\>", "CodeText",
 CellChangeTimes->{{3.9924426128251333`*^9, 
  3.992442634112012*^9}},ExpressionUUID->"ff16a4f5-7f3c-4140-bcd3-\
7dafc6536cb4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"objective", " ", "=", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"torqueAtPoint", "[", 
        RowBox[{"mHead", ",", " ", "mH"}], "]"}], " ", "+", " ", 
       RowBox[{"Total", "[", "torqueVars", "]"}]}], ")"}], "^", "2"}]}], 
   ";"}], "\[IndentingNewLine]", "\t\t"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"output", " ", "=", " ", 
    RowBox[{"NMinimize", "[", "\n", "\t", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"objective", ",", " ", "constraints"}], "}"}], ",", "\n", "\t", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"thetaAdjVars", "[", "n", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", " ", "numPoints"}], "}"}]}], "]"}]}], "]"}]}], 
   ";"}], "\t"}]}], "Input",
 CellChangeTimes->{{3.992439015782524*^9, 3.992439028276684*^9}, {
   3.992439149208548*^9, 3.992439152034925*^9}, {3.992440359426385*^9, 
   3.992440360679812*^9}, 3.9925925398828697`*^9, {3.992592776418103*^9, 
   3.9925927836163893`*^9}, 3.9926196673697968`*^9, {3.992620895765126*^9, 
   3.9926209151694517`*^9}, {3.992620983503147*^9, 3.992620993862383*^9}, {
   3.992621032590085*^9, 3.992621059858259*^9}, {3.9926210955702553`*^9, 
   3.9926210995656767`*^9}, {3.9926211440015373`*^9, 3.99262122585642*^9}, {
   3.992621276925623*^9, 3.9926212860771646`*^9}, {3.992621348824047*^9, 
   3.992621358115594*^9}, {3.992621843896555*^9, 3.992621866837627*^9}},
 CellLabel->"In[66]:=",ExpressionUUID->"e0acab0c-eec8-4602-8212-3a664fbca3b5"],

Cell[TextData[{
 "With each of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "adj"], TraditionalForm]],ExpressionUUID->
  "5a7de333-7253-4497-8f1b-85de5aacc6ef"],
 " values defined, I could plug them back into the symbolic expressions and \
view the outputs by reassigning the physical values from output into the \
symbolic values of thetaAdjVars, and then recomputing the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "n"], TraditionalForm]],ExpressionUUID->
  "fe3a65a3-7da0-460e-9ed7-02d67431d915"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "n"], TraditionalForm]],ExpressionUUID->
  "9b4b0d88-cada-487c-a0cb-5c38368cc819"],
 " values:"
}], "Text",
 CellChangeTimes->{{3.992439229258428*^9, 3.992439298651322*^9}, {
  3.9924393352078667`*^9, 3.992439353840773*^9}, {3.992598566295515*^9, 
  3.992598601897092*^9}, {3.9925987402180557`*^9, 
  3.992598740466013*^9}},ExpressionUUID->"5b7c3445-f937-4311-9cca-\
a32aad5103a5"],

Cell["\<\
Assigning thetaAdjVars to be actual values instead of symbolic ones:\
\>", "CodeText",
 CellChangeTimes->{{3.992442647272934*^9, 3.992442659142373*^9}, {
  3.992619799726254*^9, 3.992619803713193*^9}, {3.9926210110079403`*^9, 
  3.992621017291287*^9}},ExpressionUUID->"820ca8e8-534c-4d48-9c1e-\
b9a00b68b339"],

Cell[BoxData[
 RowBox[{
  RowBox[{"thetaAdjs", " ", "=", " ", 
   RowBox[{"Values", "[", 
    RowBox[{"output", "[", 
     RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ";"}]], "Input",
